---
import Icon from './Icon.astro'

interface Props {
	href?: string | null
	icon: string
	title: string
	sub: string
	arrow?: string
	accent?: boolean
	target?: string
}
const { href = null, icon, title, sub, arrow = 'chevron-right', accent = false, target } = Astro.props
const wrapCls = `action-tile flex min-w-0 w-full cursor-pointer items-center gap-4 rounded-lg border px-5.5 py-5 text-left ${accent ? 'border-[rgba(255,162,41,.32)] bg-orange-soft' : 'border-line-2 bg-s1'}`
const iconCls = `flex h-11.5 w-11.5 shrink-0 items-center justify-center rounded-md ${accent ? 'bg-accent text-[#2C1700]' : 'bg-white/[.06] text-accent'}`
const titleCls = `block text-[16.5px] font-bold ${accent ? 'text-accent' : 'text-tx'}`
---

{
	href ? (
		<a href={href} target={target} class={wrapCls}>
			<span class={iconCls}>
				<Icon name={icon} size={22} stroke={2} />
			</span>
			<span class="min-w-0 flex-1">
				<span class={titleCls}>{title}</span>
				<span class="mt-0.75 block break-words text-[13.5px] text-tx-3 [overflow-wrap:anywhere]">{sub}</span>
			</span>
			<Icon name={arrow} size={18} class="text-tx-3" />
		</a>
	) : (
		<button type="submit" class={wrapCls}>
			<span class={iconCls}>
				<Icon name={icon} size={22} stroke={2} />
			</span>
			<span class="min-w-0 flex-1">
				<span class={titleCls}>{title}</span>
				<span class="mt-0.75 block break-words text-[13.5px] text-tx-3 [overflow-wrap:anywhere]">{sub}</span>
			</span>
			<Icon name={arrow} size={18} class="text-tx-3" />
		</button>
	)
}

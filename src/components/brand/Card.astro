---
interface Props {
	tone?: 'dark' | 'cream'
	raised?: boolean
	pad?: number
	class?: string
	id?: string
}
const { tone = 'dark', raised = false, pad = 28, class: className = '', id } = Astro.props
const cls = ['card', tone === 'dark' ? 'card--dark' : 'card--cream', raised ? 'card--raised' : '', className]
	.filter(Boolean)
	.join(' ')
// .card already pads 28px; only emit an inline override when a caller asks for a different value.
const padStyle = pad === 28 ? undefined : `padding:${pad}px`
---

<div id={id} class={cls} style={padStyle}>
	<slot />
</div>

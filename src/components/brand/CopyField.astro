---
import Icon from './Icon.astro'

interface Props {
	value: string
	label?: string
	big?: boolean
	mono?: boolean
}
const { value, label, big = false, mono = true } = Astro.props
const valueStyle = [
	'flex:1',
	`font-family:${mono ? 'var(--mono)' : 'var(--sans)'}`,
	`font-size:${big ? '30px' : '15px'}`,
	'font-weight:700',
	`letter-spacing:${mono ? (big ? '.2em' : '.08em') : 'normal'}`,
	`color:${big ? 'var(--accent)' : 'var(--tx)'}`,
	'word-break:break-all',
].join(';')
---

<div>
	{label && <div style="font-size:13px;font-weight:600;color:var(--tx-3);margin-bottom:8px">{label}</div>}
	<button
		type="button"
		class="copy-btn"
		data-copy={value}
		style={`display:flex;align-items:center;gap:12px;width:100%;padding:${big ? '14px 18px' : '11px 15px'};border-radius:var(--r-md);text-align:left;background:rgba(0,0,0,.26);border:1px solid var(--line);cursor:pointer`}
	>
		<span style={valueStyle}>{value}</span>
		<span
			class="copy-ind"
			style="color:var(--tx-3);display:flex;gap:6px;align-items:center;font-size:13px;font-weight:600;flex-shrink:0"
		>
			<Icon name="copy" size={17} stroke={2.2} />
		</span>
	</button>
</div>

---
import Icon from './Icon.astro'
import { getContent } from '../../lib/content'

interface Props {
	value: string
	label?: string
	big?: boolean
	mono?: boolean
	locale?: 'da' | 'en'
}
const { value, label, big = false, mono = true, locale = 'da' } = Astro.props
// Icon is decorative, so spell out the button's purpose + value for screen readers.
const copyAria = `${getContent(locale, 'common').copy.action} ${value}`
const btnCls = `copy-btn flex w-full cursor-pointer items-center gap-3 rounded-md border border-line bg-black/[0.26] text-left ${big ? 'px-4.5 py-3.5' : 'px-3.75 py-2.75'}`
const valueCls = [
	'min-w-0 flex-1 break-all font-bold',
	mono ? 'font-mono' : 'font-sans',
	big ? 'text-[30px]' : 'text-[15px]',
	big ? 'text-accent' : 'text-tx',
	mono ? (big ? 'tracking-[0.2em]' : 'tracking-[0.08em]') : '',
].join(' ')
---

<div>
	{label && <div class="mb-2 text-[13px] font-semibold text-tx-3">{label}</div>}
	<button type="button" class={btnCls} data-copy={value} aria-label={copyAria}>
		<span class={valueCls}>{value}</span>
		<span class="copy-ind flex shrink-0 items-center gap-1.5 text-[13px] font-semibold text-tx-3">
			<Icon name="copy" size={17} stroke={2.2} />
		</span>
	</button>
</div>

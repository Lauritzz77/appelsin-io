---
// Lucide-flavored icon set (paths ported from the Claude-Design bundle's theme.jsx).
// stroke = currentColor. A path token of "circle:cx,cy,r" draws a <circle>.
interface Props {
	name: string
	size?: number
	stroke?: number
	fill?: 'none' | 'currentColor'
	class?: string
}
const ICONS: Record<string, string> = {
	'arrow-left': 'M19 12H5M12 19l-7-7 7-7',
	'arrow-right': 'M5 12h14M12 5l7 7-7 7',
	'chevron-down': 'M6 9l6 6 6-6',
	'chevron-right': 'M9 18l6-6-6-6',
	'chevron-left': 'M15 18l-6-6 6-6',
	download: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3',
	trash: 'M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2',
	pencil: 'M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z',
	check: 'M20 6L9 17l-5-5',
	plus: 'M12 5v14M5 12h14',
	x: 'M18 6L6 18M6 6l12 12',
	camera: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z|circle:12,13,4',
	image: 'M3 3h18a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z|M3 16l5-5 4 4 4-4 5 5|circle:8.5,8.5,1.5',
	calendar: 'M3 4h18a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1zM16 2v4M8 2v4M2 10h20',
	monitor: 'M2 4h20a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1zM8 21h8M12 17v4',
	qr: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h3v3h-3zM20 14v3M17 20h4v1M14 17v4',
	copy: 'M9 9h11a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V10a1 1 0 0 1 1-1zM5 15H4a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h11a1 1 0 0 1 1 1v1',
	external: 'M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3',
	signout: 'M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9',
	mail: 'M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z|M3 7l9 6 9-6',
	info: 'M12 16v-4M12 8h.01|circle:12,12,10',
	clock: 'M12 7v5l3 2|circle:12,12,9',
	link: 'M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1.5 1.5M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1.5-1.5',
	refresh: 'M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5',
	play: 'M6 4l14 8-14 8z',
	share: 'M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7M16 6l-4-4-4 4M12 2v14',
	lock: 'M5 11h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1zM8 11V7a4 4 0 0 1 8 0v4',
	globe: 'M2 12h20|circle:12,12,10|M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z',
	grid: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
	list: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
	sparkle: 'M12 2l2.2 6.5L21 11l-6.8 2.5L12 20l-2.2-6.5L3 11l6.8-2.5z',
	heart: 'M20.8 5.6a5 5 0 0 0-7-.3L12 6.8l-1.8-1.5a5 5 0 0 0-7 7.2L12 21l8.8-8.5a5 5 0 0 0 0-6.9z',
	shield: 'M12 2l8 3v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V5z',
	file: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z|M14 2v6h6',
	card: 'M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z|M1 10h22',
	upload: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 8l5-5 5 5M12 3v12',
	zap: 'M13 2L3 14h8l-1 8 10-12h-8z',
	users: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2|circle:9,7,4|M22 21v-2a4 4 0 0 0-3-3.9M16 3.1a4 4 0 0 1 0 7.8',
}
const { name, size = 20, stroke = 2, fill = 'none', class: className = '' } = Astro.props
const raw = ICONS[name] || ''
const parts = raw.split('|')
const circles = parts
	.filter((p) => p.startsWith('circle:'))
	.map((p) => p.slice(7).split(','))
const paths = parts.filter((p) => p && !p.startsWith('circle:'))
---

<svg
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill={fill === 'currentColor' ? 'currentColor' : 'none'}
	stroke="currentColor"
	stroke-width={stroke}
	stroke-linecap="round"
	stroke-linejoin="round"
	class:list={['block shrink-0', className]}
	aria-hidden="true"
>
	{paths.map((d) => <path d={d} />)}
	{circles.map(([cx, cy, r]) => <circle cx={cx} cy={cy} r={r} />)}
</svg>

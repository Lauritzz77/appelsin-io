---
// appelsin.io brand mark. Uses OUR logo asset (not the design bundle's).
// logo.svg has a white wordmark (for dark surfaces); logo-ink.svg is the same
// artwork with a navy wordmark (for cream surfaces).
interface Props {
	size?: number // rendered height in px (ignored when `class` controls the size)
	surface?: 'cream' | 'dark'
	href?: string | null
	class?: string
	alt?: string
}
const { size = 48, surface = 'dark', href = null, class: className = '', alt = 'appelsin.io' } = Astro.props
const src = surface === 'cream' ? '/logo-ink.svg' : '/logo.svg'
// drop-shadow lifts the white wordmark on dark surfaces; none needed on cream
const shadowClass = surface === 'cream' ? '' : 'drop-shadow-[0_2px_6px_rgba(0,0,0,0.18)]'
// When the caller passes utility classes, they own the img's size + display; otherwise
// fall back to the size-prop inline style (width:auto keeps the square aspect ratio).
const imgClass = [className, shadowClass].filter(Boolean).join(' ') || undefined
const imgStyle = className ? undefined : `height:${size}px;width:auto;display:block`
const imgHeight = className ? undefined : size
---

{
	href ? (
		<a href={href} aria-label={alt} class="inline-block leading-[0]">
			<img src={src} alt={alt} height={imgHeight} class={imgClass} style={imgStyle} />
		</a>
	) : (
		<img src={src} alt={alt} height={imgHeight} class={imgClass} style={imgStyle} />
	)
}

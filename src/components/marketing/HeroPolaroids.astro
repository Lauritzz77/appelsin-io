---
// Tilted Polaroid cluster for the navy hero. Placeholder party photos live in
// /public/marketing (swap for real ones any time). Captions use Caveat.
interface Props {
	locale?: 'da' | 'en'
}
const { locale = 'da' } = Astro.props
const cards = [
	{
		src: '/marketing/p01.jpg',
		cap: 'Anna & Jonas ♥',
		ar: '4 / 5',
		style: 'width:47%;left:1%;top:0;transform:rotate(-5deg);z-index:2',
	},
	{
		src: '/marketing/p02.jpg',
		cap: locale === 'en' ? 'The crew' : 'Hele banden',
		ar: '5 / 4',
		style: 'width:45%;right:0;top:10%;transform:rotate(6deg);z-index:1',
	},
	{
		src: '/marketing/p03.jpg',
		cap: locale === 'en' ? 'Last dance' : 'Sidste dans',
		ar: '4 / 5',
		style: 'width:46%;left:22%;bottom:0;transform:rotate(-2deg);z-index:3',
	},
]
---

<div class="pol-cluster" aria-hidden="true">
	{
		cards.map((c) => (
			<div class="pol" style={c.style}>
				<div class="pol-photo" style={`aspect-ratio:${c.ar}`}>
					<img src={c.src} alt="" />
				</div>
				<div class="pol-cap">{c.cap}</div>
			</div>
		))
	}
</div>

---
import type { Locale } from '../../lib/i18n'
import Icon from '../brand/Icon.astro'

interface Props {
	locale?: Locale
	kind: 'terms' | 'privacy'
	badge: string
	title: string
	paras: string[]
	contactPrefix: string
	contactSuffix: string
	backLabel: string
}
const { locale = 'da', kind, badge, title, paras, contactPrefix, contactSuffix, backLabel } = Astro.props
const home = locale === 'en' ? '/en' : '/'
---

<div class="mkt screen-root">
	<div class="mx-auto max-w-[760px] px-10 pt-7 pb-20">
		<a href={home} class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-ink-2">
			<Icon name="arrow-left" size={18} />{backLabel}
		</a>
		<div class="fu mt-11">
			<div
				class="mb-[18px] inline-flex items-center gap-[9px] rounded-full bg-peach px-[13px] py-1.5 text-[13.5px] font-semibold text-orange-deep"
			>
				<Icon name={kind === 'terms' ? 'file' : 'shield'} size={15} />{badge}
			</div>
			<h1 class="m-0 text-[clamp(38px,5cqw,56px)] font-extrabold tracking-[-0.02em] text-ink">
				{title}
			</h1>
			<div class="mt-8 flex flex-col gap-6">
				{paras.map((para) => <p class="m-0 text-[18px] leading-[1.72] text-warm-body">{para}</p>)}
				<p class="m-0 text-[18px] leading-[1.72] text-warm-body">
					{contactPrefix}<a
						href="mailto:hello@appelsin.io"
						class="font-semibold text-orange-deep underline">hello@appelsin.io</a
					>{contactSuffix}
				</p>
			</div>
		</div>
	</div>
</div>

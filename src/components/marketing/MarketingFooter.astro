---
import type { Locale } from '../../lib/i18n'
import Logo from '../brand/Logo.astro'

interface Props {
	locale?: Locale
	isSignedIn?: boolean
	onDark?: boolean
}
const { locale = 'da', isSignedIn = false, onDark = false } = Astro.props
const p = locale === 'en' ? '/en' : ''
const t =
	locale === 'en'
		? { app: 'Your events', login: 'Log in', terms: 'Terms', privacy: 'Privacy' }
		: { app: 'Dine events', login: 'Login', terms: 'Vilkår', privacy: 'Privatliv' }
const primaryHref = isSignedIn ? `${p}/app` : `${p}/login`
const primaryLabel = isSignedIn ? t.app : t.login
const borderColor = onDark ? 'var(--line)' : 'var(--cream-line)'
const linkColor = onDark ? 'var(--tx-2)' : 'var(--ink-2)'
// On the navy band the footer butts up against the FAQ band, so no top margin
// (which would otherwise escape the band and reveal the cream body behind).
const marginTop = onDark ? '0' : '40px'
---

<footer
	style={`border-top:1px solid ${borderColor};margin-top:${marginTop};padding:40px 0 64px;display:flex;flex-wrap:wrap;gap:24px;align-items:center;justify-content:space-between`}
>
	<Logo surface={onDark ? 'dark' : 'cream'} size={42} />
	<div style={`display:flex;gap:26px;flex-wrap:wrap;font-size:15.5px;font-weight:600;color:${linkColor}`}>
		<a href={primaryHref} style="cursor:pointer">{primaryLabel}</a>
		<a href={`${p}/terms`} style="cursor:pointer">{t.terms}</a>
		<a href={`${p}/privacy`} style="cursor:pointer">{t.privacy}</a>
		<a href="mailto:hello@appelsin.io">hello@appelsin.io</a>
	</div>
</footer>

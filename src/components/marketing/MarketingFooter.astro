---
import type { Locale } from '../../lib/i18n'
import { localisePath } from '../../lib/i18n'
import { getContent } from '../../lib/content'
import Logo from '../brand/Logo.astro'

interface Props {
	locale?: Locale
	isSignedIn?: boolean
	onDark?: boolean
}
const { locale = 'da', isSignedIn = false, onDark = false } = Astro.props
const nav = getContent(locale, 'common').nav
const primaryHref = isSignedIn ? localisePath('/app', locale) : localisePath('/login', locale)
const primaryLabel = isSignedIn ? nav.events : nav.login
// On the navy band the footer butts up against the FAQ band, so no top margin
// (which would otherwise escape the band and reveal the cream body behind).
---

<footer
	class:list={[
		'flex flex-wrap items-center justify-between gap-6 border-t pt-10 pb-16',
		onDark ? 'mt-0 border-line' : 'mt-10 border-cream-line',
	]}
>
	<Logo surface={onDark ? 'dark' : 'cream'} class="w-20 h-20 block" />
	<div class:list={['flex flex-wrap gap-6.5 text-[15.5px] font-semibold', onDark ? 'text-tx-2' : 'text-ink-2']}>
		<a href={primaryHref} class="cursor-pointer">{primaryLabel}</a>
		<a href={localisePath('/terms', locale)} class="cursor-pointer">{nav.terms}</a>
		<a href={localisePath('/privacy', locale)} class="cursor-pointer">{nav.privacy}</a>
		<a href="mailto:hello@appelsin.io">hello@appelsin.io</a>
	</div>
</footer>

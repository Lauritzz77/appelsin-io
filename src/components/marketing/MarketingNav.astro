---
import type { Locale } from '../../lib/i18n'
import { localisePath } from '../../lib/i18n'
import { getContent } from '../../lib/content'
import Logo from '../brand/Logo.astro'
import Button from '../brand/Button.astro'

interface Props {
	locale?: Locale
	isSignedIn?: boolean
	onDark?: boolean
}
const { locale = 'da', isSignedIn = false, onDark = false } = Astro.props
const nav = getContent(locale, 'common').nav
const home = localisePath('/', locale)
---

<nav class="mkt-nav">
	<Logo href={home} surface={onDark ? 'dark' : 'cream'} class="w-20 h-20 @max-[920px]:w-15 @max-[920px]:h-15 block" />
	<div class="mkt-nav-links gap-7 @max-[920px]:gap-5">
		{isSignedIn && <a href={localisePath('/app', locale)}>{nav.events}</a>}
		<a href={localisePath('/terms', locale)} class="mkt-nav-sub">{nav.terms}</a>
		<a href={localisePath('/privacy', locale)} class="mkt-nav-sub">{nav.privacy}</a>
		{
			isSignedIn ? (
				<a id="mkt-signout" href={home} data-home={home}>
					{nav.logout}
				</a>
			) : (
				<span class="mkt-cta">
					<Button href={localisePath('/login', locale)} size="sm">
						{nav.login}
					</Button>
				</span>
			)
		}
	</div>
</nav>

<script>
	document.getElementById('mkt-signout')?.addEventListener('click', async (e) => {
		e.preventDefault()
		const target = e.currentTarget as HTMLAnchorElement
		await fetch('/api/auth/sign-out', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: '{}',
		})
		window.location.href = target.dataset.home || '/'
	})
</script>

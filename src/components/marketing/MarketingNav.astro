---
import type { Locale } from '../../lib/i18n'
import Logo from '../brand/Logo.astro'
import Button from '../brand/Button.astro'

interface Props {
	locale?: Locale
	isSignedIn?: boolean
	onDark?: boolean
}
const { locale = 'da', isSignedIn = false, onDark = false } = Astro.props
const p = locale === 'en' ? '/en' : ''
const t =
	locale === 'en'
		? { app: 'Your events', login: 'Log in', logout: 'Log out', terms: 'Terms', privacy: 'Privacy' }
		: { app: 'Dine events', login: 'Login', logout: 'Log ud', terms: 'Vilkår', privacy: 'Privatliv' }
const home = p || '/'
---

<nav class="mkt-nav">
	<Logo href={home} surface={onDark ? 'dark' : 'cream'} class="w-20 h-20 @max-[920px]:w-15 @max-[920px]:h-15 block" />
	<div class="mkt-nav-links gap-7 @max-[920px]:gap-5">
		{isSignedIn && <a href={`${p}/app`}>{t.app}</a>}
		<a href={`${p}/terms`} class="mkt-nav-sub">{t.terms}</a>
		<a href={`${p}/privacy`} class="mkt-nav-sub">{t.privacy}</a>
		{
			isSignedIn ? (
				<a id="mkt-signout" href={home} data-home={home}>
					{t.logout}
				</a>
			) : (
				<span class="mkt-cta">
					<Button href={`${p}/login`} size="sm">
						{t.login}
					</Button>
				</span>
			)
		}
	</div>
</nav>

<script>
	document.getElementById('mkt-signout')?.addEventListener('click', async (e) => {
		e.preventDefault()
		const target = e.currentTarget as HTMLAnchorElement
		await fetch('/api/auth/sign-out', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: '{}',
		})
		window.location.href = target.dataset.home || '/'
	})
</script>

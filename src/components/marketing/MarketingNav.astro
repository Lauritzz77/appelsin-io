---
import type { Locale } from '../../lib/i18n'
import Logo from '../brand/Logo.astro'
import Button from '../brand/Button.astro'

interface Props {
	locale?: Locale
	isSignedIn?: boolean
	onDark?: boolean
}
const { locale = 'da', isSignedIn = false, onDark = false } = Astro.props
const p = locale === 'en' ? '/en' : ''
const t =
	locale === 'en'
		? { app: 'Your events', login: 'Log in', terms: 'Terms', privacy: 'Privacy', cta: 'Get started' }
		: { app: 'Dine events', login: 'Login', terms: 'Vilkår', privacy: 'Privatliv', cta: 'Kom i gang' }
const home = p || '/'
const primaryHref = isSignedIn ? `${p}/app` : `${p}/login`
const primaryLabel = isSignedIn ? t.app : t.login
---

<nav class="mkt-nav">
	<Logo href={home} surface={onDark ? 'dark' : 'cream'} size={50} />
	<div class="mkt-nav-links">
		<a href={primaryHref}>{primaryLabel}</a>
		<a href={`${p}/terms`}>{t.terms}</a>
		<a href={`${p}/privacy`}>{t.privacy}</a>
		<span class="mkt-cta">
			<Button href={isSignedIn ? `${p}/app` : `${p}/login`} size="sm">{t.cta}</Button>
		</span>
	</div>
</nav>

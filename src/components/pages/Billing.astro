---
import type { Locale } from '../../lib/i18n'
import { localisePath, numberLocale } from '../../lib/i18n'
import { getContent } from '../../lib/content'
import Layout from '../../layouts/Layout.astro'
import Icon from '../brand/Icon.astro'
import Card from '../brand/Card.astro'
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, desc } from 'drizzle-orm'
import * as schema from '../../db/schema'
import { SUBSCRIPTION_PLANS } from '../../lib/billing'

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const t = getContent(locale, 'billing')
const numLocale = numberLocale(locale)

const host = Astro.locals.host!
const db = drizzle(env.DB, { schema })

const [hostRow] = await db
	.select({ stripeCustomerId: schema.hosts.stripeCustomerId, plan: schema.hosts.plan })
	.from(schema.hosts)
	.where(eq(schema.hosts.id, host.id))
	.limit(1)

const [subscription] = await db
	.select()
	.from(schema.subscriptions)
	.where(eq(schema.subscriptions.hostId, host.id))
	.limit(1)

const purchases = await db
	.select({
		id: schema.eventPurchases.id,
		eventId: schema.eventPurchases.eventId,
		tier: schema.eventPurchases.tier,
		stripeSessionId: schema.eventPurchases.stripeSessionId,
	})
	.from(schema.eventPurchases)
	.where(eq(schema.eventPurchases.hostId, host.id))
	.orderBy(desc(schema.eventPurchases.id))
	.limit(20)

const justSubscribed = Astro.url.searchParams.get('subscribed') === '1'
const noCustomer = Astro.url.searchParams.get('nocustomer') === '1'

const onPro = hostRow?.plan === 'pro'
const hasCustomer = Boolean(hostRow?.stripeCustomerId)
const cancelsAtPeriodEnd = subscription?.cancelAtPeriodEnd && subscription.currentPeriodEnd
// Only surface the subscription upgrade buttons when both Stripe Price IDs
// are configured. Without them /api/billing/subscribe would 500.
const subscriptionsEnabled =
	Boolean(env.STRIPE_PRICE_PRO_MONTHLY) && Boolean(env.STRIPE_PRICE_PRO_YEARLY)

function formatPlanPrice(priceCents: number, currency: string, interval: 'month' | 'year') {
	const amount = priceCents / 100
	const money = new Intl.NumberFormat(numLocale, {
		style: 'currency',
		currency: currency.toUpperCase(),
		maximumFractionDigits: 0,
	}).format(amount)
	return `${money}/${interval === 'month' ? t.perMonth : t.perYear}`
}
---

<Layout title={t.meta.title} locale={locale}>
	<div class="app screen-root">
		<div class="fu mx-auto max-w-220 px-7 pt-7 pb-20">
			<a href={localisePath('/app', locale)} class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-tx-3">
				<Icon name="arrow-left" size={18} />{t.back}
			</a>

			<div class="mt-5.5 mb-7">
				<h1 class="m-0 text-[clamp(30px,5cqw,42px)] font-extrabold tracking-[-0.02em]">{t.heading}</h1>
				<p class="mt-2 text-base text-tx-3">{t.subhead}</p>
			</div>

			{
				justSubscribed && (
					<div class="mb-5 rounded-md border border-[rgba(52,211,153,.3)] bg-live-bg px-4.5 py-3.25 text-sm text-live">
						{t.subscribedBanner}
					</div>
				)
			}
			{
				noCustomer && (
					<div class="mb-5 rounded-md border border-[rgba(255,162,41,.3)] bg-orange-soft px-4.5 py-3.25 text-sm text-accent">
						{t.noCustomerBanner}
					</div>
				)
			}

			<Card pad={24} class="flex flex-wrap items-start justify-between gap-4.5">
				<div>
					<p class="text-[12px] uppercase tracking-[0.08em] text-tx-3">{t.currentPlan}</p>
					<p class="mt-1 text-[26px] font-extrabold text-tx">{onPro ? 'Pro' : 'Free'}</p>
					{
						subscription && (
							<p class="mt-1.5 text-[13px] text-tx-3">
								{t.statusPrefix}{subscription.status}
								{cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<>{t.cancels}{new Date(subscription.currentPeriodEnd).toLocaleDateString(numLocale)}</>
								)}
								{!cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<>{t.renews}{new Date(subscription.currentPeriodEnd).toLocaleDateString(numLocale)}</>
								)}
							</p>
						)
					}
				</div>
				{
					hasCustomer && (
						<form method="post" action="/api/billing/portal">
							<button type="submit" class="btn btn--secondary btn--sm">
								{t.manageStripe}
								<Icon name="external" size={15} stroke={2.2} />
							</button>
						</form>
					)
				}
			</Card>

			{
				!onPro && subscriptionsEnabled && (
					<section class="mt-8">
						<div class="app-sec-label">{t.upgradeTitle}</div>
						<p class="-mt-1.5 mb-4 max-w-140 text-[14.5px] text-tx-3">
							{t.upgradeDesc}
						</p>
						<div class="evt-actions">
							{Object.entries(SUBSCRIPTION_PLANS).map(([planId, plan]) => (
								<form method="post" action="/api/billing/subscribe" class="contents">
									<input type="hidden" name="plan" value={planId} />
									<button type="submit" class="action-tile flex w-full cursor-pointer items-center justify-between gap-4 rounded-lg border border-[rgba(255,162,41,.32)] bg-orange-soft px-5.5 py-5 text-left">
										<span>
											<span class="block text-[16.5px] font-bold text-accent">{plan.label}</span>
											<span class="mt-0.75 block text-[13.5px] text-tx-3">
												{plan.interval === 'month' ? t.payMonthly : t.payYearly}
											</span>
										</span>
										<span class="font-mono font-bold text-accent">
											{formatPlanPrice(plan.priceCents, plan.currency, plan.interval)}
										</span>
									</button>
								</form>
							))}
						</div>
					</section>
				)
			}

			<section class="mt-8">
				<div class="app-sec-label">
					{t.eventPasses} {purchases.length === 0 ? t.noneYet : `(${purchases.length})`}
				</div>
				{
					purchases.length > 0 && (
						<div class="overflow-hidden rounded-xl border border-line-2 bg-s1">
							{purchases.map((p, i) => (
								<div class={`flex items-center justify-between gap-3 px-5 py-4 text-sm ${i ? 'border-t border-line-2' : ''}`}>
									<div>
										<div class="font-bold capitalize text-tx">{p.tier}{t.passSuffix}</div>
										<div class="mt-0.5 font-mono text-[12px] text-tx-4">{p.stripeSessionId}</div>
									</div>
									{p.eventId && (
										<a href={localisePath(`/app/events/${p.eventId}`, locale)} class="whitespace-nowrap text-[13px] font-semibold text-accent">
											{t.viewEvent}
										</a>
									)}
								</div>
							))}
						</div>
					)
				}
			</section>
		</div>
	</div>
</Layout>

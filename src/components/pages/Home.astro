---
import type { Locale } from '../../lib/i18n'
import { localisePath } from '../../lib/i18n'
import { getContent } from '../../lib/content'
import { TIERS, formatPrice, type Tier as TierId } from '../../lib/tiers'
import Layout from '../../layouts/Layout.astro'
import MarketingNav from '../marketing/MarketingNav.astro'
import MarketingFooter from '../marketing/MarketingFooter.astro'
import HeroPolaroids from '../marketing/HeroPolaroids.astro'
import PlanCard from '../marketing/PlanCard.astro'
import Button from '../brand/Button.astro'
import Icon from '../brand/Icon.astro'
import Accordion from '../brand/Accordion.astro'

interface Props {
	locale: Locale
	isSignedIn: boolean
}
const { locale, isSignedIn } = Astro.props
const t = getContent(locale, 'home')

// Structural tier order + emphasis; the per-tier copy lives in home.json keyed by id.
const tiers: { id: TierId; featured?: boolean }[] = [
	{ id: 'free' },
	{ id: 'basic', featured: true },
	{ id: 'gold' },
]

function ctaHref(tier: TierId): string {
	const dest = localisePath(`/app/events/new?tier=${tier}`, locale)
	if (isSignedIn) return dest
	return localisePath(`/login?next=${encodeURIComponent(dest)}`, locale)
}
---

<Layout title={t.meta.title} description={t.meta.description} locale={locale} surface="cream">
	<div class="mkt screen-root">
		{/* NAVY HERO BAND (nav + hero) */}
		<div class="hero-band band-navy">
			<div class="mkt-wrap">
				<MarketingNav locale={locale} isSignedIn={isSignedIn} onDark />

				<section class="hero fu py-20">
					<div>
						<div class="font-hand mb-4 text-2xl font-bold tracking-[0.14em] text-accent">
							{t.hero.kicker}
						</div>
						<h1 class="hero-h1 uppercase">
							{
								t.hero.headingLines.map((line, i) => (
									<>
										{i > 0 && <br />}
										{line}
									</>
								))
							}
						</h1>
						<p class="mt-5.5 mb-8 max-w-120 text-[19.5px] leading-[1.6] text-tx-2">
							{t.hero.subhead}
						</p>
						<div class="hero-cta flex flex-wrap gap-3.5">
							<Button href="#pricing" size="lg">{t.hero.cta}</Button>
						</div>
						<div class="mt-7.5 flex flex-wrap items-center gap-1 @min-[920px]:gap-2.5 text-[14.5px] text-tx-3">
							{
								t.hero.tags.map((tag, i) => (
									<>
										{i > 0 && <span class="opacity-40">·</span>}
										<span>{tag}</span>
									</>
								))
							}
						</div>
					</div>
					<HeroPolaroids captions={t.hero.polaroids} />
				</section>
			</div>
		</div>

		{/* CREAM: how it works + pricing */}
		<div class="mkt-wrap">
			<section class="pt-15 @min-[920px]:pt-24 pb-12 @min-[920px]:pb-16">
				<div class="steps">
					{
						t.steps.map((s) => (
							<div class="rounded-xl border border-cream-line bg-white p-7 shadow-cream-sm">
								<div class="mb-4 flex items-center gap-3.5">
									<span class="flex h-13 w-13 items-center justify-center rounded-md bg-peach">
										<Icon name={s.icon} size={26} stroke={2} />
									</span>
									<span class="font-mono text-3xl font-bold">{s.num}</span>
								</div>
								<div class="mb-2 text-[21px] font-bold text-ink">{s.title}</div>
								<div class="text-base leading-[1.6] text-warm-body">{s.desc}</div>
							</div>
						))
					}
				</div>
			</section>

			<section id="pricing" class="scroll-mt-6 pt-7 pb-15 @min-[920px]:pb-24">
				<div class="mb-10 text-center">
					<h2 class="m-0 text-[clamp(32px,4cqw,46px)] font-extrabold tracking-[-0.02em] text-ink">{t.pricing.heading}</h2>
					<p class="mt-3 text-[18px] text-warm-body">{t.pricing.subhead}</p>
				</div>
				<div class="pricing">
					{
						tiers.map(({ id, featured }) => {
							const c = t.pricing.cards[id]
							return (
								<PlanCard
									name={TIERS[id].label}
									price={formatPrice(id, locale)}
									priceNote={c.priceNote}
									tagline={c.tagline}
									features={c.features}
									cta={c.cta}
									href={ctaHref(id)}
									featured={featured}
									popularLabel={t.pricing.popularLabel}
								/>
							)
						})
					}
				</div>
				<p class="mt-7 text-center text-[15px] text-warm-muted">
					{t.pricing.footnote}
				</p>
			</section>
		</div>

		{/* NAVY FAQ BAND */}
		<div class="faq-band band-navy">
			<div class="mx-auto max-w-215 px-5 @min-[920px]:px-10">
				<section class="pt-15 pb-16">
					<div class="mb-9 text-center">
						<div class="font-hand text-2xl font-semibold text-accent">{t.faq.kicker}</div>
						<h2 class="mt-0.5 text-[clamp(30px,4cqw,42px)] font-extrabold tracking-[-0.02em] text-white">
							{t.faq.heading}
						</h2>
					</div>
					<Accordion items={t.faq.items} tone="cream" />
				</section>
			</div>
		</div>

		{/* NAVY footer */}
		<div class="band-navy">
			<div class="mkt-wrap">
				<MarketingFooter locale={locale} isSignedIn={isSignedIn} onDark />
			</div>
		</div>
	</div>
</Layout>

---
import type { Locale } from '../../lib/i18n'
import { localisePath } from '../../lib/i18n'
import { getContent } from '../../lib/content'
import Layout from '../../layouts/Layout.astro'
import Logo from '../brand/Logo.astro'
import Icon from '../brand/Icon.astro'
import Button from '../brand/Button.astro'
import { safeNext } from '../../lib/safe-next'

interface Props {
	locale: Locale
}
const { locale } = Astro.props
const t = getContent(locale, 'login')

const defaultNext = localisePath('/app/events/new', locale)
const requestedNext = safeNext(Astro.url.searchParams.get('next'), defaultNext)
const createEventNext = new URL(defaultNext, Astro.url.origin)
const parsedNext = new URL(requestedNext, Astro.url.origin)
const appPath = localisePath('/app', locale)
const next =
	parsedNext.pathname === createEventNext.pathname
		? `${appPath}?fromLogin=1&createNext=${encodeURIComponent(parsedNext.pathname + parsedNext.search)}`
		: requestedNext
---

<Layout title={t.meta.title} locale={locale}>
	<div class="app screen-root flex min-h-screen flex-col">
		<div class="mx-auto w-full max-w-295 px-10 pt-6.5">
			<a href={localisePath('/', locale)} class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-tx-2">
				<Icon name="arrow-left" size={18} />{t.back}
			</a>
		</div>
		<div class="flex flex-1 items-center justify-center px-6 pt-12 pb-25">
			<div class="fu w-full max-w-110">
				<div class="mb-7.5 flex justify-center">
					<Logo surface="dark" class="w-20 h-20 block" />
				</div>

				<div
					id="login-form-card"
					class="rounded-2xl border border-line-2 bg-s1 p-5 lg:p-9 shadow-app-lg"
				>
					<h1 class="m-0 text-center text-[30px] font-extrabold tracking-[-0.02em] text-tx">{t.heading}</h1>
					<p class="mt-3 mb-7 text-center text-[16.5px] leading-[1.55] text-tx-3">
						{t.subhead}
					</p>

					<form
						id="magic-link-form"
						data-next={next}
						data-sending={t.script.sending}
						data-error-prefix={t.script.errorPrefix}
						data-network-error-prefix={t.script.networkErrorPrefix}
						data-email-fallback={t.emailPlaceholder}
					>
						<div class="field-input field-input--big flex items-center gap-2.5">
							<Icon name="mail" size={18} class="text-tx-3" />
							<input
								type="email"
								name="email"
								required
								autocomplete="email"
								placeholder={t.emailPlaceholder}
								class="flex-1 border-none bg-transparent text-[18px] text-tx outline-none placeholder:text-tx-4"
							/>
						</div>
						<div class="mt-4">
							<Button type="submit" full size="lg" iconRight="arrow-right">{t.submit}</Button>
						</div>
					</form>

					<div class="mt-5.5 flex items-center justify-center gap-2 text-sm text-tx-3">
						<Icon name="lock" size={15} />{t.lockNote}
					</div>
					<p id="status" class="mt-3.5 min-h-[1.25rem] text-center text-sm text-tx-2"></p>
				</div>

				<div
					id="login-success-card"
					class="hidden rounded-2xl border border-line-2 bg-s1 p-[44px_34px] text-center shadow-app-lg [animation:popIn_.3s_both]"
				>
					<div
						class="mx-auto mb-5 flex h-18 w-18 items-center justify-center rounded-full bg-peach text-orange-deep"
					>
						<Icon name="mail" size={34} stroke={1.8} />
					</div>
					<h1 class="m-0 text-[27px] font-extrabold text-tx">{t.success.heading}</h1>
					<p class="mt-3 mb-6.5 text-[16.5px] leading-[1.6] text-tx-3">
						{t.success.sentPrefix}<strong id="login-email" class="text-tx">{t.emailPlaceholder}</strong>{t.success.sentSuffix}
					</p>
					<a id="login-retry" href="#" class="cursor-pointer text-[14.5px] font-semibold text-accent">{t.success.retry}</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	const form = document.getElementById('magic-link-form') as HTMLFormElement
	const status = document.getElementById('status') as HTMLParagraphElement
	const button = form.querySelector('button') as HTMLButtonElement
	const formCard = document.getElementById('login-form-card') as HTMLElement
	const successCard = document.getElementById('login-success-card') as HTMLElement
	const emailOut = document.getElementById('login-email') as HTMLElement
	const retry = document.getElementById('login-retry') as HTMLAnchorElement

	retry.addEventListener('click', (e) => {
		e.preventDefault()
		successCard.style.display = 'none'
		formCard.style.display = ''
		button.disabled = false
		status.textContent = ''
	})

	form.addEventListener('submit', async (e) => {
		e.preventDefault()
		const email = (form.elements.namedItem('email') as HTMLInputElement).value
		const callbackURL = form.dataset.next || '/app/events/new'
		const locale = document.documentElement.lang === 'da' ? 'da' : 'en'
		button.disabled = true
		status.textContent = form.dataset.sending || ''
		try {
			const res = await fetch('/api/auth/sign-in/magic-link', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email, callbackURL, metadata: { locale } }),
			})
			if (res.ok) {
				status.textContent = ''
				emailOut.textContent = email || form.dataset.emailFallback || ''
				formCard.style.display = 'none'
				successCard.style.display = ''
			} else {
				const txt = await res.text()
				status.textContent = `${form.dataset.errorPrefix} ${txt}`
				button.disabled = false
			}
		} catch (err) {
			status.textContent = `${form.dataset.networkErrorPrefix} ${(err as Error).message}`
			button.disabled = false
		}
	})
</script>

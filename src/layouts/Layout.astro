---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'appelsin — live event photos',
	description = 'Guests scan a QR code, upload photos from their phone, and the photos appear live on the big screen.',
} = Astro.props;
---

<!doctype html>
<html lang="en" style="background-color: #071952">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#071952" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content="noindex" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#071952] text-zinc-100 antialiased">
		<slot />
	</body>
</html>

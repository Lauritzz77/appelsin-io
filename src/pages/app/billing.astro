---
import Layout from '../../layouts/Layout.astro'
import Icon from '../../components/brand/Icon.astro'
import Card from '../../components/brand/Card.astro'
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, desc } from 'drizzle-orm'
import * as schema from '../../db/schema'
import { SUBSCRIPTION_PLANS } from '../../lib/billing'

export const prerender = false

const host = Astro.locals.host!
const db = drizzle(env.DB, { schema })

const [hostRow] = await db
	.select({ stripeCustomerId: schema.hosts.stripeCustomerId, plan: schema.hosts.plan })
	.from(schema.hosts)
	.where(eq(schema.hosts.id, host.id))
	.limit(1)

const [subscription] = await db
	.select()
	.from(schema.subscriptions)
	.where(eq(schema.subscriptions.hostId, host.id))
	.limit(1)

const purchases = await db
	.select({
		id: schema.eventPurchases.id,
		eventId: schema.eventPurchases.eventId,
		tier: schema.eventPurchases.tier,
		stripeSessionId: schema.eventPurchases.stripeSessionId,
	})
	.from(schema.eventPurchases)
	.where(eq(schema.eventPurchases.hostId, host.id))
	.orderBy(desc(schema.eventPurchases.id))
	.limit(20)

const justSubscribed = Astro.url.searchParams.get('subscribed') === '1'
const noCustomer = Astro.url.searchParams.get('nocustomer') === '1'

const onPro = hostRow?.plan === 'pro'
const hasCustomer = Boolean(hostRow?.stripeCustomerId)
const cancelsAtPeriodEnd = subscription?.cancelAtPeriodEnd && subscription.currentPeriodEnd
// Only surface the subscription upgrade buttons when both Stripe Price IDs
// are configured. Without them /api/billing/subscribe would 500.
const subscriptionsEnabled =
	Boolean(env.STRIPE_PRICE_PRO_MONTHLY) && Boolean(env.STRIPE_PRICE_PRO_YEARLY)

function formatPlanPrice(priceCents: number, currency: string, interval: 'month' | 'year') {
	const amount = priceCents / 100
	const money = new Intl.NumberFormat('en-IE', {
		style: 'currency',
		currency: currency.toUpperCase(),
		maximumFractionDigits: 0,
	}).format(amount)
	return `${money}/${interval === 'month' ? 'mo' : 'yr'}`
}
---

<Layout title="Billing — appelsin">
	<div class="app screen-root">
		<div class="app-wrap fu" style="padding-top:28px">
			<a
				href="/app"
				style="display:inline-flex;align-items:center;gap:8px;color:var(--tx-3);font-size:15.5px;font-weight:600"
			>
				<Icon name="arrow-left" size={18} />Dashboard
			</a>

			<div style="margin:22px 0 28px">
				<h1 style="font-size:clamp(30px,5cqw,42px);font-weight:800;letter-spacing:-.02em;margin:0">Billing</h1>
				<p style="color:var(--tx-3);font-size:16px;margin:8px 0 0">Manage your subscription and invoices.</p>
			</div>

			{
				justSubscribed && (
					<div style="margin-bottom:20px;border-radius:var(--r-md);border:1px solid rgba(52,211,153,.3);background:var(--live-bg);padding:13px 18px;font-size:14px;color:var(--live)">
						Subscription active. Welcome to Pro.
					</div>
				)
			}
			{
				noCustomer && (
					<div style="margin-bottom:20px;border-radius:var(--r-md);border:1px solid rgba(255,162,41,.3);background:var(--orange-soft);padding:13px 18px;font-size:14px;color:var(--accent)">
						You have no billing history yet — buy an event pass or start a subscription first.
					</div>
				)
			}

			<Card pad={24} class="bill-plan">
				<div>
					<p style="font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--tx-3)">Current plan</p>
					<p style="margin-top:4px;font-size:26px;font-weight:800;color:var(--tx)">{onPro ? 'Pro' : 'Free'}</p>
					{
						subscription && (
							<p style="margin-top:6px;font-size:13px;color:var(--tx-3)">
								Status: {subscription.status}
								{cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<> · cancels {new Date(subscription.currentPeriodEnd).toLocaleDateString()}</>
								)}
								{!cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<> · renews {new Date(subscription.currentPeriodEnd).toLocaleDateString()}</>
								)}
							</p>
						)
					}
				</div>
				{
					hasCustomer && (
						<form method="post" action="/api/billing/portal">
							<button type="submit" class="btn btn--secondary btn--sm">
								Manage in Stripe
								<Icon name="external" size={15} stroke={2.2} />
							</button>
						</form>
					)
				}
			</Card>

			{
				!onPro && subscriptionsEnabled && (
					<section style="margin-top:32px">
						<div class="app-sec-label">Upgrade to Pro</div>
						<p style="margin:-6px 0 16px;font-size:14.5px;color:var(--tx-3);max-width:560px">
							Unlimited events, no per-event payment. Best for planners and venues running several events a month.
						</p>
						<div class="evt-actions">
							{Object.entries(SUBSCRIPTION_PLANS).map(([planId, plan]) => (
								<form method="post" action="/api/billing/subscribe" style="display:contents">
									<input type="hidden" name="plan" value={planId} />
									<button type="submit" class="action-tile" style="display:flex;align-items:center;justify-content:space-between;gap:16px;width:100%;text-align:left;padding:20px 22px;border-radius:var(--r-lg);cursor:pointer;background:var(--orange-soft);border:1px solid rgba(255,162,41,.32)">
										<span>
											<span style="display:block;font-size:16.5px;font-weight:700;color:var(--accent)">{plan.label}</span>
											<span style="display:block;margin-top:3px;font-size:13.5px;color:var(--tx-3)">
												Pay {plan.interval === 'month' ? 'monthly' : 'yearly'}, cancel anytime
											</span>
										</span>
										<span style="font-family:var(--mono);font-weight:700;color:var(--accent)">
											{formatPlanPrice(plan.priceCents, plan.currency, plan.interval)}
										</span>
									</button>
								</form>
							))}
						</div>
					</section>
				)
			}

			<section style="margin-top:32px">
				<div class="app-sec-label">
					Event passes {purchases.length === 0 ? '(none yet)' : `(${purchases.length})`}
				</div>
				{
					purchases.length > 0 && (
						<div style="border-radius:var(--r-xl);border:1px solid var(--line-2);background:var(--s1);overflow:hidden">
							{purchases.map((p, i) => (
								<div
									style={`display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 20px;font-size:14px;${i ? 'border-top:1px solid var(--line-2)' : ''}`}
								>
									<div>
										<div style="font-weight:700;color:var(--tx);text-transform:capitalize">{p.tier} pass</div>
										<div style="margin-top:2px;font-family:var(--mono);font-size:12px;color:var(--tx-4)">{p.stripeSessionId}</div>
									</div>
									{p.eventId && (
										<a
											href={`/app/events/${p.eventId}`}
											style="font-size:13px;color:var(--accent);font-weight:600;white-space:nowrap"
										>
											View event →
										</a>
									)}
								</div>
							))}
						</div>
					)
				}
			</section>
		</div>
	</div>
</Layout>

<style>
	.bill-plan {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 18px;
		flex-wrap: wrap;
	}
</style>

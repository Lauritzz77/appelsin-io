---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and, ne, desc, sql } from 'drizzle-orm'
import * as schema from '../../../../db/schema'
import Layout from '../../../../layouts/Layout.astro'
import Icon from '../../../../components/brand/Icon.astro'
import Button from '../../../../components/brand/Button.astro'
import Card from '../../../../components/brand/Card.astro'
import StatusPill from '../../../../components/brand/StatusPill.astro'
import CopyField from '../../../../components/brand/CopyField.astro'
import ActionTile from '../../../../components/brand/ActionTile.astro'
import { TIERS, isTier, formatPrice } from '../../../../lib/tiers'
import { streamThumbnailUrl } from '../../../../lib/media'
import { createStripe } from '../../../../lib/stripe'
import { activateEventFromPaidCheckoutSession } from '../../../../lib/event-purchases'

export const prerender = false

const host = Astro.locals.host!
const id = Astro.params.id!

const db = drizzle(env.DB, { schema })
let [event] = await db
	.select()
	.from(schema.events)
	.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
	.limit(1)

if (!event) return new Response('Event not found', { status: 404 })

const justPaid = Astro.url.searchParams.get('paid') === '1'
const activateError = Astro.url.searchParams.get('activate_error')
const checkoutSessionId = Astro.url.searchParams.get('session_id')
if (event.status === 'draft' && justPaid && checkoutSessionId?.startsWith('cs_')) {
	const stripe = createStripe(env)
	const session = await stripe.checkout.sessions.retrieve(checkoutSessionId)
	await activateEventFromPaidCheckoutSession(db, session, { eventId: event.id, hostId: host.id })
	;[event] = await db
		.select()
		.from(schema.events)
		.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
		.limit(1)
	if (!event) return new Response('Event not found', { status: 404 })
}

const recentPhotos = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		cfStreamUid: schema.photos.cfStreamUid,
		mediaType: schema.photos.mediaType,
		durationSeconds: schema.photos.durationSeconds,
		createdAt: schema.photos.createdAt,
	})
	.from(schema.photos)
	.where(eq(schema.photos.eventId, event.id))
	.orderBy(desc(schema.photos.createdAt))
	.limit(12)

const [{ photoCount }] = await db
	.select({ photoCount: sql<number>`count(*)` })
	.from(schema.photos)
	.where(and(eq(schema.photos.eventId, event.id), ne(schema.photos.status, 'rejected')))

const guestUrl = `${env.PUBLIC_APP_URL}/e/${event.shortCode}`
const displayUrl = `${env.PUBLIC_APP_URL}/display/${event.shortCode}`

const tier = isTier(event.tier) ? event.tier : 'free'
const tierConfig = TIERS[tier]
const isPaidTier = tierConfig.priceCents > 0

const capPct = Math.min(100, Math.round((photoCount / tierConfig.photoCap) * 100))
const capWarn = photoCount >= tierConfig.photoCap
const capNear = !capWarn && photoCount >= tierConfig.photoCap * 0.8
const barColor = capWarn ? '#ef4444' : capNear ? 'var(--accent)' : undefined

// Upload window: opens 24h before event_date, closes 2 days after.
const uploadOpensAt = new Date(event.eventDate.getTime() - 24 * 60 * 60 * 1000)
const uploadClosesAt = new Date(event.eventDate.getTime() + 2 * 24 * 60 * 60 * 1000)
const fmtDateTime = (d: Date) => d.toLocaleString('da-DK', { dateStyle: 'long', timeStyle: 'short' })

// Run-guide steps (presentational; mirrors the conditional flow).
const runSteps: { title: string; desc: string }[] = []
if (event.status === 'draft' && isPaidTier)
	runSteps.push({ title: 'Betal eventet', desc: 'Stripe-betalingen sætter eventet til live og åbner for uploads.' })
runSteps.push({ title: 'Hent QR-pakken', desc: `Print A4-skiltet + 8 bordkort med koden ${event.shortCode}.` })
if (event.hasBigScreen)
	runSteps.push({ title: 'Åbn fotovæggen', desc: `Vis billederne på storskærmen — ${displayUrl}.` })
runSteps.push({
	title: "Gæster scanner QR'en",
	desc: `Billederne dukker op øjeblikkeligt${event.hasBigScreen ? ' på skærmen' : ' i samlingen'}.`,
})
runSteps.push({ title: 'Efter eventet', desc: 'Download alle billeder som zip — du og gæster med email får et link.' })

const timelineRows: [string, string, string][] = [
	['Uploads åbner', fmtDateTime(uploadOpensAt), '24 timer før eventet'],
	['Eventet lukker', fmtDateTime(uploadClosesAt), '2 dage efter eventet'],
	['Billeder slettes', `efter ${tierConfig.retentionDays} dage`, 'derefter slettes alt automatisk'],
]
---

<Layout title={`${event.name} — appelsin`}>
	<div class="app screen-root">
		<div class="app-wrap fu" style="padding-top:28px">
			<a
				href="/app"
				style="display:inline-flex;align-items:center;gap:8px;color:var(--tx-3);font-size:15.5px;font-weight:600"
			>
				<Icon name="arrow-left" size={18} />Alle events
			</a>

			{/* header */}
			<div class="detail-head" style="margin:22px 0 6px">
				<div>
					<h1 style="font-size:clamp(30px,5cqw,42px);font-weight:800;letter-spacing:-.02em;margin:0">{event.name}</h1>
					<div
						style="display:flex;align-items:center;gap:12px;margin-top:12px;flex-wrap:wrap;color:var(--tx-3);font-size:15.5px"
					>
						<span style="display:inline-flex;gap:7px;align-items:center">
							<Icon name="calendar" size={16} />
							{new Date(event.eventDate).toLocaleDateString('da-DK', { dateStyle: 'long' })}
						</span>
						<span style="opacity:.5">·</span>
						<span>
							<strong style="color:var(--accent)">{tierConfig.label}</strong>-plan · op til {tierConfig.photoCap.toLocaleString('da-DK')} billeder · {tierConfig.retentionDays} dages opbevaring
						</span>
					</div>
				</div>
				<StatusPill status={event.status} locale="da" />
			</div>

			{
				justPaid && event.status === 'live' && (
					<div style="margin-top:16px;border-radius:var(--r-md);border:1px solid rgba(52,211,153,.3);background:var(--live-bg);padding:13px 18px;font-size:14px;color:var(--live)">
						Betaling bekræftet. Dit event er live.
					</div>
				)
			}
			{
				justPaid && event.status === 'draft' && (
					<div style="margin-top:16px;border-radius:var(--r-md);border:1px solid rgba(255,162,41,.3);background:var(--orange-soft);padding:13px 18px;font-size:14px;color:var(--accent)">
						Betaling modtaget — afslutter. Opdater om et øjeblik hvis status ikke skifter til <em>live</em>.
					</div>
				)
			}
			{
				activateError === 'free_limit' && (
					<div style="margin-top:16px;border-radius:var(--r-md);border:1px solid rgba(244,63,94,.3);background:rgba(244,63,94,.1);padding:13px 18px;font-size:14px;color:#ff8499">
						Du har allerede et aktivt gratis event. Afslut det først, eller opgrader dette event til Basic eller Gold.
					</div>
				)
			}

			{
				(event.status === 'draft' || event.status === 'live') && (
					<div style="background:var(--orange-soft);border:1px solid rgba(255,162,41,.26);border-radius:var(--r-xl);padding:26px 28px;margin-top:26px">
						<div style="display:flex;align-items:center;gap:9px;color:var(--accent);font-weight:700;font-size:17px;margin-bottom:20px">
							<Icon name="sparkle" size={19} fill="currentColor" stroke={0} />Sådan kører du dit event
						</div>
						<div style="display:grid;gap:16px">
							{runSteps.map((s, i) => (
								<div style="display:flex;gap:15px;align-items:flex-start">
									<span style="width:32px;height:32px;border-radius:999px;flex-shrink:0;font-weight:800;font-size:14px;display:flex;align-items:center;justify-content:center;background:var(--accent);color:#2C1700">
										{i + 1}
									</span>
									<div>
										<div style="font-size:16.5px;font-weight:700;color:var(--tx)">{s.title}</div>
										<div style="font-size:14.5px;color:var(--tx-2);margin-top:2px">{s.desc}</div>
									</div>
								</div>
							))}
						</div>
					</div>
				)
			}

			{/* name + code */}
			<div style="display:grid;gap:16px;grid-template-columns:1fr;margin-top:28px">
				<Card pad={24}>
					<form id="rename-event-form" data-event-id={event.id}>
						<label style="display:block">
							<span class="field-label">Eventnavn</span>
							<input
								id="event-name-input"
								name="name"
								type="text"
								value={event.name}
								maxlength="80"
								class="field-input"
								required
							/>
						</label>
						<div style="margin-top:14px;display:flex;align-items:center;gap:14px">
							<Button id="rename-event-btn" type="submit" size="sm">Gem navn</Button>
							<p id="rename-event-status" class="text-sm text-zinc-500" aria-live="polite"></p>
						</div>
					</form>
				</Card>
				<Card pad={24}>
					<div style="display:grid;grid-template-columns:1fr;gap:16px">
						<CopyField big label="Kort kode — gæster skriver den på appelsin.io/e" value={event.shortCode} />
						<CopyField label="Direkte gæste-link" mono={false} value={guestUrl} />
					</div>
				</Card>
			</div>

			{/* big screen toggle */}
			<Card pad={22} class="bigscreen-card">
				<span
					style="width:46px;height:46px;border-radius:var(--r-md);background:rgba(255,255,255,.06);color:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0"
				>
					<Icon name="monitor" size={22} />
				</span>
				<div style="flex:1">
					<div style="font-size:16.5px;font-weight:700">Storskærm til eventet</div>
					<div style="font-size:14px;color:var(--tx-3);margin-top:3px">
						Slå fra, hvis billederne ikke skal vises på en skærm til eventet. Det ændrer teksten i QR-pakken.
					</div>
					<p id="has-big-screen-status" class="mt-2 text-xs text-zinc-500" aria-live="polite"></p>
				</div>
				<label class="toggle">
					<input id="has-big-screen-toggle" type="checkbox" checked={event.hasBigScreen} data-event-id={event.id} />
					<span class="knob"></span>
				</label>
			</Card>

			{/* action grid */}
			<div class="app-sec-label" style="margin-top:32px">Værktøjer</div>
			<div class="evt-actions">
				<ActionTile
					href={`/app/events/${event.id}/qr.pdf`}
					icon="qr"
					title="Hent QR-pakke"
					sub="A4-skilt + 8 bordkort (PDF)"
					arrow="download"
				/>
				{
					photoCount > 0 && (
						<ActionTile
							href={`/api/events/${event.id}/download`}
							icon="image"
							title="Hent alle billeder"
							sub={`ZIP med ${photoCount.toLocaleString('da-DK')} originaler`}
							arrow="download"
						/>
					)
				}
				{
					isPaidTier && (
						<ActionTile
							href={`/app/events/${event.id}/style`}
							icon="pencil"
							title="Tilpas fotovæg"
							sub="Tema, tæthed og titel-overlay"
							arrow="chevron-right"
						/>
					)
				}
				{
					event.status === 'live' ? (
						<ActionTile
							href={`/display/${event.shortCode}`}
							target="_blank"
							icon="monitor"
							title="Åbn fotovæg"
							sub={`appelsin.io/display/${event.shortCode}`}
							arrow="external"
							accent
						/>
					) : event.status === 'draft' && isPaidTier ? (
						<form method="post" action={`/api/events/${event.id}/checkout`} style="display:contents">
							<ActionTile
								icon="card"
								title={`Betal ${formatPrice(tier, 'da')} & aktivér`}
								sub={`${tierConfig.label} — åbner Stripe-betaling`}
								arrow="external"
								accent
							/>
						</form>
					) : null
				}
			</div>

			{/* timeline + counter */}
			<Card pad={26} class="mt-timeline">
				<div style="display:flex;align-items:center;gap:9px;font-size:17px;font-weight:700;margin-bottom:18px">
					<Icon name="clock" size={19} class="text-[var(--accent)]" />Tidslinje
				</div>
				{
					timelineRows.map((r, i) => (
						<div
							style={`display:flex;gap:14px;padding:12px 0;align-items:baseline;${i ? 'border-top:1px solid var(--line-2)' : ''}`}
						>
							<span
								style={`width:11px;height:11px;border-radius:999px;margin-top:5px;flex-shrink:0;background:${i === 0 ? 'var(--live)' : i === 1 ? 'var(--accent)' : 'var(--tx-4)'}`}
							/>
							<div style="flex:1">
								<span style="font-size:15.5px;color:var(--tx-2)">{r[0]} </span>
								<strong style="font-size:15.5px;color:var(--tx)">{r[1]}</strong>
								<div style="font-size:13.5px;color:var(--tx-3);margin-top:2px">{r[2]}</div>
							</div>
						</div>
					))
				}
				<div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--line-2)">
					<div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:15px">
						<span style="color:var(--tx-2);font-weight:600">Uploads</span>
						<span
							class="tabular-nums"
							style={`font-family:var(--mono);font-weight:700;color:${capWarn ? '#ff8499' : capNear ? 'var(--accent)' : 'var(--tx)'}`}
						>
							{photoCount.toLocaleString('da-DK')} / {tierConfig.photoCap.toLocaleString('da-DK')}
						</span>
					</div>
					<div class="progress">
						<div class="bar" style={`width:${capPct}%${barColor ? `;background:${barColor};box-shadow:none` : ''}`}></div>
					</div>
					{
						capWarn && (
							<p style="margin-top:12px;font-size:13px;color:#ff8499">
								Eventet har nået sin upload-grænse. Nye uploads er blokeret, indtil du opgraderer planen eller afviste billeder frigør pladser.
							</p>
						)
					}
					{
						capNear && (
							<p style="margin-top:12px;font-size:13px;color:var(--accent)">
								Nærmer sig upload-grænsen — overvej at opgradere, før grænsen er nået.
							</p>
						)
					}
				</div>
			</Card>

			{/* recent uploads — markup preserved for the WS/buildTile script */}
			<div style="display:flex;align-items:center;justify-content:space-between;margin-top:32px;margin-bottom:14px">
				<div class="app-sec-label" style="margin:0">
					Seneste uploads <span id="recent-uploads-count">{recentPhotos.length === 0 ? '(ingen endnu)' : `(${recentPhotos.length})`}</span>
				</div>
				{
					event.status === 'live' && (
						<span style="display:inline-flex;align-items:center;gap:7px;font-size:13px;color:var(--live);font-weight:600">
							<span style="width:7px;height:7px;border-radius:999px;background:var(--live);animation:pulseDot 2s infinite" />opdateres live
						</span>
					)
				}
			</div>
			<section
				id="recent-uploads"
				data-event-code={event.shortCode}
				data-event-status={event.status}
				data-cf-images-hash={env.CF_IMAGES_HASH}
				data-cf-stream-domain={env.CF_STREAM_CUSTOMER_DOMAIN}
			>
				<div id="photo-grid" class="up-grid">
					{
						recentPhotos.map((p) => (
							<div
								class="photo-tile group relative aspect-square overflow-hidden rounded bg-zinc-900"
								data-photo-id={p.id}
							>
								{p.mediaType === 'video' && p.cfStreamUid ? (
									<>
										<img
											src={streamThumbnailUrl(p.cfStreamUid, env.CF_STREAM_CUSTOMER_DOMAIN)}
											alt=""
											class="h-full w-full object-cover"
										/>
										<span class="absolute bottom-1 left-1 rounded bg-zinc-950/80 px-1.5 py-0.5 text-[10px] font-medium text-white">
											{p.durationSeconds ? `${p.durationSeconds}s` : 'Video'}
										</span>
									</>
								) : p.cfImagesId ? (
									<img
										src={`https://imagedelivery.net/${env.CF_IMAGES_HASH}/${p.cfImagesId}/public`}
										alt=""
										class="h-full w-full object-cover"
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center text-xs text-zinc-600">intet billede</div>
								)}
								<button
									type="button"
									class="photo-delete absolute right-1 top-1 flex h-7 w-7 items-center justify-center rounded-full bg-zinc-950/70 text-zinc-100 opacity-0 transition group-hover:opacity-100 focus:opacity-100 hover:bg-red-600 hover:text-white"
									data-photo-id={p.id}
									aria-label="Slet billede"
									title="Slet billede"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 20 20"
										fill="currentColor"
										class="h-4 w-4"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M8.75 1.5A1.5 1.5 0 0 0 7.25 3v.5H4.5a.75.75 0 0 0 0 1.5h.443l.737 11.05A2 2 0 0 0 7.676 18h4.648a2 2 0 0 0 1.996-1.95L15.057 5h.443a.75.75 0 0 0 0-1.5H12.75V3a1.5 1.5 0 0 0-1.5-1.5h-2.5Zm2 2.5V3h-2v1h2ZM8.5 7.75a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1-.75-.75Z"
											clip-rule="evenodd"
										/>
									</svg>
								</button>
							</div>
						))
					}
				</div>
			</section>

			{/* danger zone */}
			<div
				style="margin-top:40px;padding:22px 24px;border-radius:var(--r-xl);border:1px solid rgba(244,63,94,.22);background:rgba(244,63,94,.05);display:flex;align-items:center;gap:18px;flex-wrap:wrap"
			>
				<div style="flex:1;min-width:200px">
					<div style="font-size:16px;font-weight:700;color:#ff8499">Slet event</div>
					<div style="font-size:14px;color:var(--tx-3);margin-top:3px">
						Sletter dette event og alle uploadede billeder. Dette kan ikke fortrydes.
					</div>
				</div>
				<button
					id="delete-event-btn"
					type="button"
					class="btn btn--danger btn--sm"
					data-event-id={event.id}
					data-event-name={event.name}
				>
					<Icon name="trash" size={16} stroke={2.2} />Slet event
				</button>
			</div>
		</div>
	</div>
</Layout>

<style>
	.bigscreen-card {
		margin-top: 16px;
		display: flex;
		align-items: center;
		gap: 18px;
	}
	.mt-timeline {
		margin-top: 28px;
	}
</style>

<script>
	document.getElementById('has-big-screen-toggle')?.addEventListener('change', async (event) => {
		const input = event.currentTarget as HTMLInputElement
		const status = document.getElementById('has-big-screen-status')
		const id = input.dataset.eventId
		if (!id) return

		const desired = input.checked
		input.disabled = true
		if (status) {
			status.textContent = 'Gemmer...'
			status.className = 'mt-2 text-xs text-zinc-500'
		}

		try {
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ hasBigScreen: desired }),
			})
			if (!res.ok) throw new Error(`Kunne ikke gemme (${res.status})`)
			if (status) {
				status.textContent = 'Gemt'
				status.className = 'mt-2 text-xs text-green-400'
			}
		} catch (e) {
			input.checked = !desired
			if (status) {
				status.textContent = (e as Error).message
				status.className = 'mt-2 text-xs text-red-400'
			}
		} finally {
			input.disabled = false
		}
	})

	document.getElementById('rename-event-form')?.addEventListener('submit', async (event) => {
		event.preventDefault()
		const form = event.currentTarget as HTMLFormElement
		const input = document.getElementById('event-name-input') as HTMLInputElement | null
		const button = document.getElementById('rename-event-btn') as HTMLButtonElement | null
		const status = document.getElementById('rename-event-status')
		const name = input?.value.trim()
		if (!name || !button) return

		button.disabled = true
		if (status) {
			status.textContent = 'Gemmer...'
			status.className = 'text-sm text-zinc-500'
		}

		try {
			const id = form.dataset.eventId
			if (!id) throw new Error('Manglende event-id')
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name }),
			})
			const payload = (await res.json().catch(() => null)) as { name?: string } | null
			if (!res.ok) throw new Error(`Omdøbning mislykkedes (${res.status})`)
			document.title = `${payload?.name || name} — appelsin`
			const heading = document.querySelector('h1')
			if (heading) heading.textContent = payload?.name || name
			if (status) {
				status.textContent = 'Gemt'
				status.className = 'text-sm text-green-400'
			}
		} catch (e) {
			if (status) {
				status.textContent = (e as Error).message
				status.className = 'text-sm text-red-400'
			}
		} finally {
			button.disabled = false
		}
	})

	document.getElementById('delete-event-btn')?.addEventListener('click', async (event) => {
		const btn = event.currentTarget as HTMLButtonElement
		const id = btn.dataset.eventId
		const name = btn.dataset.eventName || 'dette event'
		if (!id) return
		const confirmed = await window.AppDialog.confirm({
			title: `Slet "${name}"?`,
			message: 'Dette sletter eventet og alle uploadede billeder. Dette kan ikke fortrydes.',
			confirmText: 'Slet event',
			danger: true,
		})
		if (!confirmed) return

		btn.disabled = true
		try {
			const res = await fetch(`/api/events/${id}`, { method: 'DELETE' })
			if (!res.ok) throw new Error(`Sletning mislykkedes (${res.status})`)
			window.location.href = '/app'
		} catch (e) {
			btn.disabled = false
			await window.AppDialog.alert({
				title: 'Kunne ikke slette event',
				message: (e as Error).message,
			})
		}
	})

	// Click-to-copy fields (code + guest link).
	document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const value = btn.dataset.copy || ''
			navigator.clipboard?.writeText(value)
			const ind = btn.querySelector<HTMLElement>('.copy-ind')
			if (!ind) return
			const prev = ind.innerHTML
			ind.textContent = 'Kopieret'
			ind.style.color = 'var(--live)'
			window.setTimeout(() => {
				ind.innerHTML = prev
				ind.style.color = 'var(--tx-3)'
			}, 1400)
		})
	})

	const recentUploads = document.getElementById('recent-uploads')
	const photoGrid = document.getElementById('photo-grid')
	const recentCount = document.getElementById('recent-uploads-count')
	const eventCode = recentUploads?.dataset.eventCode
	const eventStatus = recentUploads?.dataset.eventStatus
	const cfImagesHash = recentUploads?.dataset.cfImagesHash ?? ''
	const cfStreamDomain = recentUploads?.dataset.cfStreamDomain ?? ''

	function updateRecentCount() {
		if (!recentCount || !photoGrid) return
		const n = photoGrid.children.length
		recentCount.textContent = n === 0 ? '(ingen endnu)' : `(${n})`
	}

	function streamThumbUrl(uid: string): string {
		return `https://${cfStreamDomain}/${uid}/thumbnails/thumbnail.jpg?time=1s&height=600`
	}

	type IncomingPhoto = {
		photoId: string
		mediaType: 'photo' | 'video'
		cfImagesId: string | null
		cfStreamUid: string | null
		durationSeconds: number | null
	}

	function buildTile(p: IncomingPhoto): HTMLDivElement {
		const tile = document.createElement('div')
		tile.className = 'photo-tile group relative aspect-square overflow-hidden rounded bg-zinc-900'
		tile.dataset.photoId = p.photoId

		let inner = ''
		if (p.mediaType === 'video' && p.cfStreamUid) {
			inner += `<img src="${streamThumbUrl(p.cfStreamUid)}" alt="" class="h-full w-full object-cover" />`
			inner += `<span class="absolute bottom-1 left-1 rounded bg-zinc-950/80 px-1.5 py-0.5 text-[10px] font-medium text-white">${
				p.durationSeconds ? `${p.durationSeconds}s` : 'Video'
			}</span>`
		} else if (p.cfImagesId) {
			inner += `<img src="https://imagedelivery.net/${cfImagesHash}/${p.cfImagesId}/public" alt="" class="h-full w-full object-cover" />`
		} else {
			inner += `<div class="flex h-full w-full items-center justify-center text-xs text-zinc-600">intet billede</div>`
		}
		inner += `<button
			type="button"
			class="photo-delete absolute right-1 top-1 flex h-7 w-7 items-center justify-center rounded-full bg-zinc-950/70 text-zinc-100 opacity-0 transition group-hover:opacity-100 focus:opacity-100 hover:bg-red-600 hover:text-white"
			data-photo-id="${p.photoId}"
			aria-label="Slet billede"
			title="Slet billede"
		><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path fill-rule="evenodd" d="M8.75 1.5A1.5 1.5 0 0 0 7.25 3v.5H4.5a.75.75 0 0 0 0 1.5h.443l.737 11.05A2 2 0 0 0 7.676 18h4.648a2 2 0 0 0 1.996-1.95L15.057 5h.443a.75.75 0 0 0 0-1.5H12.75V3a1.5 1.5 0 0 0-1.5-1.5h-2.5Zm2 2.5V3h-2v1h2ZM8.5 7.75a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" /></svg></button>`
		tile.innerHTML = inner
		return tile
	}

	function addPhoto(p: IncomingPhoto) {
		if (!photoGrid) return
		if (photoGrid.querySelector(`[data-photo-id="${p.photoId}"]`)) return
		photoGrid.insertBefore(buildTile(p), photoGrid.firstChild)
		updateRecentCount()
	}

	function removePhotoTile(photoId: string) {
		if (!photoGrid) return
		const tile = photoGrid.querySelector(`[data-photo-id="${photoId}"]`)
		tile?.remove()
		updateRecentCount()
	}

	// Event delegation so newly inserted tiles also get delete behaviour.
	photoGrid?.addEventListener('click', async (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.photo-delete')
		if (!btn) return
		const id = btn.dataset.photoId
		if (!id) return
		const confirmed = await window.AppDialog.confirm({
			title: 'Slet billede?',
			message: 'Dette fjerner billedet fra eventet. Dette kan ikke fortrydes.',
			confirmText: 'Slet billede',
			danger: true,
		})
		if (!confirmed) return

		const tile = btn.closest<HTMLElement>('.photo-tile')
		tile?.classList.add('opacity-50', 'pointer-events-none')

		try {
			const res = await fetch(`/api/photos/${id}`, { method: 'DELETE' })
			if (!res.ok) throw new Error(`Sletning mislykkedes (${res.status})`)
			// The DO will also broadcast delete-photo over WS, but remove
			// locally for instant feedback (the WS handler is idempotent).
			removePhotoTile(id)
		} catch (err) {
			tile?.classList.remove('opacity-50', 'pointer-events-none')
			await window.AppDialog.alert({
				title: 'Kunne ikke slette billede',
				message: (err as Error).message,
			})
		}
	})

	// Live updates from the Durable Object — only meaningful when the event is
	// live (DO accepts no socket otherwise).
	if (eventStatus === 'live' && eventCode) {
		let socket: WebSocket | null = null
		let reconnectTimer: ReturnType<typeof setTimeout> | null = null

		function connect() {
			const proto = location.protocol === 'https:' ? 'wss' : 'ws'
			socket = new WebSocket(`${proto}://${location.host}/api/display-socket?code=${eventCode}`)
			socket.onopen = () => socket?.send(JSON.stringify({ type: 'hello' }))
			socket.onmessage = (e) => {
				try {
					const msg = JSON.parse(e.data) as
						| ({ type: 'new-photo' } & IncomingPhoto)
						| { type: 'delete-photo'; photoId: string }
						| { type: 'ack' }
					if (msg.type === 'new-photo') {
						addPhoto({
							photoId: msg.photoId,
							mediaType: msg.mediaType,
							cfImagesId: msg.cfImagesId,
							cfStreamUid: msg.cfStreamUid,
							durationSeconds: msg.durationSeconds,
						})
					} else if (msg.type === 'delete-photo') {
						removePhotoTile(msg.photoId)
					}
				} catch {
					/* ignore malformed */
				}
			}
			socket.onclose = () => {
				reconnectTimer = setTimeout(connect, 2000)
			}
			socket.onerror = () => socket?.close()
		}
		connect()
		window.addEventListener('beforeunload', () => {
			if (reconnectTimer) clearTimeout(reconnectTimer)
			socket?.close()
		})
	}
</script>

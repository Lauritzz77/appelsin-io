---
export const prerender = false

import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and } from 'drizzle-orm'
import * as schema from '../../../../db/schema'
import { getContent } from '../../../../lib/content'
import { createStripe } from '../../../../lib/stripe'
import { activateEventFromPaidCheckoutSession } from '../../../../lib/event-purchases'
import { TIERS, isTier } from '../../../../lib/tiers'
import EventDetailPage from '../../../../components/pages/EventDetailPage.astro'
import EventPaywall from '../../../../components/pages/EventPaywall.astro'

const host = Astro.locals.host!
const id = Astro.params.id!
const errors = getContent('da', 'common').errors

const db = drizzle(env.DB, { schema })
let [event] = await db
	.select()
	.from(schema.events)
	.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
	.limit(1)

if (!event) return new Response(errors.notFound, { status: 404 })

const justPaid = Astro.url.searchParams.get('paid') === '1'
const checkoutSessionId = Astro.url.searchParams.get('session_id')
if (event.status === 'draft' && justPaid && checkoutSessionId?.startsWith('cs_')) {
	const stripe = createStripe(env)
	const session = await stripe.checkout.sessions.retrieve(checkoutSessionId)
	await activateEventFromPaidCheckoutSession(db, session, { eventId: event.id, hostId: host.id })
	;[event] = await db
		.select()
		.from(schema.events)
		.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
		.limit(1)
	if (!event) return new Response(errors.notFound, { status: 404 })
}

// Paid events are created as `draft` and only flip to `live` once Stripe
// completes. Gate the draft behind a payment screen so opening one offers
// checkout straight away, before any of the event tools are shown. `justPaid`
// falls through to the detail page (which shows the "finalising" banner) for
// the rare async payment that hasn't settled yet.
const tier = isTier(event.tier) ? event.tier : 'free'
const needsPayment = event.status === 'draft' && TIERS[tier].priceCents > 0 && !justPaid
---

{
	needsPayment ? (
		<EventPaywall locale="da" event={event} />
	) : (
		<EventDetailPage locale="da" event={event} />
	)
}

---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and, desc } from 'drizzle-orm'
import * as schema from '../../../../db/schema'
import Layout from '../../../../layouts/Layout.astro'
import EventStyleEditor from '../../../../components/EventStyleEditor.vue'
import { TIERS, isTier, formatPrice } from '../../../../lib/tiers'
import { parseBranding } from '../../../../lib/branding'

export const prerender = false

const host = Astro.locals.host!
const id = Astro.params.id!

const db = drizzle(env.DB, { schema })
const [event] = await db
	.select()
	.from(schema.events)
	.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
	.limit(1)

if (!event) return new Response('Event not found', { status: 404 })

const tier = isTier(event.tier) ? event.tier : 'free'
const isFreeTier = TIERS[tier].priceCents <= 0
const branding = parseBranding(event.brandingJson)

// Pull up to 12 real photos for the preview. If none exist yet we generate
// placeholder colored tiles so the layout still demos meaningfully.
const photosRaw = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		createdAt: schema.photos.createdAt,
	})
	.from(schema.photos)
	.where(and(eq(schema.photos.eventId, event.id), eq(schema.photos.status, 'approved')))
	.orderBy(desc(schema.photos.createdAt))
	.limit(24)

const realPhotos = photosRaw.map((p) => ({
	id: p.id,
	cfImagesId: p.cfImagesId,
	createdAt: p.createdAt?.getTime() ?? 0,
}))

const previewPhotos =
	realPhotos.length > 0
		? realPhotos
		: Array.from({ length: 24 }, (_, i) => ({
				id: `placeholder-${i}`,
				cfImagesId: null,
				createdAt: Date.now() - i * 1000,
			}))
---

<Layout title={`Style — ${event.name}`}>
	<main class="mx-auto max-w-6xl px-6 py-8">
		<a
			href={`/app/events/${event.id}`}
			class="mb-4 inline-block text-sm text-zinc-400 hover:text-zinc-200"
			>← {event.name}</a
		>

		<header class="mb-8">
			<h1 class="text-3xl font-semibold tracking-tight">Photo wall style</h1>
			<p class="mt-2 text-sm text-zinc-400">
				Customise the live photo wall shown at your venue.
			</p>
		</header>

		{
			isFreeTier ? (
				<section class="rounded-2xl border border-zinc-800 bg-zinc-900/50 p-8 text-center">
					<h2 class="text-xl font-semibold">Custom styling is a paid feature</h2>
					<p class="mt-3 text-sm text-zinc-400">
						Upgrade this event to {TIERS.basic.label} ({formatPrice('basic')}) or {TIERS.gold.label} (
						{formatPrice('gold')}) to choose a theme, tile density, and add a title
						overlay. Free events use the appelsin photo collage with a corner QR.
					</p>
					<a
						href="/app/events/new"
						class="mt-6 inline-block rounded-md bg-orange-500 px-4 py-2 text-sm font-medium text-zinc-950 hover:bg-orange-400"
					>
						Create a paid event
					</a>
				</section>
			) : (
				<EventStyleEditor
					client:only="vue"
					eventId={event.id}
					eventCode={event.shortCode}
					initial={branding}
					previewPhotos={previewPhotos}
					cfImagesHash={env.CF_IMAGES_HASH}
				/>
			)
		}
	</main>
</Layout>

---
import Layout from '../../../layouts/Layout.astro'
import Icon from '../../../components/brand/Icon.astro'
import Button from '../../../components/brand/Button.astro'
import { TIERS, TIER_IDS, isTier, formatPrice, type Tier } from '../../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!

const requested = Astro.url.searchParams.get('tier')
const selectedTier: Tier = isTier(requested) ? requested : 'free'
const createError = Astro.url.searchParams.get('error')

const tierLabel = (tier: Tier) => (tier === 'free' ? 'Gratis' : TIERS[tier].label)
const tierPrice = (tier: Tier) => formatPrice(tier, 'da')
const tierDescription = (tier: Tier) => {
	const t = TIERS[tier]
	const parts = [
		`Op til ${t.photoCap.toLocaleString('da-DK')} billeder`,
		`${t.retentionDays} dages opbevaring`,
	]
	if (t.watermark) parts.push('appelsin-vandmærke')
	return parts.join(' · ')
}
---

<Layout title="Nyt event — appelsin" locale="da">
	<div class="app screen-root">
		<div class="app-wrap fu" style="max-width:640px;padding-top:30px">
			<a
				href="/app"
				style="display:inline-flex;align-items:center;gap:8px;color:var(--tx-3);font-size:15.5px;font-weight:600"
			>
				<Icon name="arrow-left" size={18} />Tilbage
			</a>
			<h1 style="font-size:clamp(30px,5cqw,40px);font-weight:800;letter-spacing:-.02em;margin:24px 0 12px">
				Nyt event
			</h1>
			<div style="display:flex;flex-direction:column;gap:12px;font-size:17px;line-height:1.6;color:var(--tx-2);max-width:520px;margin:0">
				<p style="margin:0">
					Saml alle minderne fra dit arrangement ét sted. Når du opretter et event, får du en unik kode og QR-kode, som
					dine gæster nemt kan scanne for at uploade billeder direkte fra festen.
				</p>
				<p style="margin:0">
					Billederne kan vises live på en storskærm, iPad eller computer under arrangementet, så alle kan følge med i
					øjeblikkene, mens de sker. Efter eventet kan du downloade hele billedsamlingen og gemme minderne for altid.
				</p>
				<p style="margin:0;color:var(--tx-3)">Perfekt til bryllupper, fødselsdage, firmafester og andre særlige begivenheder.</p>
			</div>

			{
				createError === 'free_exists' && (
					<div style="margin-top:24px;border-radius:var(--r-md);border:1px solid rgba(244,63,94,.3);background:rgba(244,63,94,.1);padding:14px 18px;font-size:14px;color:#ff8499">
						Du har allerede et gratis event. Slet det eksisterende først, eller vælg Basic eller Gold til dette event.
					</div>
				)
			}

			<form method="post" action="/api/events/new" style="display:flex;flex-direction:column;gap:26px;margin-top:34px">
				<input type="hidden" name="returnToPrefix" value="/app/events" />

				<label style="display:block">
					<span class="field-label">Eventnavn</span>
					<input
						id="name"
						name="name"
						type="text"
						required
						maxlength="80"
						placeholder="Anna & Jonas bryllup"
						class="field-input field-input--big"
					/>
				</label>

				<div>
					<label style="display:block">
						<span class="field-label">Eventdato</span>
						<input id="eventDate" name="eventDate" type="date" required class="field-input field-input--big" />
					</label>
					{/* timeline helper */}
					<div
						style="margin-top:16px;background:var(--orange-soft);border:1px solid rgba(255,162,41,.28);border-radius:var(--r-lg);padding:20px 22px"
					>
						<div
							style="display:flex;align-items:center;gap:9px;color:var(--accent);font-weight:700;font-size:13.5px;letter-spacing:.04em;text-transform:uppercase;margin-bottom:14px"
						>
							<Icon name="clock" size={16} />Datoen styrer tidslinjen
						</div>
						<div style="display:flex;flex-direction:column;gap:11px;font-size:15px;line-height:1.5;color:var(--tx-2)">
							<div style="display:flex;gap:12px">
								<span style="color:var(--accent);font-weight:800">·</span>
								<span>Gæster kan uploade fra <strong>24 timer før</strong> — så folk der scanner QR'en aftenen før kan komme i gang.</span>
							</div>
							<div style="display:flex;gap:12px">
								<span style="color:var(--accent);font-weight:800">·</span>
								<span>Eventet er <strong>live i 2 dage efter</strong> — så seneste billeder fra natten og dagen efter også kommer med.</span>
							</div>
							<div style="display:flex;gap:12px">
								<span style="color:var(--accent);font-weight:800">·</span>
								<span>Derefter markeres eventet som <strong>afsluttet</strong>, og billederne gemmes i <strong>7-90 dage</strong> afhængigt af planen, hvorefter alt slettes automatisk.</span>
							</div>
						</div>
					</div>
				</div>

				<fieldset style="border:none;padding:0;margin:0">
					<legend class="app-sec-label" style="padding:0">Vælg plan</legend>
					<div style="display:flex;flex-direction:column;gap:12px">
						{
							TIER_IDS.map((id) => {
								const t = TIERS[id]
								return (
									<label class="radio-card">
										<input type="radio" name="tier" value={id} checked={id === selectedTier} />
										<span class="radio-dot" />
										<span style="flex:1">
											<span style="display:flex;align-items:center;gap:10px">
												<span style="font-size:18px;font-weight:700;color:var(--tx)">{tierLabel(id)}</span>
												{id === 'basic' && <span class="badge badge--soft">Populær</span>}
											</span>
											<span style="display:block;margin-top:4px;font-size:14.5px;color:var(--tx-3)">{tierDescription(id)}</span>
										</span>
										<span class="rc-price">
											{tierPrice(id)}
											{t.priceCents > 0 && <span style="color:var(--tx-3)"> / event</span>}
										</span>
									</label>
								)
							})
						}
					</div>
				</fieldset>

				<div>
					<Button type="submit" full size="lg" iconRight="arrow-right">Opret event</Button>
					<p style="font-size:13.5px;color:var(--tx-3);text-align:center;margin-top:14px;line-height:1.5">
						Oprettes som {host.email}. Status starter som <span style="font-family:var(--mono)">kladde</span>; betalte
						planer bliver <span style="font-family:var(--mono)">live</span> efter betaling.
					</p>
				</div>
			</form>
		</div>
	</div>
</Layout>

<style>
	.radio-card {
		display: flex;
		align-items: center;
		gap: 16px;
		width: 100%;
		text-align: left;
		padding: 18px 20px;
		border-radius: var(--r-lg);
		cursor: pointer;
		background: var(--s1);
		border: 1.5px solid var(--line-2);
		transition: all 0.18s;
		position: relative;
	}
	.radio-card:hover {
		border-color: var(--line);
	}
	.radio-card input {
		position: absolute;
		opacity: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}
	.radio-card:has(input:checked) {
		background: var(--orange-soft);
		border-color: var(--accent);
		box-shadow: 0 0 0 4px var(--orange-soft);
	}
	.radio-dot {
		width: 22px;
		height: 22px;
		border-radius: 999px;
		flex-shrink: 0;
		border: 2px solid var(--tx-3);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: border-color 0.15s;
	}
	.radio-card:has(input:checked) .radio-dot {
		border-color: var(--accent);
	}
	.radio-dot::after {
		content: '';
		width: 11px;
		height: 11px;
		border-radius: 999px;
		background: var(--accent);
		transform: scale(0);
		transition: transform 0.15s;
	}
	.radio-card:has(input:checked) .radio-dot::after {
		transform: scale(1);
	}
	.radio-card:focus-within {
		border-color: var(--accent);
	}
	.rc-price {
		font-size: 17px;
		font-weight: 700;
		color: var(--tx-2);
		white-space: nowrap;
	}
	.radio-card:has(input:checked) .rc-price {
		color: var(--accent);
	}
</style>

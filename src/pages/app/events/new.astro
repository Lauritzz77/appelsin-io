---
import Layout from '../../../layouts/Layout.astro'
import { TIERS, TIER_IDS, isTier, formatPrice, type Tier } from '../../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!

const requested = Astro.url.searchParams.get('tier')
const selectedTier: Tier = isTier(requested) ? requested : 'free'
const createError = Astro.url.searchParams.get('error')

const tierLabel = (tier: Tier) => (tier === 'free' ? 'Gratis' : TIERS[tier].label)
const tierPrice = (tier: Tier) => formatPrice(tier, 'da')
const tierDescription = (tier: Tier) => {
	const t = TIERS[tier]
	const parts = [
		`Op til ${t.photoCap.toLocaleString('da-DK')} billeder`,
		`${t.retentionDays} dages opbevaring`,
	]
	if (t.watermark) parts.push('appelsin-vandmærke')
	return parts.join(' · ')
}
---

<Layout title="Nyt event — appelsin" locale="da">
	<main class="mx-auto max-w-xl px-6 py-12">
		<a href="/" class="mb-6 inline-block text-sm text-zinc-400 hover:text-zinc-200">← Tilbage</a>
		<h1 class="mb-2 text-2xl font-semibold tracking-tight">Nyt event</h1>
		<div class="mb-8 space-y-3 text-sm leading-6 text-zinc-400">
			<p>
				Saml alle minderne fra dit arrangement ét sted. Når du opretter et event, får du en unik kode og QR-kode, som dine gæster nemt kan scanne for at uploade billeder direkte fra festen.
			</p>
			<p>
				Billederne kan vises live på en storskærm, iPad eller computer under arrangementet, så alle kan følge med i øjeblikkene, mens de sker. Efter eventet kan du downloade hele billedsamlingen og gemme minderne for altid.
			</p>
			<p class="text-zinc-500">
				Perfekt til bryllupper, fødselsdage, firmafester og andre særlige begivenheder.
			</p>
		</div>

		{
			createError === 'free_exists' && (
				<div class="mb-6 rounded-md border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">
					Du har allerede et gratis event. Slet det eksisterende først, eller vælg Basic eller Gold til dette event.
				</div>
			)
		}

		<form method="post" action="/api/events/new" class="space-y-6">
			<input type="hidden" name="returnToPrefix" value="/app/events" />
			<div>
				<label for="name" class="mb-1 block text-sm text-zinc-300">Eventnavn</label>
				<input
					id="name"
					name="name"
					type="text"
					required
					maxlength="80"
					placeholder="Anna & Jonas bryllup"
					class="w-full rounded-md border border-zinc-800 bg-zinc-900 px-3 py-2 text-zinc-100 placeholder:text-zinc-600 focus:border-orange-500 focus:outline-none"
				/>
			</div>
			<div>
				<label for="eventDate" class="mb-1 block text-sm text-zinc-300">Eventdato</label>
				<input
					id="eventDate"
					name="eventDate"
					type="date"
					required
					class="w-full rounded-md border border-zinc-800 bg-zinc-900 px-3 py-2 text-zinc-100 focus:border-orange-500 focus:outline-none"
				/>
				<div class="mt-3 rounded-md border border-zinc-800 bg-zinc-900/40 p-4 text-sm leading-6 text-zinc-300">
					<p class="mb-2 text-xs font-medium uppercase tracking-wider text-orange-400">
						Datoen styrer tidslinjen
					</p>
					<ul class="space-y-2">
						<li>• Gæster kan uploade fra <strong class="text-zinc-100">24 timer før</strong> — så folk der scanner QR'en aftenen før kan komme i gang.</li>
						<li>• Eventet er <strong class="text-zinc-100">live i 2 dage efter</strong> — så seneste billeder fra natten og dagen efter også kommer med.</li>
						<li>• Derefter markeres eventet som <em class="not-italic font-medium text-zinc-100">afsluttet</em>, og billederne gemmes i <strong class="text-zinc-100">7-90 dage</strong> afhængigt af planen, hvorefter alt slettes automatisk.</li>
					</ul>
				</div>
			</div>

			<fieldset>
				<legend class="mb-2 block text-sm text-zinc-300">Plan</legend>
				<div class="space-y-2">
					{TIER_IDS.map((id) => {
						const t = TIERS[id]
						const isSelected = id === selectedTier
						return (
							<label
								class:list={[
									'flex cursor-pointer items-start gap-3 rounded-md border p-3 transition',
									isSelected
										? 'border-orange-500 bg-orange-500/10'
										: 'border-zinc-800 bg-zinc-900 hover:border-zinc-700',
								]}
							>
								<input
									type="radio"
									name="tier"
									value={id}
									checked={isSelected}
									class="mt-1 accent-orange-500"
								/>
								<div class="flex-1">
									<div class="flex items-baseline justify-between">
										<span class="font-medium text-zinc-100">{tierLabel(id)}</span>
										<span class="text-sm text-zinc-300">
											{tierPrice(id)}
											{t.priceCents > 0 && <span class="text-zinc-500"> / event</span>}
										</span>
									</div>
									<div class="mt-1 text-xs text-zinc-500">
										{tierDescription(id)}
									</div>
								</div>
							</label>
						)
					})}
				</div>
			</fieldset>

			<button
				type="submit"
				class="w-full rounded-md bg-orange-500 px-4 py-2 font-medium text-zinc-950 hover:bg-orange-400"
			>
				Opret event
			</button>
		</form>

		<p class="mt-4 text-xs text-zinc-500">
			Oprettes som {host.email}. Status starter som <code>kladde</code>; betalte planer bliver <code>live</code> efter betaling.
		</p>
	</main>
</Layout>

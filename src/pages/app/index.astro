---
import Layout from '../../layouts/Layout.astro'
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, desc } from 'drizzle-orm'
import * as schema from '../../db/schema'
import { TIERS, isTier } from '../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!
const db = drizzle(env.DB, { schema })
const events = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.hostId, host.id))
	.orderBy(desc(schema.events.createdAt))

const tierLabel = (tier: unknown) => TIERS[isTier(tier) ? tier : 'free'].label
const statusIndicatorClass = (status: unknown) =>
	status === 'live'
		? 'bg-emerald-400 shadow-[0_0_0_3px_rgba(52,211,153,0.14)]'
		: status === 'ended'
			? 'bg-zinc-500'
			: 'bg-orange-400 shadow-[0_0_0_3px_rgba(251,146,60,0.14)]'
const statusLabel = (status: unknown) =>
	status === 'live' ? 'live' : status === 'ended' ? 'afsluttet' : 'kladde'
---

<Layout title="Dashboard — appelsin">
	<main class="mx-auto max-w-3xl px-6 py-8">
		<a href="/" class="mb-4 inline-block">
			<img src="/logo.svg" alt="appelsin" width="56" height="56" class="-ml-1" />
		</a>
		<header class="mb-8 flex items-baseline justify-between">
			<h1 class="text-3xl font-semibold tracking-tight">Events</h1>
			<a
				href="/app/events/new"
				class="rounded-md bg-orange-500 px-4 py-2 font-medium text-zinc-950 hover:bg-orange-400"
			>
				Nyt event
			</a>
		</header>

		{
			events.length === 0 ? (
				<p class="text-zinc-400">Ingen events endnu. Opret dit første.</p>
			) : (
				<ul class="space-y-3">
					{events.map((e) => (
						<li
							class="event-row flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 transition hover:border-zinc-700 hover:bg-zinc-900"
						>
							<a
								href={`/app/events/${e.id}`}
								class="min-w-0 flex-1"
							>
								<div class="flex items-baseline justify-between">
									<div>
										<div class="event-name font-medium">{e.name}</div>
										<div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-zinc-500">
											<span>
												kode <span class="font-mono text-zinc-400">{e.shortCode}</span>
											</span>
											<span aria-hidden>·</span>
											<span
												class="inline-flex h-2.5 w-2.5 rounded-full"
												class:list={[statusIndicatorClass(e.status)]}
												title={`Status: ${statusLabel(e.status)}`}
											>
												<span class="sr-only">Status: {statusLabel(e.status)}</span>
											</span>
											<span aria-hidden>·</span>
											<span>
												plan{' '}
												<span class="font-medium text-orange-300">{tierLabel(e.tier)}</span>
											</span>
										</div>
									</div>
									<div class="text-sm text-zinc-400">
										{new Date(e.eventDate).toLocaleDateString('da-DK')}
									</div>
								</div>
							</a>
							<button
								type="button"
								class="event-rename grid h-9 w-9 shrink-0 place-items-center rounded-full text-zinc-500 transition hover:bg-zinc-800 hover:text-zinc-200 focus:outline-none focus:ring-2 focus:ring-orange-500 disabled:cursor-wait disabled:opacity-50"
								data-event-id={e.id}
								data-event-name={e.name}
								aria-label={`Omdøb ${e.name}`}
								title="Omdøb event"
							>
								<svg
									class="h-4 w-4"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M12 20h9"></path>
									<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
								</svg>
							</button>
							<button
								type="button"
								class="event-delete grid h-9 w-9 shrink-0 place-items-center rounded-full text-zinc-500 transition hover:bg-red-500/15 hover:text-red-300 focus:outline-none focus:ring-2 focus:ring-orange-500 disabled:cursor-wait disabled:opacity-50"
								data-event-id={e.id}
								data-event-name={e.name}
								aria-label={`Slet ${e.name}`}
								title="Slet event"
							>
								<svg
									class="h-4 w-4"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M3 6h18"></path>
									<path d="M8 6V4h8v2"></path>
									<path d="M19 6l-1 14H6L5 6"></path>
									<path d="M10 11v5"></path>
									<path d="M14 11v5"></path>
								</svg>
							</button>
						</li>
					))}
				</ul>
			)
		}

		<footer class="mt-16 flex items-center gap-3 text-xs text-zinc-500">
			<span>Logget ind som {host.email}</span>
			<span aria-hidden>·</span>
			<a href="/app/billing" class="underline hover:text-zinc-300">Fakturering</a>
			<span aria-hidden>·</span>
			<button id="sign-out-btn" type="button" class="underline hover:text-zinc-300">
				Log ud
			</button>
		</footer>
	</main>
</Layout>

<script>
	document.getElementById('sign-out-btn')?.addEventListener('click', async () => {
		await fetch('/api/auth/sign-out', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: '{}',
		})
		window.location.href = '/login'
	})

	document.querySelectorAll<HTMLButtonElement>('.event-rename').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const id = btn.dataset.eventId
			const currentName = btn.dataset.eventName || ''
			if (!id) return

			const nextName = (
				await window.AppDialog.prompt({
					title: 'Omdøb event',
					confirmText: 'Gem navn',
					input: {
						label: 'Eventnavn',
						defaultValue: currentName,
						maxLength: 80,
					},
				})
			)?.trim()
			if (!nextName || nextName === currentName) return

			const row = btn.closest<HTMLElement>('.event-row')
			const nameEl = row?.querySelector<HTMLElement>('.event-name')
			btn.disabled = true

			try {
				const res = await fetch(`/api/events/${id}`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name: nextName }),
				})
				const payload = (await res.json().catch(() => null)) as { name?: string } | null
				if (!res.ok) throw new Error(`Omdøbning mislykkedes (${res.status})`)
				const savedName = payload?.name || nextName
				if (nameEl) nameEl.textContent = savedName
				btn.dataset.eventName = savedName
				btn.setAttribute('aria-label', `Omdøb ${savedName}`)
				const deleteBtn = row?.querySelector<HTMLButtonElement>('.event-delete')
				if (deleteBtn) {
					deleteBtn.dataset.eventName = savedName
					deleteBtn.setAttribute('aria-label', `Slet ${savedName}`)
				}
			} catch (e) {
				await window.AppDialog.alert({
					title: 'Kunne ikke omdøbe event',
					message: (e as Error).message,
				})
			} finally {
				btn.disabled = false
			}
		})
	})

	document.querySelectorAll<HTMLButtonElement>('.event-delete').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const id = btn.dataset.eventId
			const name = btn.dataset.eventName || 'dette event'
			if (!id) return
			const confirmed = await window.AppDialog.confirm({
				title: `Slet "${name}"?`,
				message: 'Dette sletter eventet og alle uploadede billeder. Dette kan ikke fortrydes.',
				confirmText: 'Slet event',
				danger: true,
			})
			if (!confirmed) return

			const row = btn.closest<HTMLElement>('.event-row')
			btn.disabled = true
			row?.classList.add('opacity-50', 'pointer-events-none')

			try {
				const res = await fetch(`/api/events/${id}`, { method: 'DELETE' })
				if (!res.ok) throw new Error(`Sletning mislykkedes (${res.status})`)
				row?.remove()
				if (document.querySelectorAll('.event-row').length === 0) window.location.reload()
			} catch (e) {
				btn.disabled = false
				row?.classList.remove('opacity-50', 'pointer-events-none')
				await window.AppDialog.alert({
					title: 'Kunne ikke slette event',
					message: (e as Error).message,
				})
			}
		})
	})
</script>

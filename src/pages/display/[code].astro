---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and, desc } from 'drizzle-orm'
import QRCode from 'qrcode'
import * as schema from '../../db/schema'
import Layout from '../../layouts/Layout.astro'
import PhotoWall from '../../components/PhotoWall.vue'
import PhotoCollage from '../../components/PhotoCollage.vue'
import { isTier } from '../../lib/tiers'
import { parseBranding } from '../../lib/branding'

export const prerender = false

const code = Astro.params.code?.toUpperCase()
if (!code) return Astro.redirect('/')

const db = drizzle(env.DB, { schema })
const [event] = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.shortCode, code))
	.limit(1)

if (!event) return Astro.redirect('/')

const initialPhotosRaw = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		createdAt: schema.photos.createdAt,
	})
	.from(schema.photos)
	.where(and(eq(schema.photos.eventId, event.id), eq(schema.photos.status, 'approved')))
	.orderBy(desc(schema.photos.createdAt))
	.limit(50)

const initialPhotos = initialPhotosRaw.map((p) => ({
	id: p.id,
	cfImagesId: p.cfImagesId,
	createdAt: p.createdAt?.getTime() ?? 0,
}))

const tier = isTier(event.tier) ? event.tier : 'free'
const isFreeTier = tier === 'free'
const branding = parseBranding(event.brandingJson)

// Free tier carries appelsin branding on the wall: logo top-left + a corner
// QR that doubles as the guest upload link. High error-correction so the
// centre can host a small logo overlay without breaking scannability.
// SVG output (rather than toDataURL → PNG) — canvas/pngjs aren't available
// in the Workers runtime, so the PNG path fails silently.
let qrDataUrl = ''
if (isFreeTier) {
	const guestUrl = `${env.PUBLIC_APP_URL}/e/${event.shortCode}`
	const qrSvg = await QRCode.toString(guestUrl, {
		type: 'svg',
		errorCorrectionLevel: 'H',
		margin: 0,
		color: { dark: '#071952', light: '#ffffff' },
	})
	qrDataUrl = `data:image/svg+xml;utf8,${encodeURIComponent(qrSvg)}`
}
---

<Layout title={`${event.name} — live`}>
	<main class="min-h-screen bg-[#071952]">
		{
			isFreeTier ? (
				<PhotoCollage
					client:only="vue"
					code={code}
					initialPhotos={initialPhotos}
					cfImagesHash={env.CF_IMAGES_HASH}
					qrDataUrl={qrDataUrl}
				/>
			) : (
				<PhotoWall
					client:only="vue"
					code={code}
					initialPhotos={initialPhotos}
					cfImagesHash={env.CF_IMAGES_HASH}
					branding={branding}
				/>
			)
		}
	</main>
</Layout>

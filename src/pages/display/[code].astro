---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and, desc, notInArray, sql } from 'drizzle-orm'
import QRCode from 'qrcode'
import * as schema from '../../db/schema'
import Layout from '../../layouts/Layout.astro'
import PhotoWall from '../../components/PhotoWall.vue'
import PhotoCollage from '../../components/PhotoCollage.vue'
import { isTier } from '../../lib/tiers'
import { parseBranding } from '../../lib/branding'
import { getContent, fill } from '../../lib/content'

export const prerender = false

const code = Astro.params.code?.toUpperCase()
if (!code) return Astro.redirect('/')

const db = drizzle(env.DB, { schema })
const [event] = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.shortCode, code))
	.limit(1)

if (!event) return Astro.redirect('/')

// 10 newest + 10 random from the rest, so the wall always shows a mix of
// fresh uploads and older highlights instead of just looping the last few.
// Left-join eventUsers so each tile can show the uploader's name overlay.
const newestRaw = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		cfStreamUid: schema.photos.cfStreamUid,
		mediaType: schema.photos.mediaType,
		durationSeconds: schema.photos.durationSeconds,
		createdAt: schema.photos.createdAt,
		uploaderName: schema.eventUsers.name,
		mediaWidth: schema.photos.mediaWidth,
		mediaHeight: schema.photos.mediaHeight,
	})
	.from(schema.photos)
	.leftJoin(schema.eventUsers, eq(schema.photos.eventUserId, schema.eventUsers.id))
	.where(and(eq(schema.photos.eventId, event.id), eq(schema.photos.status, 'approved')))
	.orderBy(desc(schema.photos.createdAt))
	.limit(10)

const newestIds = newestRaw.map((p) => p.id)
const randomRaw =
	newestIds.length > 0
		? await db
				.select({
					id: schema.photos.id,
					cfImagesId: schema.photos.cfImagesId,
					cfStreamUid: schema.photos.cfStreamUid,
					mediaType: schema.photos.mediaType,
					durationSeconds: schema.photos.durationSeconds,
					createdAt: schema.photos.createdAt,
					uploaderName: schema.eventUsers.name,
					mediaWidth: schema.photos.mediaWidth,
					mediaHeight: schema.photos.mediaHeight,
				})
				.from(schema.photos)
				.leftJoin(schema.eventUsers, eq(schema.photos.eventUserId, schema.eventUsers.id))
				.where(
					and(
						eq(schema.photos.eventId, event.id),
						eq(schema.photos.status, 'approved'),
						notInArray(schema.photos.id, newestIds)
					)
				)
				.orderBy(sql`random()`)
				.limit(10)
		: []

const mapPhoto = (p: typeof newestRaw[number]) => ({
	id: p.id,
	cfImagesId: p.cfImagesId,
	cfStreamUid: p.cfStreamUid,
	mediaType: p.mediaType,
	durationSeconds: p.durationSeconds,
	createdAt: p.createdAt?.getTime() ?? 0,
	uploaderName: p.uploaderName ?? null,
	mediaWidth: p.mediaWidth ?? null,
	mediaHeight: p.mediaHeight ?? null,
})

const newestMedia = newestRaw.map(mapPhoto)
const randomMedia = randomRaw.map(mapPhoto)
const initialPhotos = [
	...newestMedia.filter((p) => p.mediaType === 'video'),
	...newestMedia.filter((p) => p.mediaType !== 'video'),
	...randomMedia,
]

const tier = isTier(event.tier) ? event.tier : 'free'
const isFreeTier = tier === 'free'
const isLive = event.status === 'live'
const branding = parseBranding(event.brandingJson)

const guestUrl = `${env.PUBLIC_APP_URL}/e/${event.shortCode}`
const qrSvg = await QRCode.toString(guestUrl, {
	type: 'svg',
	errorCorrectionLevel: 'H',
	margin: 0,
	color: { dark: '#ffffff', light: '#07195200' },
})
const qrDataUrl = `data:image/svg+xml;utf8,${encodeURIComponent(qrSvg)}`

const t = getContent('da', 'display')
---

<Layout title={fill(t.pageTitle, { name: event.name })} locale="da" brandFonts>
	<main class="min-h-screen bg-navy">
		{
			isFreeTier ? (
				<PhotoCollage
					client:only="vue"
					code={code}
					initialPhotos={initialPhotos}
					cfImagesHash={env.CF_IMAGES_HASH} streamDomain={env.CF_STREAM_CUSTOMER_DOMAIN}
					qrDataUrl={qrDataUrl}
					isLive={isLive}
					messages={t.wall}
				/>
			) : (
				<div class="wall-viewport">
					<PhotoWall
						client:only="vue"
						code={code}
						initialPhotos={initialPhotos}
						cfImagesHash={env.CF_IMAGES_HASH} streamDomain={env.CF_STREAM_CUSTOMER_DOMAIN}
						branding={branding}
						qrDataUrl={qrDataUrl}
						isLive={isLive}
						messages={t.wall}
					/>
				</div>
			)
		}
	</main>
</Layout>

<style>
	.wall-viewport {
		width: 100vw;
		height: 100vh;
		container-type: size;
	}
</style>

---
import Layout from '../../../layouts/Layout.astro'
import Icon from '../../../components/brand/Icon.astro'
import Card from '../../../components/brand/Card.astro'
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, desc } from 'drizzle-orm'
import * as schema from '../../../db/schema'
import { SUBSCRIPTION_PLANS } from '../../../lib/billing'

export const prerender = false

const host = Astro.locals.host!
const db = drizzle(env.DB, { schema })

const [hostRow] = await db
	.select({ stripeCustomerId: schema.hosts.stripeCustomerId, plan: schema.hosts.plan })
	.from(schema.hosts)
	.where(eq(schema.hosts.id, host.id))
	.limit(1)

const [subscription] = await db
	.select()
	.from(schema.subscriptions)
	.where(eq(schema.subscriptions.hostId, host.id))
	.limit(1)

const purchases = await db
	.select({
		id: schema.eventPurchases.id,
		eventId: schema.eventPurchases.eventId,
		tier: schema.eventPurchases.tier,
		stripeSessionId: schema.eventPurchases.stripeSessionId,
	})
	.from(schema.eventPurchases)
	.where(eq(schema.eventPurchases.hostId, host.id))
	.orderBy(desc(schema.eventPurchases.id))
	.limit(20)

const justSubscribed = Astro.url.searchParams.get('subscribed') === '1'
const noCustomer = Astro.url.searchParams.get('nocustomer') === '1'

const onPro = hostRow?.plan === 'pro'
const hasCustomer = Boolean(hostRow?.stripeCustomerId)
const cancelsAtPeriodEnd = subscription?.cancelAtPeriodEnd && subscription.currentPeriodEnd
const subscriptionsEnabled =
	Boolean(env.STRIPE_PRICE_PRO_MONTHLY) && Boolean(env.STRIPE_PRICE_PRO_YEARLY)

function formatPlanPrice(priceCents: number, currency: string, interval: 'month' | 'year') {
	const amount = priceCents / 100
	const money = new Intl.NumberFormat('en-IE', {
		style: 'currency',
		currency: currency.toUpperCase(),
		maximumFractionDigits: 0,
	}).format(amount)
	return `${money}/${interval === 'month' ? 'mo' : 'yr'}`
}
---

<Layout title="Billing — appelsin" locale="en">
	<div class="app screen-root">
		<div class="fu mx-auto max-w-[880px] px-7 pt-7 pb-20">
			<a href="/en/app" class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-tx-3">
				<Icon name="arrow-left" size={18} />Dashboard
			</a>

			<div class="mt-[22px] mb-7">
				<h1 class="m-0 text-[clamp(30px,5cqw,42px)] font-extrabold tracking-[-0.02em]">Billing</h1>
				<p class="mt-2 text-base text-tx-3">Manage your subscription and invoices.</p>
			</div>

			{
				justSubscribed && (
					<div class="mb-5 rounded-md border border-[rgba(52,211,153,.3)] bg-live-bg px-[18px] py-[13px] text-sm text-live">
						Subscription active. Welcome to Pro.
					</div>
				)
			}
			{
				noCustomer && (
					<div class="mb-5 rounded-md border border-[rgba(255,162,41,.3)] bg-orange-soft px-[18px] py-[13px] text-sm text-accent">
						You have no billing history yet — buy an event pass or start a subscription first.
					</div>
				)
			}

			<Card pad={24} class="flex flex-wrap items-start justify-between gap-[18px]">
				<div>
					<p class="text-[12px] uppercase tracking-[0.08em] text-tx-3">Current plan</p>
					<p class="mt-1 text-[26px] font-extrabold text-tx">{onPro ? 'Pro' : 'Free'}</p>
					{
						subscription && (
							<p class="mt-1.5 text-[13px] text-tx-3">
								Status: {subscription.status}
								{cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<> · cancels {new Date(subscription.currentPeriodEnd).toLocaleDateString()}</>
								)}
								{!cancelsAtPeriodEnd && subscription.currentPeriodEnd && (
									<> · renews {new Date(subscription.currentPeriodEnd).toLocaleDateString()}</>
								)}
							</p>
						)
					}
				</div>
				{
					hasCustomer && (
						<form method="post" action="/api/billing/portal">
							<button type="submit" class="btn btn--secondary btn--sm">
								Manage in Stripe
								<Icon name="external" size={15} stroke={2.2} />
							</button>
						</form>
					)
				}
			</Card>

			{
				!onPro && subscriptionsEnabled && (
					<section class="mt-8">
						<div class="app-sec-label">Upgrade to Pro</div>
						<p class="-mt-1.5 mb-4 max-w-[560px] text-[14.5px] text-tx-3">
							Unlimited events, no per-event payment. Best for planners and venues running several events a month.
						</p>
						<div class="evt-actions">
							{Object.entries(SUBSCRIPTION_PLANS).map(([planId, plan]) => (
								<form method="post" action="/api/billing/subscribe" class="contents">
									<input type="hidden" name="plan" value={planId} />
									<button type="submit" class="action-tile flex w-full cursor-pointer items-center justify-between gap-4 rounded-lg border border-[rgba(255,162,41,.32)] bg-orange-soft px-[22px] py-5 text-left">
										<span>
											<span class="block text-[16.5px] font-bold text-accent">{plan.label}</span>
											<span class="mt-[3px] block text-[13.5px] text-tx-3">
												Pay {plan.interval === 'month' ? 'monthly' : 'yearly'}, cancel anytime
											</span>
										</span>
										<span class="font-mono font-bold text-accent">
											{formatPlanPrice(plan.priceCents, plan.currency, plan.interval)}
										</span>
									</button>
								</form>
							))}
						</div>
					</section>
				)
			}

			<section class="mt-8">
				<div class="app-sec-label">
					Event passes {purchases.length === 0 ? '(none yet)' : `(${purchases.length})`}
				</div>
				{
					purchases.length > 0 && (
						<div class="overflow-hidden rounded-xl border border-line-2 bg-s1">
							{purchases.map((p, i) => (
								<div class={`flex items-center justify-between gap-3 px-5 py-4 text-sm ${i ? 'border-t border-line-2' : ''}`}>
									<div>
										<div class="font-bold capitalize text-tx">{p.tier} pass</div>
										<div class="mt-0.5 font-mono text-[12px] text-tx-4">{p.stripeSessionId}</div>
									</div>
									{p.eventId && (
										<a href={`/en/app/events/${p.eventId}`} class="whitespace-nowrap text-[13px] font-semibold text-accent">
											View event →
										</a>
									)}
								</div>
							))}
						</div>
					)
				}
			</section>
		</div>
	</div>
</Layout>

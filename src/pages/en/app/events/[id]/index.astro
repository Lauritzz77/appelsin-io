---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, and, desc } from 'drizzle-orm'
import * as schema from '../../../../../db/schema'
import Layout from '../../../../../layouts/Layout.astro'
import Icon from '../../../../../components/brand/Icon.astro'
import Button from '../../../../../components/brand/Button.astro'
import Card from '../../../../../components/brand/Card.astro'
import StatusPill from '../../../../../components/brand/StatusPill.astro'
import CopyField from '../../../../../components/brand/CopyField.astro'
import ActionTile from '../../../../../components/brand/ActionTile.astro'
import { TIERS, isTier, formatPrice } from '../../../../../lib/tiers'
import { streamThumbnailUrl } from '../../../../../lib/media'
import { createStripe } from '../../../../../lib/stripe'
import { activateEventFromPaidCheckoutSession } from '../../../../../lib/event-purchases'
import { eventDownloadUrl, eventGalleryUrl } from '../../../../../lib/event-download'
import { countActiveMedia } from '../../../../../lib/event-media'

export const prerender = false

const host = Astro.locals.host!
const id = Astro.params.id!

const db = drizzle(env.DB, { schema })
let [event] = await db
	.select()
	.from(schema.events)
	.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
	.limit(1)

if (!event) return new Response('Event not found', { status: 404 })

const justPaid = Astro.url.searchParams.get('paid') === '1'
const activateError = Astro.url.searchParams.get('activate_error')
const checkoutSessionId = Astro.url.searchParams.get('session_id')
if (event.status === 'draft' && justPaid && checkoutSessionId?.startsWith('cs_')) {
	const stripe = createStripe(env)
	const session = await stripe.checkout.sessions.retrieve(checkoutSessionId)
	await activateEventFromPaidCheckoutSession(db, session, { eventId: event.id, hostId: host.id })
	;[event] = await db
		.select()
		.from(schema.events)
		.where(and(eq(schema.events.id, id), eq(schema.events.hostId, host.id)))
		.limit(1)
	if (!event) return new Response('Event not found', { status: 404 })
}

const recentPhotos = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		cfStreamUid: schema.photos.cfStreamUid,
		mediaType: schema.photos.mediaType,
		durationSeconds: schema.photos.durationSeconds,
		createdAt: schema.photos.createdAt,
	})
	.from(schema.photos)
	.where(and(eq(schema.photos.eventId, event.id), eq(schema.photos.status, 'approved')))
	.orderBy(desc(schema.photos.createdAt))
	.limit(12)

const photoCount = await countActiveMedia(db, event.id)

// Photos awaiting host approval — only ever non-empty when moderation is on.
const pendingPhotos = await db
	.select({
		id: schema.photos.id,
		cfImagesId: schema.photos.cfImagesId,
		cfStreamUid: schema.photos.cfStreamUid,
		mediaType: schema.photos.mediaType,
		durationSeconds: schema.photos.durationSeconds,
		uploaderName: schema.eventUsers.name,
	})
	.from(schema.photos)
	.leftJoin(schema.eventUsers, eq(schema.eventUsers.id, schema.photos.eventUserId))
	.where(and(eq(schema.photos.eventId, event.id), eq(schema.photos.status, 'pending')))
	.orderBy(desc(schema.photos.createdAt))
	.limit(60)

const guestUrl = `${env.PUBLIC_APP_URL}/e/${event.shortCode}`
const displayUrl = `${env.PUBLIC_APP_URL}/display/${event.shortCode}`
const downloadUrl = await eventDownloadUrl(Astro.url.origin, event.id, env.BETTER_AUTH_SECRET)
const galleryUrl = await eventGalleryUrl(Astro.url.origin, event.id, env.BETTER_AUTH_SECRET)

const tier = isTier(event.tier) ? event.tier : 'free'
const tierConfig = TIERS[tier]
const isPaidTier = tierConfig.priceCents > 0
const canEditEventDate = event.status !== 'live'
const eventDateInputValue = event.eventDate.toISOString().slice(0, 10)

const capPct = Math.min(100, Math.round((photoCount / tierConfig.photoCap) * 100))
const capWarn = photoCount >= tierConfig.photoCap
const capNear = !capWarn && photoCount >= tierConfig.photoCap * 0.8
const barColor = capWarn ? '#ef4444' : capNear ? 'var(--accent)' : undefined

const uploadOpensAt = new Date(event.eventDate.getTime() - 24 * 60 * 60 * 1000)
const uploadClosesAt = new Date(event.eventDate.getTime() + 2 * 24 * 60 * 60 * 1000)
const fmtDateTime = (d: Date) => d.toLocaleString('en-IE', { dateStyle: 'long', timeStyle: 'short' })

const runSteps: { title: string; desc: string }[] = []
if (event.status === 'draft' && isPaidTier)
	runSteps.push({ title: 'Pay for the event', desc: 'Stripe payment activates the event and opens uploads.' })
runSteps.push({ title: 'Download the QR pack', desc: `Print the A4 sign + 8 table cards with code ${event.shortCode}.` })
if (event.hasBigScreen)
	runSteps.push({ title: 'Open the photo wall', desc: `Show photos on the big screen — ${displayUrl}.` })
runSteps.push({
	title: 'Guests scan the QR',
	desc: `Photos appear instantly${event.hasBigScreen ? ' on the screen' : ' in the collection'}.`,
})
runSteps.push({ title: 'After the event', desc: 'Download everything as a zip — you and guests with email get a link.' })

const timelineRows: [string, string, string][] = [
	['Uploads open', fmtDateTime(uploadOpensAt), '24 hours before the event'],
	['Event closes', fmtDateTime(uploadClosesAt), '2 days after the event'],
	['Photos deleted', `after ${tierConfig.retentionDays} days`, 'then everything is deleted automatically'],
]
---

<Layout title={`${event.name} — appelsin`} locale="en">
	<div class="app screen-root">
		<div class="fu mx-auto max-w-[880px] px-7 pt-7 pb-20">
			<a href="/en/app" class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-tx-3">
				<Icon name="arrow-left" size={18} />All events
			</a>

			<div class="detail-head mt-[22px] mb-1.5">
				<div class="min-w-0">
					<h1 class="m-0 break-words text-[clamp(30px,5cqw,42px)] font-extrabold tracking-[-0.02em]">{event.name}</h1>
					<div class="mt-3 flex min-w-0 flex-wrap items-center gap-3 text-[15.5px] text-tx-3">
						<span class="inline-flex min-w-0 items-center gap-[7px]">
							<Icon name="calendar" size={16} />
							{new Date(event.eventDate).toLocaleDateString('en-IE', { dateStyle: 'long' })}
						</span>
						<span class="opacity-50">·</span>
						<span class="min-w-0 break-words">
							<strong class="text-accent">{tierConfig.label}</strong> plan · up to {tierConfig.photoCap.toLocaleString('en-IE')} photos · {tierConfig.retentionDays}-day retention
						</span>
					</div>
				</div>
				<StatusPill status={event.status} locale="en" />
			</div>

			{
				justPaid && event.status === 'live' && (
					<div class="mt-4 rounded-md border border-[rgba(52,211,153,.3)] bg-live-bg px-[18px] py-[13px] text-sm text-live">
						Payment confirmed. Your event is live.
					</div>
				)
			}
			{
				justPaid && event.status === 'draft' && (
					<div class="mt-4 rounded-md border border-[rgba(255,162,41,.3)] bg-orange-soft px-[18px] py-[13px] text-sm text-accent">
						Payment received — finalising. Refresh in a moment if the status doesn’t flip to <em>live</em>.
					</div>
				)
			}
			{
				activateError === 'free_limit' && (
					<div class="mt-4 rounded-md border border-[rgba(244,63,94,.3)] bg-[rgba(244,63,94,.1)] px-[18px] py-[13px] text-sm text-danger">
						You already have an active free event. End it first, or upgrade this one to Basic or Gold.
					</div>
				)
			}

			{
				(event.status === 'draft' || event.status === 'live') && (
					<div class="mt-[22px] rounded-xl border border-[rgba(255,162,41,.26)] bg-orange-soft px-5 py-5 sm:mt-[26px] sm:px-7 sm:py-[26px]">
						<div class="mb-4 flex items-center gap-2 text-[16px] font-bold text-accent sm:mb-5 sm:gap-[9px] sm:text-[17px]">
							<Icon name="sparkle" size={19} fill="currentColor" stroke={0} />How to run your event
						</div>
						<div class="grid gap-3 sm:gap-4">
							{runSteps.map((s, i) => (
								<div class="flex items-start gap-3 sm:gap-[15px]">
									<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent text-[12px] font-extrabold text-[#2C1700] sm:h-8 sm:w-8 sm:text-sm">
										{i + 1}
									</span>
									<div>
										<div class="text-[15.5px] font-bold text-tx sm:text-[16.5px]">{s.title}</div>
										<div class="mt-px text-[14px] leading-[1.45] text-tx-2 sm:mt-0.5 sm:text-[14.5px] sm:leading-normal">{s.desc}</div>
									</div>
								</div>
							))}
						</div>
					</div>
				)
			}

			<div class="mt-7 grid grid-cols-1 gap-4">
				<Card pad={24}>
					<form id="rename-event-form" data-event-id={event.id}>
						<label class="block">
							<span class="field-label">Event name</span>
							<input
								id="event-name-input"
								name="name"
								type="text"
								value={event.name}
								maxlength="80"
								class="field-input"
								required
							/>
						</label>
						<div class="mt-[14px] flex items-center gap-[14px]">
							<Button id="rename-event-btn" type="submit" size="sm">Save name</Button>
							<p id="rename-event-status" class="text-sm text-zinc-500" aria-live="polite"></p>
						</div>
					</form>
					<form id="event-date-form" data-event-id={event.id} class="mt-5 border-t border-line-2 pt-5">
						<label class="block">
							<span class="field-label">Event date</span>
							<input
								id="event-date-input"
								name="eventDate"
								type="date"
								value={eventDateInputValue}
								class="field-input"
								required
								disabled={!canEditEventDate}
							/>
						</label>
						<div class="mt-[14px] flex flex-wrap items-center gap-[14px]">
							{
								canEditEventDate ? (
									<Button id="event-date-btn" type="submit" size="sm">Save date</Button>
								) : (
									<p class="m-0 text-sm text-tx-3">The date cannot be changed while the event is live.</p>
								)
							}
							<p id="event-date-status" class="text-sm text-zinc-500" aria-live="polite"></p>
						</div>
					</form>
				</Card>
				<Card pad={24}>
					<div class="grid grid-cols-1 gap-4">
						<CopyField big label="Short code — guests type it at appelsin.io" value={event.shortCode} />
						<CopyField label="Direct guest link" mono={false} value={guestUrl} />
					</div>
				</Card>
			</div>

			<Card pad={20} class="mt-4 grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-x-3 gap-y-2 sm:gap-x-[18px]">
				<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-white/[.06] text-accent sm:h-[46px] sm:w-[46px]">
					<Icon name="monitor" size={22} />
				</span>
				<div class="min-w-0 text-[16px] font-bold leading-tight sm:text-[16.5px]">Big screen at the event</div>
				<label class="toggle justify-self-end">
					<input id="has-big-screen-toggle" type="checkbox" checked={event.hasBigScreen} data-event-id={event.id} />
					<span class="knob"></span>
				</label>
				<div class="col-span-3 mt-1 text-sm leading-[1.45] text-tx-3 sm:col-span-2 sm:col-start-2 sm:mt-0 sm:leading-normal">
					Turn off if photos won’t be shown on a screen at the venue. Changes the QR pack copy.
				</div>
				<p id="has-big-screen-status" class="col-span-3 min-h-[1rem] text-xs text-zinc-500 sm:col-span-2 sm:col-start-2" aria-live="polite"></p>
			</Card>

			<Card pad={20} class="mt-4 grid grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-x-3 gap-y-2 sm:gap-x-[18px]">
				<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-white/[.06] text-accent sm:h-[46px] sm:w-[46px]">
					<Icon name="check" size={22} />
				</span>
				<div class="min-w-0 text-[16px] font-bold leading-tight sm:text-[16.5px]">Approve photos before they appear</div>
				<label class="toggle justify-self-end">
					<input id="moderation-toggle" type="checkbox" checked={event.moderationMode === 'queue'} data-event-id={event.id} />
					<span class="knob"></span>
				</label>
				<div class="col-span-3 mt-1 text-sm leading-[1.45] text-tx-3 sm:col-span-2 sm:col-start-2 sm:mt-0 sm:leading-normal">
					When this is on, you approve each photo before it shows on the photo wall and in the collection.
				</div>
				<p id="moderation-status" class="col-span-3 min-h-[1rem] text-xs text-zinc-500 sm:col-span-2 sm:col-start-2" aria-live="polite"></p>
			</Card>

			<div class="app-sec-label mt-8">Tools</div>
			<div class="evt-actions">
				<ActionTile
					href={`/en/app/events/${event.id}/qr.pdf`}
					icon="qr"
					title="Download QR pack"
					sub="A4 sign + 8 table cards (PDF)"
					arrow="download"
				/>
				{
					photoCount > 0 && (
						<div class="download-action">
							<ActionTile
								href={galleryUrl}
								icon="image"
								title="Open photo collection"
								sub={`${photoCount.toLocaleString('en-IE')} uploads · share or save on iPhone`}
								arrow="external"
							/>
							<a class="download-copy-mobile" href={downloadUrl}>
								<Icon name="download" size={16} stroke={2.2} />Download ZIP
							</a>
						</div>
					)
				}
				{
					isPaidTier && (
						<ActionTile
							href={`/en/app/events/${event.id}/style`}
							icon="pencil"
							title="Customise photo wall"
							sub="Theme, density and title overlay"
							arrow="chevron-right"
						/>
					)
				}
				{
					event.status === 'live' ? (
						<ActionTile
							href={`/display/${event.shortCode}`}
							target="_blank"
							icon="monitor"
							title="Open photo wall"
							sub={`appelsin.io/display/${event.shortCode}`}
							arrow="external"
							accent
						/>
					) : event.status === 'draft' && isPaidTier ? (
						<form method="post" action={`/api/events/${event.id}/checkout`} style="display:contents">
							<ActionTile
								icon="card"
								title={`Pay ${formatPrice(tier, 'en')} & activate`}
								sub={`${tierConfig.label} — opens Stripe checkout`}
								arrow="external"
								accent
							/>
						</form>
					) : null
				}
			</div>

			<Card pad={26} class="mt-7">
				<div class="mb-[18px] flex items-center gap-[9px] text-[17px] font-bold">
					<Icon name="clock" size={19} class="text-accent" />Timeline
				</div>
				{
					timelineRows.map((r, i) => (
						<div class={`flex items-baseline gap-[14px] py-3 ${i ? 'border-t border-line-2' : ''}`}>
							<span
								class="mt-[5px] h-[11px] w-[11px] shrink-0 rounded-full"
								style={`background:${i === 0 ? 'var(--live)' : i === 1 ? 'var(--accent)' : 'var(--tx-4)'}`}
							/>
							<div class="min-w-0 flex-1">
								<span class="text-[15.5px] text-tx-2">{r[0]} </span>
								<strong class="break-words text-[15.5px] text-tx">{r[1]}</strong>
								<div class="mt-0.5 text-[13.5px] text-tx-3">{r[2]}</div>
							</div>
						</div>
					))
				}
				<div class="mt-5 border-t border-line-2 pt-5">
					<div class="mb-2.5 flex justify-between text-[15px]">
						<span class="font-semibold text-tx-2">Uploads</span>
						<span
							class="tabular-nums font-mono font-bold"
							style={`color:${capWarn ? '#ff8499' : capNear ? 'var(--accent)' : 'var(--tx)'}`}
						>
							{photoCount.toLocaleString('en-IE')} / {tierConfig.photoCap.toLocaleString('en-IE')}
						</span>
					</div>
					<div class="progress">
						<div class="bar" style={`width:${capPct}%${barColor ? `;background:${barColor};box-shadow:none` : ''}`}></div>
					</div>
					{
						capWarn && (
							<p class="mt-3 text-[13px] text-danger">
								This event has reached its upload limit. New uploads are blocked until you upgrade the tier or rejected photos free up slots.
							</p>
						)
					}
					{
						capNear && (
							<p class="mt-3 text-[13px] text-accent">
								Approaching the upload limit — consider upgrading before the cap is hit.
							</p>
						)
					}
				</div>
			</Card>

			{
				pendingPhotos.length > 0 && (
					<section id="pending-section" class="mt-8">
						<div class="app-sec-label" style="margin:0 0 14px">
							Awaiting approval <span id="pending-count">({pendingPhotos.length})</span>
						</div>
						<div id="pending-grid" class="up-grid">
							{pendingPhotos.map((p) => (
								<div class="photo-tile group relative aspect-square overflow-hidden rounded bg-zinc-900 ring-2 ring-accent" data-photo-id={p.id}>
									{p.mediaType === 'video' && p.cfStreamUid ? (
										<img src={streamThumbnailUrl(p.cfStreamUid, env.CF_STREAM_CUSTOMER_DOMAIN)} alt="" class="h-full w-full object-cover" />
									) : p.cfImagesId ? (
										<img src={`https://imagedelivery.net/${env.CF_IMAGES_HASH}/${p.cfImagesId}/public`} alt="" class="h-full w-full object-cover" />
									) : (
										<div class="flex h-full w-full items-center justify-center text-xs text-zinc-600">no image</div>
									)}
									<div class="absolute inset-x-1 bottom-1 flex gap-1">
										<button type="button" class="photo-approve flex h-8 flex-1 items-center justify-center gap-1 rounded bg-live text-[12px] font-bold text-[#04220f] transition hover:brightness-110" data-photo-id={p.id}>
											<Icon name="check" size={14} stroke={3} />Approve
										</button>
										<button type="button" class="photo-reject flex h-8 w-8 shrink-0 items-center justify-center rounded bg-zinc-950/70 text-zinc-100 transition hover:bg-red-600" data-photo-id={p.id} aria-label="Reject photo" title="Reject photo">
											<Icon name="trash" size={15} stroke={2.2} />
										</button>
									</div>
								</div>
							))}
						</div>
					</section>
				)
			}

			<div class="mt-8 mb-[14px] flex flex-wrap items-center justify-between gap-3">
				<div class="app-sec-label" style="margin:0">
					Recent uploads <span id="recent-uploads-count">{recentPhotos.length === 0 ? '(none yet)' : `(${recentPhotos.length})`}</span>
				</div>
				<div class="upload-tools">
					{
						event.status === 'live' && (
							<span class="inline-flex items-center gap-[7px] text-[13px] font-semibold text-live">
								<span class="h-[7px] w-[7px] rounded-full bg-live [animation:pulseDot_2s_infinite]" />updating live
							</span>
						)
					}
					<div class="view-toggle" role="group" aria-label="Show uploads">
						<button type="button" class="view-toggle-btn is-active" data-upload-view="grid" aria-pressed="true" title="Show as grid">
							<Icon name="grid" size={17} />
						</button>
						<button type="button" class="view-toggle-btn" data-upload-view="column" aria-pressed="false" title="Show in one column">
							<Icon name="list" size={18} />
						</button>
					</div>
				</div>
			</div>
			<section
				id="recent-uploads"
				data-event-code={event.shortCode}
				data-event-status={event.status}
				data-cf-images-hash={env.CF_IMAGES_HASH}
				data-cf-stream-domain={env.CF_STREAM_CUSTOMER_DOMAIN}
			>
				<div id="photo-grid" class="up-grid">
					{
						recentPhotos.map((p) => (
							<div
								class="photo-tile group relative aspect-square overflow-hidden rounded bg-zinc-900"
								data-photo-id={p.id}
							>
								{p.mediaType === 'video' && p.cfStreamUid ? (
									<>
										<img
											src={streamThumbnailUrl(p.cfStreamUid, env.CF_STREAM_CUSTOMER_DOMAIN)}
											alt=""
											class="h-full w-full object-cover"
										/>
										<span class="absolute bottom-1 left-1 rounded bg-zinc-950/80 px-1.5 py-0.5 text-[10px] font-medium text-white">
											{p.durationSeconds ? `${p.durationSeconds}s` : 'Video'}
										</span>
									</>
								) : p.cfImagesId ? (
									<img
										src={`https://imagedelivery.net/${env.CF_IMAGES_HASH}/${p.cfImagesId}/public`}
										alt=""
										class="h-full w-full object-cover"
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center text-xs text-zinc-600">no image</div>
								)}
								<button
									type="button"
									class="photo-delete absolute right-1 top-1 flex h-7 w-7 items-center justify-center rounded-full bg-zinc-950/70 text-zinc-100 opacity-100 transition hover:bg-red-600 hover:text-white sm:opacity-0 sm:group-hover:opacity-100 sm:focus:opacity-100"
									data-photo-id={p.id}
									aria-label="Delete photo"
									title="Delete photo"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 20 20"
										fill="currentColor"
										class="h-4 w-4"
										aria-hidden="true"
									>
										<path
											fill-rule="evenodd"
											d="M8.75 1.5A1.5 1.5 0 0 0 7.25 3v.5H4.5a.75.75 0 0 0 0 1.5h.443l.737 11.05A2 2 0 0 0 7.676 18h4.648a2 2 0 0 0 1.996-1.95L15.057 5h.443a.75.75 0 0 0 0-1.5H12.75V3a1.5 1.5 0 0 0-1.5-1.5h-2.5Zm2 2.5V3h-2v1h2ZM8.5 7.75a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1-.75-.75Z"
											clip-rule="evenodd"
										/>
									</svg>
								</button>
							</div>
						))
					}
				</div>
			</section>

			<div class="mt-10 flex flex-wrap items-center gap-[18px] rounded-xl border border-[rgba(244,63,94,.22)] bg-[rgba(244,63,94,.05)] px-6 py-[22px]">
				<div class="min-w-[200px] flex-1">
					<div class="text-base font-bold text-danger">Delete event</div>
					<div class="mt-[3px] text-sm text-tx-3">
						Deletes this event and all uploaded photos. This cannot be undone.
					</div>
				</div>
				<button
					id="delete-event-btn"
					type="button"
					class="btn btn--danger btn--sm"
					data-event-id={event.id}
					data-event-name={event.name}
				>
					<Icon name="trash" size={16} stroke={2.2} />Delete event
				</button>
			</div>
		</div>
	</div>
</Layout>

<script>
	document.getElementById('has-big-screen-toggle')?.addEventListener('change', async (event) => {
		const input = event.currentTarget as HTMLInputElement
		const status = document.getElementById('has-big-screen-status')
		const id = input.dataset.eventId
		if (!id) return

		const desired = input.checked
		input.disabled = true
		if (status) {
			status.textContent = 'Saving...'
			status.className = 'mt-2 text-xs text-zinc-500'
		}

		try {
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ hasBigScreen: desired }),
			})
			if (!res.ok) throw new Error(`Could not save (${res.status})`)
			if (status) {
				status.textContent = 'Saved'
				status.className = 'mt-2 text-xs text-green-400'
			}
		} catch (e) {
			input.checked = !desired
			if (status) {
				status.textContent = (e as Error).message
				status.className = 'mt-2 text-xs text-red-400'
			}
		} finally {
			input.disabled = false
		}
	})

	document.getElementById('rename-event-form')?.addEventListener('submit', async (event) => {
		event.preventDefault()
		const form = event.currentTarget as HTMLFormElement
		const input = document.getElementById('event-name-input') as HTMLInputElement | null
		const button = document.getElementById('rename-event-btn') as HTMLButtonElement | null
		const status = document.getElementById('rename-event-status')
		const name = input?.value.trim()
		if (!name || !button) return

		button.disabled = true
		if (status) {
			status.textContent = 'Saving...'
			status.className = 'text-sm text-zinc-500'
		}

		try {
			const id = form.dataset.eventId
			if (!id) throw new Error('Missing event id')
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name }),
			})
			const payload = (await res.json().catch(() => null)) as { name?: string } | null
			if (!res.ok) throw new Error(`Rename failed (${res.status})`)
			document.title = `${payload?.name || name} — appelsin`
			const heading = document.querySelector('h1')
			if (heading) heading.textContent = payload?.name || name
			if (status) {
				status.textContent = 'Saved'
				status.className = 'text-sm text-green-400'
			}
		} catch (e) {
			if (status) {
				status.textContent = (e as Error).message
				status.className = 'text-sm text-red-400'
			}
		} finally {
			button.disabled = false
		}
	})

	document.getElementById('event-date-form')?.addEventListener('submit', async (event) => {
		event.preventDefault()
		const form = event.currentTarget as HTMLFormElement
		const input = document.getElementById('event-date-input') as HTMLInputElement | null
		const button = document.getElementById('event-date-btn') as HTMLButtonElement | null
		const status = document.getElementById('event-date-status')
		const eventDate = input?.value
		if (!eventDate || !button) return

		button.disabled = true
		if (status) {
			status.textContent = 'Saving...'
			status.className = 'text-sm text-zinc-500'
		}

		try {
			const id = form.dataset.eventId
			if (!id) throw new Error('Missing event id')
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ eventDate }),
			})
			if (!res.ok) throw new Error(`Date update failed (${res.status})`)
			if (status) {
				status.textContent = 'Saved'
				status.className = 'text-sm text-green-400'
			}
			window.setTimeout(() => window.location.reload(), 350)
		} catch (e) {
			if (status) {
				status.textContent = (e as Error).message
				status.className = 'text-sm text-red-400'
			}
		} finally {
			button.disabled = false
		}
	})

	document.getElementById('delete-event-btn')?.addEventListener('click', async (event) => {
		const btn = event.currentTarget as HTMLButtonElement
		const id = btn.dataset.eventId
		const name = btn.dataset.eventName || 'this event'
		if (!id) return
		const confirmed = await window.AppDialog.confirm({
			title: `Delete "${name}"?`,
			message: 'This deletes the event and all uploaded photos. This cannot be undone.',
			confirmText: 'Delete event',
			danger: true,
		})
		if (!confirmed) return

		btn.disabled = true
		try {
			const res = await fetch(`/api/events/${id}`, { method: 'DELETE' })
			if (!res.ok) throw new Error(`Delete failed (${res.status})`)
			window.location.href = '/en/app'
		} catch (e) {
			btn.disabled = false
			await window.AppDialog.alert({
				title: 'Could not delete event',
				message: (e as Error).message,
			})
		}
	})

	// Click-to-copy fields (code + guest link).
	document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			const value = btn.dataset.copy || ''
			navigator.clipboard?.writeText(value)
			const ind = btn.querySelector<HTMLElement>('.copy-ind')
			if (!ind) return
			const prev = ind.innerHTML
			ind.textContent = 'Copied'
			ind.style.color = 'var(--live)'
			window.setTimeout(() => {
				ind.innerHTML = prev
				ind.style.color = 'var(--tx-3)'
			}, 1400)
		})
	})

	const recentUploads = document.getElementById('recent-uploads')
	const photoGrid = document.getElementById('photo-grid')
	const recentCount = document.getElementById('recent-uploads-count')
	const uploadViewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-upload-view]'))
	const eventCode = recentUploads?.dataset.eventCode
	const eventStatus = recentUploads?.dataset.eventStatus
	const cfImagesHash = recentUploads?.dataset.cfImagesHash ?? ''
	const cfStreamDomain = recentUploads?.dataset.cfStreamDomain ?? ''
	const uploadViewStorageKey = 'appelsin:upload-view'

	type UploadView = 'grid' | 'column'

	function setUploadView(view: UploadView) {
		if (!photoGrid) return
		photoGrid.classList.toggle('up-grid--column', view === 'column')
		uploadViewButtons.forEach((btn) => {
			const active = btn.dataset.uploadView === view
			btn.classList.toggle('is-active', active)
			btn.setAttribute('aria-pressed', String(active))
		})
		localStorage.setItem(uploadViewStorageKey, view)
	}

	const savedUploadView = localStorage.getItem(uploadViewStorageKey) === 'column' ? 'column' : 'grid'
	setUploadView(savedUploadView)

	uploadViewButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const view = btn.dataset.uploadView === 'column' ? 'column' : 'grid'
			setUploadView(view)
		})
	})

	function updateRecentCount() {
		if (!recentCount || !photoGrid) return
		const n = photoGrid.children.length
		recentCount.textContent = n === 0 ? '(none yet)' : `(${n})`
	}

	function streamThumbUrl(uid: string): string {
		return `https://${cfStreamDomain}/${uid}/thumbnails/thumbnail.jpg?time=1s&height=600`
	}

	type IncomingPhoto = {
		photoId: string
		mediaType: 'photo' | 'video'
		cfImagesId: string | null
		cfStreamUid: string | null
		durationSeconds: number | null
	}

	function buildTile(p: IncomingPhoto): HTMLDivElement {
		const tile = document.createElement('div')
		tile.className = 'photo-tile group relative aspect-square overflow-hidden rounded bg-zinc-900'
		tile.dataset.photoId = p.photoId

		let inner = ''
		if (p.mediaType === 'video' && p.cfStreamUid) {
			inner += `<img src="${streamThumbUrl(p.cfStreamUid)}" alt="" class="h-full w-full object-cover" />`
			inner += `<span class="absolute bottom-1 left-1 rounded bg-zinc-950/80 px-1.5 py-0.5 text-[10px] font-medium text-white">${
				p.durationSeconds ? `${p.durationSeconds}s` : 'Video'
			}</span>`
		} else if (p.cfImagesId) {
			inner += `<img src="https://imagedelivery.net/${cfImagesHash}/${p.cfImagesId}/public" alt="" class="h-full w-full object-cover" />`
		} else {
			inner += `<div class="flex h-full w-full items-center justify-center text-xs text-zinc-600">no image</div>`
		}
		inner += `<button
			type="button"
			class="photo-delete absolute right-1 top-1 flex h-7 w-7 items-center justify-center rounded-full bg-zinc-950/70 text-zinc-100 opacity-100 transition hover:bg-red-600 hover:text-white sm:opacity-0 sm:group-hover:opacity-100 sm:focus:opacity-100"
			data-photo-id="${p.photoId}"
			aria-label="Delete photo"
			title="Delete photo"
		><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path fill-rule="evenodd" d="M8.75 1.5A1.5 1.5 0 0 0 7.25 3v.5H4.5a.75.75 0 0 0 0 1.5h.443l.737 11.05A2 2 0 0 0 7.676 18h4.648a2 2 0 0 0 1.996-1.95L15.057 5h.443a.75.75 0 0 0 0-1.5H12.75V3a1.5 1.5 0 0 0-1.5-1.5h-2.5Zm2 2.5V3h-2v1h2ZM8.5 7.75a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" /></svg></button>`
		tile.innerHTML = inner
		return tile
	}

	function addPhoto(p: IncomingPhoto) {
		if (!photoGrid) return
		if (photoGrid.querySelector(`[data-photo-id="${p.photoId}"]`)) return
		photoGrid.insertBefore(buildTile(p), photoGrid.firstChild)
		updateRecentCount()
	}

	function removePhotoTile(photoId: string) {
		if (!photoGrid) return
		const tile = photoGrid.querySelector(`[data-photo-id="${photoId}"]`)
		tile?.remove()
		updateRecentCount()
	}

	photoGrid?.addEventListener('click', async (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.photo-delete')
		if (!btn) return
		const id = btn.dataset.photoId
		if (!id) return
		const confirmed = await window.AppDialog.confirm({
			title: 'Delete photo?',
			message: 'This removes the photo from the event. This cannot be undone.',
			confirmText: 'Delete photo',
			danger: true,
		})
		if (!confirmed) return

		const tile = btn.closest<HTMLElement>('.photo-tile')
		tile?.classList.add('opacity-50', 'pointer-events-none')

		try {
			const res = await fetch(`/api/photos/${id}`, { method: 'DELETE' })
			if (!res.ok) throw new Error(`Delete failed (${res.status})`)
			removePhotoTile(id)
		} catch (err) {
			tile?.classList.remove('opacity-50', 'pointer-events-none')
			await window.AppDialog.alert({
				title: 'Could not delete photo',
				message: (err as Error).message,
			})
		}
	})

	if (eventStatus === 'live' && eventCode) {
		let socket: WebSocket | null = null
		let reconnectTimer: ReturnType<typeof setTimeout> | null = null

		function connect() {
			const proto = location.protocol === 'https:' ? 'wss' : 'ws'
			socket = new WebSocket(`${proto}://${location.host}/api/display-socket?code=${eventCode}`)
			socket.onopen = () => socket?.send(JSON.stringify({ type: 'hello' }))
			socket.onmessage = (e) => {
				try {
					const msg = JSON.parse(e.data) as
						| ({ type: 'new-photo' } & IncomingPhoto)
						| { type: 'delete-photo'; photoId: string }
						| { type: 'ack' }
					if (msg.type === 'new-photo') {
						addPhoto({
							photoId: msg.photoId,
							mediaType: msg.mediaType,
							cfImagesId: msg.cfImagesId,
							cfStreamUid: msg.cfStreamUid,
							durationSeconds: msg.durationSeconds,
						})
					} else if (msg.type === 'delete-photo') {
						removePhotoTile(msg.photoId)
					}
				} catch {
					/* ignore malformed */
				}
			}
			socket.onclose = () => {
				reconnectTimer = setTimeout(connect, 2000)
			}
			socket.onerror = () => socket?.close()
		}
		connect()
		window.addEventListener('beforeunload', () => {
			if (reconnectTimer) clearTimeout(reconnectTimer)
			socket?.close()
		})
	}
</script>

<script>
	// Moderation toggle — switch the event between instant display and an approval queue.
	document.getElementById('moderation-toggle')?.addEventListener('change', async (event) => {
		const input = event.currentTarget as HTMLInputElement
		const status = document.getElementById('moderation-status')
		const id = input.dataset.eventId
		if (!id) return
		const desired = input.checked
		const statusBase = 'col-span-3 min-h-[1rem] text-xs sm:col-span-2 sm:col-start-2'
		input.disabled = true
		if (status) {
			status.textContent = 'Saving...'
			status.className = `${statusBase} text-zinc-500`
		}
		try {
			const res = await fetch(`/api/events/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ moderationMode: desired ? 'queue' : 'open' }),
			})
			if (!res.ok) throw new Error(`Could not save (${res.status})`)
			if (status) {
				status.textContent = desired ? 'Approval turned on' : 'Approval turned off'
				status.className = `${statusBase} text-green-400`
			}
		} catch (e) {
			input.checked = !desired
			if (status) {
				status.textContent = (e as Error).message
				status.className = `${statusBase} text-red-400`
			}
		} finally {
			input.disabled = false
		}
	})

	// Approve / reject photos held in the moderation queue.
	const pendingGrid = document.getElementById('pending-grid')
	const pendingCountEl = document.getElementById('pending-count')
	function refreshPendingCount() {
		if (!pendingGrid || !pendingCountEl) return
		const n = pendingGrid.children.length
		pendingCountEl.textContent = `(${n})`
		if (n === 0) document.getElementById('pending-section')?.remove()
	}
	pendingGrid?.addEventListener('click', async (e) => {
		const target = e.target as HTMLElement
		const approveBtn = target.closest<HTMLButtonElement>('.photo-approve')
		const rejectBtn = target.closest<HTMLButtonElement>('.photo-reject')
		const btn = approveBtn ?? rejectBtn
		if (!btn) return
		const id = btn.dataset.photoId
		if (!id) return
		const nextStatus = approveBtn ? 'approved' : 'rejected'
		const tile = btn.closest<HTMLElement>('.photo-tile')
		tile?.classList.add('opacity-50', 'pointer-events-none')
		try {
			const res = await fetch(`/api/photos/${id}`, {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ status: nextStatus }),
			})
			if (!res.ok) throw new Error(`Action failed (${res.status})`)
			tile?.remove()
			refreshPendingCount()
		} catch (err) {
			tile?.classList.remove('opacity-50', 'pointer-events-none')
			await window.AppDialog.alert({
				title: 'Could not update photo',
				message: (err as Error).message,
			})
		}
	})
</script>

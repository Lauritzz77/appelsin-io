---
import Layout from '../../../../layouts/Layout.astro'
import { TIERS, TIER_IDS, isTier, formatPrice, type Tier } from '../../../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!

const requested = Astro.url.searchParams.get('tier')
const selectedTier: Tier = isTier(requested) ? requested : 'free'
const createError = Astro.url.searchParams.get('error')

const tierLabel = (tier: Tier) => (tier === 'free' ? 'Free' : TIERS[tier].label)
const tierPrice = (tier: Tier) => formatPrice(tier, 'en')
const tierDescription = (tier: Tier) => {
	const t = TIERS[tier]
	const parts = [
		`Up to ${t.photoCap.toLocaleString('en-IE')} photos`,
		`${t.retentionDays}-day retention`,
	]
	if (t.watermark) parts.push('appelsin watermark')
	return parts.join(' · ')
}
---

<Layout title="New event — appelsin" locale="en">
	<main class="mx-auto max-w-xl px-6 py-12">
		<a href="/en" class="mb-6 inline-block text-sm text-zinc-400 hover:text-zinc-200">← Back</a>
		<h1 class="mb-2 text-2xl font-semibold tracking-tight">New event</h1>
		<p class="mb-8 text-sm text-zinc-400 leading-6">
			An event groups photos from one occasion — a wedding, birthday, or company party. You get a short code and a QR that guests scan to upload pictures. Everything shows live on a big screen, and you can download the whole set as a zip afterwards.
		</p>

		{
			createError === 'free_exists' && (
				<div class="mb-6 rounded-md border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300">
					You already have a free event. Delete the existing one first, or pick Basic or Gold for this event.
				</div>
			)
		}

		<form method="post" action="/api/events/new" class="space-y-6">
			<input type="hidden" name="returnToPrefix" value="/en/app/events" />
			<div>
				<label for="name" class="mb-1 block text-sm text-zinc-300">Event name</label>
				<input
					id="name"
					name="name"
					type="text"
					required
					maxlength="80"
					placeholder="Anna & Jonas — wedding"
					class="w-full rounded-md border border-zinc-800 bg-zinc-900 px-3 py-2 text-zinc-100 placeholder:text-zinc-600 focus:border-orange-500 focus:outline-none"
				/>
			</div>
			<div>
				<label for="eventDate" class="mb-1 block text-sm text-zinc-300">Event date</label>
				<input
					id="eventDate"
					name="eventDate"
					type="date"
					required
					class="w-full rounded-md border border-zinc-800 bg-zinc-900 px-3 py-2 text-zinc-100 focus:border-orange-500 focus:outline-none"
				/>
				<div class="mt-3 rounded-md border border-zinc-800 bg-zinc-900/40 p-4 text-sm leading-6 text-zinc-300">
					<p class="mb-2 text-xs font-medium uppercase tracking-wider text-orange-400">
						The date drives the timeline
					</p>
					<ul class="space-y-2">
						<li>• Guests can upload from <strong class="text-zinc-100">24 hours before</strong> — so anyone scanning the QR the night before can get going.</li>
						<li>• The event is <strong class="text-zinc-100">live for 2 days after</strong> — catching late-night and morning-after photos.</li>
						<li>• Then it's marked <em class="not-italic font-medium text-zinc-100">ended</em>, and photos are kept for <strong class="text-zinc-100">7-90 days</strong> depending on plan, then everything is deleted automatically.</li>
					</ul>
				</div>
			</div>

			<fieldset>
				<legend class="mb-2 block text-sm text-zinc-300">Plan</legend>
				<div class="space-y-2">
					{TIER_IDS.map((id) => {
						const t = TIERS[id]
						const isSelected = id === selectedTier
						return (
							<label
								class:list={[
									'flex cursor-pointer items-start gap-3 rounded-md border p-3 transition',
									isSelected
										? 'border-orange-500 bg-orange-500/10'
										: 'border-zinc-800 bg-zinc-900 hover:border-zinc-700',
								]}
							>
								<input
									type="radio"
									name="tier"
									value={id}
									checked={isSelected}
									class="mt-1 accent-orange-500"
								/>
								<div class="flex-1">
									<div class="flex items-baseline justify-between">
										<span class="font-medium text-zinc-100">{tierLabel(id)}</span>
										<span class="text-sm text-zinc-300">
											{tierPrice(id)}
											{t.priceCents > 0 && <span class="text-zinc-500"> / event</span>}
										</span>
									</div>
									<div class="mt-1 text-xs text-zinc-500">
										{tierDescription(id)}
									</div>
								</div>
							</label>
						)
					})}
				</div>
			</fieldset>

			<button
				type="submit"
				class="w-full rounded-md bg-orange-500 px-4 py-2 font-medium text-zinc-950 hover:bg-orange-400"
			>
				Create event
			</button>
		</form>

		<p class="mt-4 text-xs text-zinc-500">
			Created as {host.email}. Status starts as <code>draft</code>; paid plans go <code>live</code> after payment.
		</p>
	</main>
</Layout>

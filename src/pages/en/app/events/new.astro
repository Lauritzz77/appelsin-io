---
import Layout from '../../../../layouts/Layout.astro'
import Icon from '../../../../components/brand/Icon.astro'
import Button from '../../../../components/brand/Button.astro'
import { TIERS, TIER_IDS, isTier, formatPrice, type Tier } from '../../../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!

const requested = Astro.url.searchParams.get('tier')
const selectedTier: Tier = isTier(requested) ? requested : 'free'
const createError = Astro.url.searchParams.get('error')

const tierLabel = (tier: Tier) => (tier === 'free' ? 'Free' : TIERS[tier].label)
const tierPrice = (tier: Tier) => formatPrice(tier, 'en')
const tierDescription = (tier: Tier) => {
	const t = TIERS[tier]
	const parts = [`Up to ${t.photoCap.toLocaleString('en-IE')} photos`, `${t.retentionDays}-day retention`]
	if (t.watermark) parts.push('appelsin watermark')
	return parts.join(' · ')
}
---

<Layout title="New event — appelsin" locale="en">
	<div class="app screen-root">
		<div class="fu mx-auto max-w-[640px] px-7 pt-[30px] pb-20">
			<a href="/en/app" class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-tx-3">
				<Icon name="arrow-left" size={18} />Back
			</a>
			<h1 class="mt-6 mb-3 text-[clamp(30px,5cqw,40px)] font-extrabold tracking-[-0.02em]">New event</h1>
			<div class="m-0 flex max-w-[520px] flex-col gap-3 text-[17px] leading-[1.6] text-tx-2">
				<p class="m-0">
					Gather all the memories from your occasion in one place. When you create an event you get a unique code and QR
					that your guests can scan to upload photos straight from the party.
				</p>
				<p class="m-0">
					The photos can show live on a big screen, iPad or laptop during the event, so everyone can follow the moments
					as they happen. Afterwards you can download the whole set and keep the memories forever.
				</p>
				<p class="m-0 text-tx-3">Perfect for weddings, birthdays, company parties and other special occasions.</p>
			</div>

			{
				createError === 'free_exists' && (
					<div class="mt-6 rounded-md border border-[rgba(244,63,94,.3)] bg-[rgba(244,63,94,.1)] px-[18px] py-[14px] text-sm text-danger">
						You already have a free event. Delete the existing one first, or pick Basic or Gold for this event.
					</div>
				)
			}

			<form method="post" action="/api/events/new" class="mt-[34px] flex flex-col gap-[26px]">
				<input type="hidden" name="returnToPrefix" value="/en/app/events" />

				<label class="block">
					<span class="field-label">Event name</span>
					<input
						id="name"
						name="name"
						type="text"
						required
						maxlength="80"
						placeholder="Anna & Jonas — wedding"
						class="field-input field-input--big"
					/>
				</label>

				<div>
					<label class="block">
						<span class="field-label">Event date</span>
						<input id="eventDate" name="eventDate" type="date" required class="field-input field-input--big" />
					</label>
					<div class="mt-4 rounded-lg border border-[rgba(255,162,41,.28)] bg-orange-soft px-[22px] py-5">
						<div class="mb-[14px] flex items-center gap-[9px] text-[13.5px] font-bold uppercase tracking-[0.04em] text-accent">
							<Icon name="clock" size={16} />The date drives the timeline
						</div>
						<div class="flex flex-col gap-[11px] text-[15px] leading-[1.5] text-tx-2">
							<div class="flex gap-3">
								<span class="font-extrabold text-accent">·</span>
								<span>Guests can upload from <strong>24 hours before</strong> — so anyone scanning the QR the night before can get going.</span>
							</div>
							<div class="flex gap-3">
								<span class="font-extrabold text-accent">·</span>
								<span>The event is <strong>live for 2 days after</strong> — catching late-night and morning-after photos.</span>
							</div>
							<div class="flex gap-3">
								<span class="font-extrabold text-accent">·</span>
								<span>Then it's marked <strong>ended</strong>, and photos are kept for <strong>7-90 days</strong> depending on plan, then everything is deleted automatically.</span>
							</div>
						</div>
					</div>
				</div>

				<fieldset class="m-0 border-none p-0">
					<legend class="app-sec-label">Choose plan</legend>
					<div class="flex flex-col gap-3">
						{
							TIER_IDS.map((id) => {
								const t = TIERS[id]
								return (
									<label class="radio-card">
										<input type="radio" name="tier" value={id} checked={id === selectedTier} />
										<span class="radio-dot" />
										<span class="flex-1">
											<span class="flex items-center gap-[10px]">
												<span class="text-[18px] font-bold text-tx">{tierLabel(id)}</span>
												{id === 'basic' && <span class="badge badge--soft">Popular</span>}
											</span>
											<span class="mt-1 block text-[14.5px] text-tx-3">{tierDescription(id)}</span>
										</span>
										<span class="rc-price">
											{tierPrice(id)}
											{t.priceCents > 0 && <span class="text-tx-3"> / event</span>}
										</span>
									</label>
								)
							})
						}
					</div>
				</fieldset>

				<div>
					<Button type="submit" full size="lg" iconRight="arrow-right">Create event</Button>
					<p class="mt-[14px] text-center text-[13.5px] leading-[1.5] text-tx-3">
						Created as {host.email}. Status starts as <span class="font-mono">draft</span>; paid plans go
						<span class="font-mono">live</span> after payment.
					</p>
				</div>
			</form>
		</div>
	</div>
</Layout>

<style>
	.radio-card {
		display: flex;
		align-items: center;
		gap: 16px;
		width: 100%;
		text-align: left;
		padding: 18px 20px;
		border-radius: var(--r-lg);
		cursor: pointer;
		background: var(--s1);
		border: 1.5px solid var(--line-2);
		transition: all 0.18s;
		position: relative;
	}
	.radio-card:hover {
		border-color: var(--line);
	}
	.radio-card input {
		position: absolute;
		opacity: 0;
		width: 1px;
		height: 1px;
		pointer-events: none;
	}
	.radio-card:has(input:checked) {
		background: var(--orange-soft);
		border-color: var(--accent);
		box-shadow: 0 0 0 4px var(--orange-soft);
	}
	.radio-dot {
		width: 22px;
		height: 22px;
		border-radius: 999px;
		flex-shrink: 0;
		border: 2px solid var(--tx-3);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: border-color 0.15s;
	}
	.radio-card:has(input:checked) .radio-dot {
		border-color: var(--accent);
	}
	.radio-dot::after {
		content: '';
		width: 11px;
		height: 11px;
		border-radius: 999px;
		background: var(--accent);
		transform: scale(0);
		transition: transform 0.15s;
	}
	.radio-card:has(input:checked) .radio-dot::after {
		transform: scale(1);
	}
	.radio-card:focus-within {
		border-color: var(--accent);
	}
	.rc-price {
		font-size: 17px;
		font-weight: 700;
		color: var(--tx-2);
		white-space: nowrap;
	}
	.radio-card:has(input:checked) .rc-price {
		color: var(--accent);
	}
</style>

---
import Layout from '../../../layouts/Layout.astro'
import Logo from '../../../components/brand/Logo.astro'
import Icon from '../../../components/brand/Icon.astro'
import Button from '../../../components/brand/Button.astro'
import StatusPill from '../../../components/brand/StatusPill.astro'
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq, desc } from 'drizzle-orm'
import * as schema from '../../../db/schema'
import { TIERS, isTier } from '../../../lib/tiers'

export const prerender = false

const host = Astro.locals.host!
const db = drizzle(env.DB, { schema })
const events = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.hostId, host.id))
	.orderBy(desc(schema.events.createdAt))

const tierLabel = (tier: unknown) => TIERS[isTier(tier) ? tier : 'free'].label
---

<Layout title="Dashboard — appelsin" locale="en">
	<div class="app screen-root">
		<div class="app-top"><Logo href="/en" surface="dark" size={40} /></div>
		<div class="app-wrap fu">
			<div
				style="display:flex;align-items:center;justify-content:space-between;margin:12px 0 28px;gap:16px;flex-wrap:wrap"
			>
				<div>
					<h1 style="font-size:clamp(32px,5cqw,44px);font-weight:800;letter-spacing:-.02em;margin:0">Your events</h1>
					<p style="color:var(--tx-3);font-size:16px;margin:8px 0 0">
						Pick an event to see its code, photo wall and pictures.
					</p>
				</div>
				<Button href="/en/app/events/new" size="md" icon="plus">New event</Button>
			</div>

			{
				events.length === 0 ? (
					<p style="color:var(--tx-3)">No events yet. Create your first.</p>
				) : (
					<div style="display:flex;flex-direction:column;gap:14px">
						{events.map((e) => (
							<div
								class="event-row"
								style="display:flex;align-items:center;gap:18px;padding:22px 24px;background:var(--s1);border-radius:var(--r-xl);border:1px solid var(--line-2);transition:all .2s"
							>
								<a href={`/en/app/events/${e.id}`} style="display:flex;align-items:center;gap:18px;flex:1;min-width:0">
									<span style="position:relative;width:58px;height:58px;flex-shrink:0;border-radius:var(--r-md);background:linear-gradient(135deg,var(--s3),var(--s2));border:1px solid var(--line);display:flex;align-items:center;justify-content:center;transform:rotate(-5deg);color:var(--tx-3)">
										<Icon name="image" size={24} />
									</span>
									<span style="flex:1;min-width:0">
										<span style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
											<span class="event-name" style="font-size:20px;font-weight:700;color:var(--tx)">
												{e.name}
											</span>
											<StatusPill status={e.status} locale="en" />
										</span>
										<span style="display:flex;align-items:center;gap:14px;margin-top:7px;font-size:14px;color:var(--tx-3);flex-wrap:wrap">
											<span style="font-family:var(--mono);font-weight:700;letter-spacing:.08em;color:var(--tx-2)">
												{e.shortCode}
											</span>
											<span style="opacity:.5">·</span>
											<span>
												plan <strong style="color:var(--accent)">{tierLabel(e.tier)}</strong>
											</span>
											<span style="opacity:.5">·</span>
											<span>{new Date(e.eventDate).toLocaleDateString('en-IE')}</span>
										</span>
									</span>
								</a>
								<div style="display:flex;align-items:center;gap:4px">
									<button
										type="button"
										class="event-rename"
										style="width:38px;height:38px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;color:var(--tx-3)"
										data-event-id={e.id}
										data-event-name={e.name}
										aria-label={`Rename ${e.name}`}
										title="Rename event"
									>
										<Icon name="pencil" size={18} />
									</button>
									<button
										type="button"
										class="event-delete"
										style="width:38px;height:38px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;color:var(--tx-3)"
										data-event-id={e.id}
										data-event-name={e.name}
										aria-label={`Delete ${e.name}`}
										title="Delete event"
									>
										<Icon name="trash" size={18} />
									</button>
									<Icon name="chevron-right" size={20} class="text-[var(--tx-4)]" />
								</div>
							</div>
						))}
					</div>
				)
			}

			<div
				style="display:flex;align-items:center;gap:18px;margin-top:40px;padding-top:26px;flex-wrap:wrap;border-top:1px solid var(--line-2);font-size:14.5px;color:var(--tx-3)"
			>
				<span>Signed in as <strong style="color:var(--tx-2)">{host.email}</strong></span>
				<span style="margin-left:auto;display:flex;gap:20px">
					<a
						href="/en/app/billing"
						style="cursor:pointer;display:inline-flex;gap:7px;align-items:center;color:var(--tx-2)"
						><Icon name="card" size={16} />Billing</a
					>
					<button
						id="sign-out-btn"
						type="button"
						style="cursor:pointer;display:inline-flex;gap:7px;align-items:center;color:var(--tx-2)"
						><Icon name="signout" size={16} />Sign out</button
					>
				</span>
			</div>
		</div>
	</div>
</Layout>

<style>
	.event-row:hover {
		background: var(--s2) !important;
		border-color: var(--line) !important;
		box-shadow: var(--sh-app);
		transform: translateY(-2px);
	}
	.event-rename:hover {
		background: rgba(255, 255, 255, 0.08);
		color: var(--tx) !important;
	}
	.event-delete:hover {
		background: rgba(244, 63, 94, 0.14);
		color: #ff8499 !important;
	}
</style>

<script>
	document.getElementById('sign-out-btn')?.addEventListener('click', async () => {
		await fetch('/api/auth/sign-out', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: '{}',
		})
		window.location.href = '/en/login'
	})

	document.querySelectorAll<HTMLButtonElement>('.event-rename').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const id = btn.dataset.eventId
			const currentName = btn.dataset.eventName || ''
			if (!id) return

			const nextName = (
				await window.AppDialog.prompt({
					title: 'Rename event',
					confirmText: 'Save name',
					input: {
						label: 'Event name',
						defaultValue: currentName,
						maxLength: 80,
					},
				})
			)?.trim()
			if (!nextName || nextName === currentName) return

			const row = btn.closest<HTMLElement>('.event-row')
			const nameEl = row?.querySelector<HTMLElement>('.event-name')
			btn.disabled = true

			try {
				const res = await fetch(`/api/events/${id}`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name: nextName }),
				})
				const payload = (await res.json().catch(() => null)) as { name?: string } | null
				if (!res.ok) throw new Error(`Rename failed (${res.status})`)
				const savedName = payload?.name || nextName
				if (nameEl) nameEl.textContent = savedName
				btn.dataset.eventName = savedName
				btn.setAttribute('aria-label', `Rename ${savedName}`)
				const deleteBtn = row?.querySelector<HTMLButtonElement>('.event-delete')
				if (deleteBtn) {
					deleteBtn.dataset.eventName = savedName
					deleteBtn.setAttribute('aria-label', `Delete ${savedName}`)
				}
			} catch (e) {
				await window.AppDialog.alert({
					title: 'Could not rename event',
					message: (e as Error).message,
				})
			} finally {
				btn.disabled = false
			}
		})
	})

	document.querySelectorAll<HTMLButtonElement>('.event-delete').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const id = btn.dataset.eventId
			const name = btn.dataset.eventName || 'this event'
			if (!id) return
			const confirmed = await window.AppDialog.confirm({
				title: `Delete "${name}"?`,
				message: 'This deletes the event and all uploaded photos. This cannot be undone.',
				confirmText: 'Delete event',
				danger: true,
			})
			if (!confirmed) return

			const row = btn.closest<HTMLElement>('.event-row')
			btn.disabled = true
			row?.classList.add('opacity-50', 'pointer-events-none')

			try {
				const res = await fetch(`/api/events/${id}`, { method: 'DELETE' })
				if (!res.ok) throw new Error(`Delete failed (${res.status})`)
				row?.remove()
				if (document.querySelectorAll('.event-row').length === 0) window.location.reload()
			} catch (e) {
				btn.disabled = false
				row?.classList.remove('opacity-50', 'pointer-events-none')
				await window.AppDialog.alert({
					title: 'Could not delete event',
					message: (e as Error).message,
				})
			}
		})
	})
</script>

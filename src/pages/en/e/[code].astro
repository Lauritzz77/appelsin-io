---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq } from 'drizzle-orm'
import * as schema from '../../../db/schema'
import Layout from '../../../layouts/Layout.astro'
import GuestUpload from '../../../components/GuestUpload.vue'

export const prerender = false

const code = Astro.params.code?.toUpperCase()
if (!code) return Astro.redirect('/en')

const db = drizzle(env.DB, { schema })
const [event] = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.shortCode, code))
	.limit(1)

if (!event) return new Response('Event not found', { status: 404 })
if (event.status !== 'live') {
	return new Response('Event is not live yet', { status: 403 })
}
---

<Layout title={`Share photos — ${event.name}`} locale="en">
	<div style="min-height:100vh;background:radial-gradient(130% 80% at 50% -10%, #0c2a6e, #061541 65%)">
		<div style="max-width:480px;margin:0 auto;padding:0 24px 48px">
			<div style="padding:56px 0 24px;text-align:center">
				<img src="/logo.svg" alt="appelsin.io" style="height:48px;width:auto;margin:0 auto 14px;display:block" />
				<div style="font-family:var(--hand);font-size:24px;color:var(--orange);font-weight:600;line-height:1">you’re part of</div>
				<h1 style="font-size:26px;font-weight:800;letter-spacing:-.02em;margin:6px 0 0;color:var(--tx)">{event.name}</h1>
				<p style="font-size:14.5px;color:var(--tx-3);margin:8px 0 0">
					Take a photo{event.tier === 'gold' ? ' or a short video clip' : ''} — it shows on the screen instantly.
				</p>
			</div>
			<GuestUpload
				client:only="vue"
				code={code}
				cfImagesHash={env.CF_IMAGES_HASH}
				streamDomain={env.CF_STREAM_CUSTOMER_DOMAIN}
				locale="en"
				allowVideo={event.tier === 'gold'}
			/>
		</div>
	</div>
</Layout>

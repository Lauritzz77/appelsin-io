---
import { env } from 'cloudflare:workers'
import { drizzle } from 'drizzle-orm/d1'
import { eq } from 'drizzle-orm'
import * as schema from '../../../db/schema'
import Layout from '../../../layouts/Layout.astro'
import GuestUpload from '../../../components/GuestUpload.vue'

export const prerender = false

const code = Astro.params.code?.toUpperCase()
if (!code) return Astro.redirect('/en')

const db = drizzle(env.DB, { schema })
const [event] = await db
	.select()
	.from(schema.events)
	.where(eq(schema.events.shortCode, code))
	.limit(1)

if (!event) return new Response('Event not found', { status: 404 })
if (event.status !== 'live') {
	return new Response('Event is not live yet', { status: 403 })
}
---

<Layout title={`Share photos — ${event.name}`} locale="en">
	<div class="min-h-screen bg-[radial-gradient(130%_80%_at_50%_-10%,#0c2a6e,#061541_65%)]">
		<div class="mx-auto max-w-[480px] px-6 pb-12">
			<div class="pt-14 pb-6 text-center">
				<img src="/logo.svg" alt="appelsin.io" class="mx-auto mb-[14px] block h-20 w-20" />
				<div class="font-hand text-[24px] font-semibold leading-none text-accent">you’re part of</div>
				<h1 class="mt-1.5 text-[26px] font-extrabold tracking-[-0.02em] text-tx">{event.name}</h1>
				<p class="mt-2 text-[14.5px] text-tx-3">
					Take a photo{event.tier === 'gold' ? ' or a short video clip' : ''} — it shows on the screen instantly.
				</p>
			</div>
			<GuestUpload
				client:only="vue"
				code={code}
				cfImagesHash={env.CF_IMAGES_HASH}
				streamDomain={env.CF_STREAM_CUSTOMER_DOMAIN}
				locale="en"
				allowVideo={event.tier === 'gold'}
			/>
		</div>
	</div>
</Layout>

---
import Layout from '../../../layouts/Layout.astro'
---

<Layout title="Join event — appelsin" locale="en">
	<main class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-6 py-12">
		<a href="/en" aria-label="appelsin home" class="mb-8 inline-block">
			<img src="/logo.svg" alt="appelsin" width="72" height="72" class="-ml-1" />
		</a>

		<h1 class="text-2xl font-semibold tracking-tight">Enter event code</h1>
		<p class="mt-2 text-sm leading-6 text-zinc-400">
			Type the code from the event screen or invitation to share photos.
		</p>

		<form id="event-code-form" class="mt-8 space-y-4">
			<label class="block">
				<span class="text-sm font-medium text-zinc-200">Event code</span>
				<input
					id="event-code-input"
					name="code"
					type="text"
					inputmode="text"
					autocomplete="off"
					autocapitalize="characters"
					spellcheck="false"
					required
					class="mt-2 block w-full rounded-md border border-zinc-700 bg-zinc-950 px-4 py-3 font-mono text-lg uppercase tracking-[0.16em] text-white outline-none transition placeholder:normal-case placeholder:tracking-normal placeholder:text-zinc-600 focus:border-orange-500"
					placeholder="EC4KJL"
				/>
			</label>

			<p id="event-code-error" class="min-h-5 text-sm text-red-400" aria-live="polite"></p>

			<button
				type="submit"
				class="w-full rounded-md bg-orange-500 px-4 py-3 font-medium text-zinc-950 transition hover:bg-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 focus:ring-offset-[#071952]"
			>
				Join event
			</button>
		</form>
	</main>
</Layout>

<script>
	const form = document.getElementById('event-code-form') as HTMLFormElement | null
	const input = document.getElementById('event-code-input') as HTMLInputElement | null
	const error = document.getElementById('event-code-error')

	input?.addEventListener('input', () => {
		input.value = input.value.toUpperCase()
		if (error) error.textContent = ''
	})

	form?.addEventListener('submit', (event) => {
		event.preventDefault()
		const code = input?.value.trim().replace(/\s+/g, '').toUpperCase()

		if (!code) {
			if (error) error.textContent = 'Enter an event code.'
			input?.focus()
			return
		}

		window.location.href = `/en/e/${encodeURIComponent(code)}`
	})
</script>

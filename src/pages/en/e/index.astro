---
import Layout from '../../../layouts/Layout.astro'
import Logo from '../../../components/brand/Logo.astro'
---

<Layout title="Join event — appelsin" locale="en">
	<div
		class="app screen-root"
		style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:40px 24px"
	>
		<div style="width:100%;max-width:440px" class="fu">
			<div style="display:flex;justify-content:center;margin-bottom:24px"><Logo href="/en" surface="dark" size={56} /></div>
			<div class="card card--dark" style="padding:32px 28px">
				<h1 style="font-size:26px;font-weight:800;letter-spacing:-.02em;text-align:center;margin:0">Enter event code</h1>
				<p style="text-align:center;color:var(--tx-3);margin:10px 0 24px;font-size:15px;line-height:1.5">
					Type the code from the event screen or invitation to share photos.
				</p>

				<form id="event-code-form">
					<label style="display:block">
						<span class="field-label">Event code</span>
						<input
							id="event-code-input"
							name="code"
							type="text"
							inputmode="text"
							autocomplete="off"
							autocapitalize="characters"
							spellcheck="false"
							required
							class="field-input field-input--mono field-input--big"
							style="text-transform:uppercase;text-align:center"
							placeholder="EC4KJL"
						/>
					</label>
					<p id="event-code-error" style="min-height:1.25rem;margin-top:10px;font-size:14px;color:#ff8499" aria-live="polite"></p>
					<div style="margin-top:6px">
						<button type="submit" class="btn btn--primary btn--full btn--lg">Join event</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</Layout>

<script>
	const form = document.getElementById('event-code-form') as HTMLFormElement | null
	const input = document.getElementById('event-code-input') as HTMLInputElement | null
	const error = document.getElementById('event-code-error')

	input?.addEventListener('input', () => {
		input.value = input.value.toUpperCase()
		if (error) error.textContent = ''
	})

	form?.addEventListener('submit', (event) => {
		event.preventDefault()
		const code = input?.value.trim().replace(/\s+/g, '').toUpperCase()

		if (!code) {
			if (error) error.textContent = 'Enter an event code.'
			input?.focus()
			return
		}

		window.location.href = `/en/e/${encodeURIComponent(code)}`
	})
</script>

---
import Layout from '../../../layouts/Layout.astro'
import Logo from '../../../components/brand/Logo.astro'
---

<Layout title="Join event — appelsin" locale="en">
	<div class="app screen-root flex min-h-screen items-center justify-center px-6 py-10">
		<div class="fu w-full max-w-[440px]">
			<div class="mb-6 flex justify-center"><Logo href="/en" surface="dark" class="w-20 h-20 block" /></div>
			<div class="rounded-xl border border-line-2 bg-s1 px-7 py-8 shadow-app">
				<h1 class="m-0 text-center text-[26px] font-extrabold tracking-[-0.02em]">Enter event code</h1>
				<p class="mt-2.5 mb-6 text-center text-[15px] leading-[1.5] text-tx-3">
					Type the code from the event screen or invitation to share photos.
				</p>

				<form id="event-code-form">
					<label class="block">
						<span class="field-label">Event code</span>
						<input
							id="event-code-input"
							name="code"
							type="text"
							inputmode="text"
							autocomplete="off"
							autocapitalize="characters"
							spellcheck="false"
							required
							class="field-input field-input--mono field-input--big text-center uppercase"
							placeholder="EC4KJL"
						/>
					</label>
					<p id="event-code-error" class="mt-2.5 min-h-[1.25rem] text-sm text-danger" aria-live="polite"></p>
					<div class="mt-1.5">
						<button type="submit" class="btn btn--primary btn--full btn--lg">Join event</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</Layout>

<script>
	const form = document.getElementById('event-code-form') as HTMLFormElement | null
	const input = document.getElementById('event-code-input') as HTMLInputElement | null
	const error = document.getElementById('event-code-error')

	input?.addEventListener('input', () => {
		input.value = input.value.toUpperCase()
		if (error) error.textContent = ''
	})

	form?.addEventListener('submit', (event) => {
		event.preventDefault()
		const code = input?.value.trim().replace(/\s+/g, '').toUpperCase()

		if (!code) {
			if (error) error.textContent = 'Enter an event code.'
			input?.focus()
			return
		}

		window.location.href = `/en/e/${encodeURIComponent(code)}`
	})
</script>

---
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import MarketingNav from '../../components/marketing/MarketingNav.astro'
import MarketingFooter from '../../components/marketing/MarketingFooter.astro'
import HeroPolaroids from '../../components/marketing/HeroPolaroids.astro'
import PlanCard from '../../components/marketing/PlanCard.astro'
import Button from '../../components/brand/Button.astro'
import Icon from '../../components/brand/Icon.astro'
import Accordion from '../../components/brand/Accordion.astro'
import { formatPrice, type Tier as TierId } from '../../lib/tiers'

const isSignedIn = !!Astro.locals.host

type Card = {
	id: TierId
	priceNote: string
	tagline: string
	features: string[]
	cta: string
	featured?: boolean
}

const cards: Card[] = [
	{
		id: 'free',
		priceNote: 'One active event at a time',
		tagline: 'Try Appelsin.io for a smaller event — no card required.',
		features: ['20 photos per event', '7-day retention', 'Download all photos after the event'],
		cta: 'Start free',
	},
	{
		id: 'basic',
		priceNote: 'per event',
		tagline: 'Perfect for weddings, birthdays and smaller parties.',
		features: [
			'500 photos per event',
			'15-day retention',
			'Customise event title and text colour',
			'Download all photos after the event',
		],
		cta: 'Choose Basic',
		featured: true,
	},
	{
		id: 'gold',
		priceNote: 'per event',
		tagline: 'For big parties, long nights and lots of guests.',
		features: [
			'2,000 photos per event',
			'1-month retention',
			'Customise event title and text colour',
			'15-second video clips',
			'Download all photos after the event',
		],
		cta: 'Choose Gold',
	},
]

function ctaHref(tier: TierId): string {
	const dest = `/en/app/events/new?tier=${tier}`
	if (isSignedIn) return dest
	return `/en/login?next=${encodeURIComponent(dest)}`
}

const steps = [
	{ ic: 'qr', n: '01', t: 'Scan the code', d: 'Guests scan the QR code with their phone camera. No app, no login.' },
	{ ic: 'camera', n: '02', t: 'Upload a photo', d: 'They pick a photo or record a clip — straight from the phone.' },
	{ ic: 'monitor', n: '03', t: 'Live on screen', d: 'The photo appears on the wall instantly, so everyone can follow along.' },
]

const faq = [
	{
		q: 'Do my guests need to download an app?',
		a: "No. Guests scan the QR code with their phone's camera and upload directly in the browser. No app, no account.",
	},
	{
		q: 'What happens if we hit the photo limit?',
		a: 'New uploads are blocked once the cap is reached. You can delete rejected photos to free up slots, or upgrade the event to a bigger plan. Free is meant for testing — pick Basic or Gold for the real party.',
	},
	{
		q: 'What happens to the photos after the event?',
		a: 'The event automatically marks as ended 2 days after the event date. You and your guests (with email) get a link to the photo collection by email. Photos are then kept for 7-30 days depending on plan, after which everything is deleted automatically.',
	},
	{
		q: 'Can I show the photo wall on an iPad or laptop?',
		a: 'Yes. The photo wall is just a URL — open it in any browser on a big screen, iPad, laptop, or projector. Photos update live as guests upload.',
	},
	{
		q: "Can I delete a photo that shouldn't be shown?",
		a: "Yes. You can delete individual photos from the event dashboard — they disappear from the photo wall instantly and aren't included in the final photo collection.",
	},
	{
		q: 'When can guests start uploading?',
		a: 'The upload window opens 24 hours before the event date, so anyone scanning the QR the night before can get going. The event stays live until 2 days after the event date to catch late-night and morning-after photos.',
	},
	{
		q: 'Where are the photos stored?',
		a: "All photos are hosted on Cloudflare's EU infrastructure. We don't sell your data and won't use it for anything other than serving and delivering the photos during the agreed retention period.",
	},
]
---

<Layout
	title="appelsin — live event photos"
	description="Guests scan a QR code, upload photos from their phone, and the photos appear live on the big screen."
	locale="en"
	surface="cream"
>
	<div class="mkt screen-root">
		{/* NAVY HERO BAND (nav + hero) */}
		<div class="hero-band band-navy">
			<div class="mkt-wrap">
				<MarketingNav locale="en" isSignedIn={isSignedIn} onDark />

				<section class="hero fu pt-20">
					<div>
						<div class="mb-[18px] text-sm font-bold uppercase tracking-[0.14em] text-accent">
							For weddings · birthdays · parties
						</div>
						<h1 class="hero-h1 uppercase">
							Party photos,<br />live on the big screen.
						</h1>
						<p class="mt-[22px] mb-8 max-w-[480px] text-[19.5px] leading-[1.6] text-tx-2">
							Guests scan a QR code and upload photos straight from their phone — no app. Everything shows live on the
							big screen, and you download the whole party afterwards.
						</p>
						<div class="hero-cta flex flex-wrap gap-[14px]">
							<Button href="#pricing" size="lg">See plans</Button>
						</div>
						<div class="mt-[30px] flex flex-wrap items-center gap-[10px] text-[14.5px] font-semibold text-tx-3">
							{
								['Free to try', 'No app', 'Ready in 2 min'].map((t, i) => (
									<>
										{i > 0 && <span class="opacity-40">·</span>}
										<span>{t}</span>
									</>
								))
							}
						</div>
					</div>
					<HeroPolaroids locale="en" />
				</section>
			</div>
		</div>

		{/* CREAM: how it works + pricing */}
		<div class="mkt-wrap">
			<section class="pt-[56px] pb-16">
				<div class="steps">
					{
						steps.map((s) => (
							<div class="rounded-xl border border-cream-line bg-white p-7 shadow-cream-sm">
								<div class="mb-4 flex items-center gap-[14px]">
									<span class="flex h-[52px] w-[52px] items-center justify-center rounded-md bg-peach text-orange-deep">
										<Icon name={s.ic} size={26} stroke={2} />
									</span>
									<span class="font-mono text-[15px] font-bold text-warm-muted">{s.n}</span>
								</div>
								<div class="mb-2 text-[21px] font-bold text-ink">{s.t}</div>
								<div class="text-base leading-[1.6] text-warm-body">{s.d}</div>
							</div>
						))
					}
				</div>
			</section>

			<section id="pricing" class="scroll-mt-6 pt-[28px] pb-16">
				<div class="mb-10 text-center">
					<h2 class="m-0 text-[clamp(32px,4cqw,46px)] font-extrabold tracking-[-0.02em] text-ink">One price per event</h2>
					<p class="mt-3 text-[18px] text-warm-body">Pick a plan for the day. No subscriptions, no surprises.</p>
				</div>
				<div class="pricing">
					{
						cards.map((c) => (
							<PlanCard
								name={c.id === 'free' ? 'Free' : c.id === 'basic' ? 'Basic' : 'Gold'}
								price={formatPrice(c.id, 'en')}
								priceNote={c.priceNote}
								tagline={c.tagline}
								features={c.features}
								cta={c.cta}
								href={ctaHref(c.id)}
								featured={c.featured}
								popularLabel="Most popular"
							/>
						))
					}
				</div>
				<p class="mt-7 text-center text-[15px] text-warm-muted">
					All plans include the QR pack, live photo wall, moderation queue and EU hosting.
				</p>
			</section>
		</div>

		{/* NAVY FAQ BAND */}
		<div class="faq-band band-navy">
			<div class="mx-auto max-w-[860px] px-5 lg:px-10">
				<section class="pt-[60px] pb-16">
					<div class="mb-9 text-center">
						<div class="font-hand 2xl font-semibold text-accent">good to know</div>
						<h2 class="mt-0.5 text-[clamp(30px,4cqw,42px)] font-extrabold tracking-[-0.02em] text-white">
							Questions before the party?
						</h2>
					</div>
					<Accordion items={faq} tone="cream" />
				</section>
			</div>
		</div>

		{/* NAVY footer */}
		<div class="band-navy">
			<div class="mkt-wrap">
				<MarketingFooter locale="en" isSignedIn={isSignedIn} onDark />
			</div>
		</div>
	</div>
</Layout>

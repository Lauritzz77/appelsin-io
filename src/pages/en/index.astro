---
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import MarketingNav from '../../components/marketing/MarketingNav.astro'
import MarketingFooter from '../../components/marketing/MarketingFooter.astro'
import HeroCollage from '../../components/marketing/HeroCollage.astro'
import PlanCard from '../../components/marketing/PlanCard.astro'
import Button from '../../components/brand/Button.astro'
import Icon from '../../components/brand/Icon.astro'
import Accordion from '../../components/brand/Accordion.astro'
import { formatPrice, type Tier as TierId } from '../../lib/tiers'

const isSignedIn = !!Astro.locals.host

type Card = {
	id: TierId
	priceNote: string
	tagline: string
	features: string[]
	cta: string
	featured?: boolean
}

const cards: Card[] = [
	{
		id: 'free',
		priceNote: 'Only 1 active event',
		tagline: 'Try it at a real event — no card required.',
		features: ['20 photos per event', '7-day retention', 'Download photos after the event'],
		cta: 'Start free',
	},
	{
		id: 'basic',
		priceNote: 'per event',
		tagline: 'Clean, branded, ready for a wedding.',
		features: [
			'500 photos per event',
			'15-day retention',
			'Custom event title and accent colour',
			'Download photos after the event',
		],
		cta: 'Choose Basic',
		featured: true,
	},
	{
		id: 'gold',
		priceNote: 'per event',
		tagline: 'For big nights and long parties.',
		features: [
			'2,000 photos per event',
			'1-month retention',
			'Custom event title and accent colour',
			'15-second video clips',
			'Download photos after the event',
		],
		cta: 'Choose Gold',
	},
]

function ctaHref(tier: TierId): string {
	const dest = `/en/app/events/new?tier=${tier}`
	if (isSignedIn) return dest
	return `/en/login?next=${encodeURIComponent(dest)}`
}
const startHref = ctaHref('basic')

const steps = [
	{ ic: 'qr', n: '01', t: 'Scan the code', d: 'Guests scan the QR code with their phone camera. No app, no login.' },
	{ ic: 'camera', n: '02', t: 'Upload a photo', d: 'They pick a photo or record a clip — straight from the phone.' },
	{ ic: 'monitor', n: '03', t: 'Live on screen', d: 'The photo appears on the wall instantly, so everyone can follow along.' },
]

const faq = [
	{
		q: 'Do my guests need to download an app?',
		a: "No. Guests scan the QR code with their phone's camera and upload directly in the browser. No app, no account.",
	},
	{
		q: 'What happens if we hit the photo limit?',
		a: 'New uploads are blocked once the cap is reached. You can delete rejected photos to free up slots, or upgrade the event to a bigger plan. Free is meant for testing — pick Basic or Gold for the real party.',
	},
	{
		q: 'What happens to the photos after the event?',
		a: 'The event automatically marks as ended 2 days after the event date. You and your guests (with email) get a download link by email. Photos are then kept for 7-30 days depending on plan, after which everything is deleted automatically.',
	},
	{
		q: 'Can I show the photo wall on an iPad or laptop?',
		a: 'Yes. The photo wall is just a URL — open it in any browser on a big screen, iPad, laptop, or projector. Photos update live as guests upload.',
	},
	{
		q: "Can I delete a photo that shouldn't be shown?",
		a: "Yes. You can delete individual photos from the event dashboard — they disappear from the photo wall instantly and aren't included in the final download.",
	},
	{
		q: 'When can guests start uploading?',
		a: 'The upload window opens 24 hours before the event date, so anyone scanning the QR the night before can get going. The event stays live until 2 days after the event date to catch late-night and morning-after photos.',
	},
	{
		q: 'Where are the photos stored?',
		a: "All photos are hosted on Cloudflare's EU infrastructure. We don't sell your data and won't use it for anything other than serving and delivering the photos during the agreed retention period.",
	},
]
---

<Layout
	title="appelsin — live event photos"
	description="Guests scan a QR code, upload photos from their phone, and the photos appear live on the big screen."
	locale="en"
	surface="cream"
>
	<div class="mkt screen-root">
		<div class="mkt-wrap">
			<MarketingNav locale="en" isSignedIn={isSignedIn} />

			{/* HERO */}
			<section class="hero fu">
				<div>
					<div
						class="hero-kicker"
						style="font-family:var(--hand);font-size:30px;line-height:1.15;font-weight:600;color:var(--orange-700);margin-bottom:8px"
					>
						share the moments as they happen
					</div>
					<h1 class="hero-h1">
						Party photos,<br />live on the <span style="color:var(--orange)">big screen</span>.
					</h1>
					<p style="font-size:19.5px;line-height:1.6;color:var(--warm-body);max-width:480px;margin:22px 0 32px">
						Guests scan a QR code, upload from their phone, and photos appear on the screen instantly. Pay once per
						event — no subscriptions.
					</p>
					<div style="display:flex;gap:14px;flex-wrap:wrap">
						<Button href={startHref} size="lg" iconRight="arrow-right">Create your event</Button>
						<Button href="#pricing" variant="secondary" size="lg">See plans</Button>
					</div>
					<div
						style="display:flex;gap:22px;margin-top:30px;flex-wrap:wrap;color:var(--warm-muted);font-size:14.5px;font-weight:600"
					>
						{
							['No app', 'Ready in 2 min', 'EU hosting'].map((t) => (
								<span style="display:flex;align-items:center;gap:7px">
									<Icon name="check" size={15} stroke={3} class="text-[var(--orange-700)]" />
									{t}
								</span>
							))
						}
					</div>
				</div>
				<HeroCollage locale="en" />
			</section>

			{/* HOW IT WORKS */}
			<section style="padding:calc(20px*var(--d)) 0 calc(64px*var(--d))">
				<div class="steps">
					{
						steps.map((s) => (
							<div style="background:#fff;border-radius:var(--r-xl);padding:28px;border:1px solid var(--cream-line);box-shadow:var(--sh-cream-sm)">
								<div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
									<span style="width:52px;height:52px;border-radius:var(--r-md);background:var(--peach);color:var(--orange-700);display:flex;align-items:center;justify-content:center">
										<Icon name={s.ic} size={26} stroke={2} />
									</span>
									<span style="font-family:var(--mono);font-size:15px;font-weight:700;color:var(--warm-muted)">{s.n}</span>
								</div>
								<div style="font-size:21px;font-weight:700;color:var(--ink);margin-bottom:8px">{s.t}</div>
								<div style="font-size:16px;line-height:1.6;color:var(--warm-body)">{s.d}</div>
							</div>
						))
					}
				</div>
			</section>

			{/* PRICING */}
			<section id="pricing" style="padding:calc(28px*var(--d)) 0;scroll-margin-top:24px">
				<div style="text-align:center;margin-bottom:40px">
					<h2 style="font-size:clamp(32px,4cqw,46px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:0">
						One price per event
					</h2>
					<p style="font-size:18px;color:var(--warm-body);margin-top:12px">
						Pick a plan for the day. No subscriptions, no surprises.
					</p>
				</div>
				<div class="pricing">
					{
						cards.map((c) => (
							<PlanCard
								name={c.id === 'free' ? 'Free' : c.id === 'basic' ? 'Basic' : 'Gold'}
								price={formatPrice(c.id, 'en')}
								priceNote={c.priceNote}
								tagline={c.tagline}
								features={c.features}
								cta={c.cta}
								href={ctaHref(c.id)}
								featured={c.featured}
								popularLabel="Most popular"
							/>
						))
					}
				</div>
				<p style="text-align:center;margin-top:28px;font-size:15px;color:var(--warm-muted)">
					All plans include the QR pack, live photo wall, moderation queue and EU hosting.
				</p>
			</section>

			{/* FAQ */}
			<section style="padding:calc(56px*var(--d)) 0 calc(40px*var(--d));max-width:820px;margin:0 auto">
				<div style="text-align:center;margin-bottom:36px">
					<div style="font-family:var(--hand);font-size:27px;color:var(--orange-700);font-weight:600">good to know</div>
					<h2 style="font-size:clamp(30px,4cqw,42px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:2px 0 0">
						Questions before the party?
					</h2>
				</div>
				<Accordion items={faq} tone="cream" />
			</section>

			<MarketingFooter locale="en" isSignedIn={isSignedIn} />
		</div>
	</div>
</Layout>

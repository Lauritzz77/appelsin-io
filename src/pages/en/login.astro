---
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import Logo from '../../components/brand/Logo.astro'
import Icon from '../../components/brand/Icon.astro'
import Button from '../../components/brand/Button.astro'

const requested = Astro.url.searchParams.get('next')
const next = requested && requested.startsWith('/') ? requested : '/en/app/events/new'
---

<Layout title="Sign in — appelsin" locale="en" surface="cream">
	<div class="mkt screen-root flex flex-col">
		<div class="mx-auto w-full max-w-[1180px] px-10 pt-[26px]">
			<a href="/en" class="inline-flex items-center gap-2 text-[15.5px] font-semibold text-ink-2">
				<Icon name="arrow-left" size={18} />Home
			</a>
		</div>
		<div class="flex flex-1 items-center justify-center px-6 pt-12 pb-[100px]">
			<div class="fu w-full max-w-[440px]">
				<div class="mb-[30px] flex justify-center">
					<Logo surface="cream" class="w-20 h-20 block" />
				</div>

				<div
					id="login-form-card"
					class="rounded-2xl border border-cream-line bg-white p-[38px_34px] shadow-cream-lg"
				>
					<h1 class="m-0 text-center text-[30px] font-extrabold tracking-[-0.02em] text-ink">Sign in</h1>
					<p class="mt-3 mb-7 text-center text-[16.5px] leading-[1.55] text-warm-body">
						Enter your email — we’ll send you a secure sign-in link.
					</p>

					<form id="magic-link-form" data-next={next}>
						<div class="field-input field-input--big flex items-center gap-[10px]">
							<Icon name="mail" size={18} class="text-warm-muted" />
							<input
								type="email"
								name="email"
								required
								autocomplete="email"
								placeholder="you@example.com"
								class="flex-1 border-none bg-transparent text-[18px] text-ink outline-none"
							/>
						</div>
						<div class="mt-4">
							<Button type="submit" full size="lg" iconRight="arrow-right">Send sign-in link</Button>
						</div>
					</form>

					<div class="mt-[22px] flex items-center justify-center gap-2 text-sm text-warm-muted">
						<Icon name="lock" size={15} />No password. The link is valid for 15 minutes.
					</div>
					<p id="status" class="mt-[14px] min-h-[1.25rem] text-center text-sm text-warm-body"></p>
				</div>

				<div
					id="login-success-card"
					class="hidden rounded-2xl border border-cream-line bg-white p-[44px_34px] text-center shadow-cream-lg [animation:popIn_.3s_both]"
				>
					<div
						class="mx-auto mb-5 flex h-[72px] w-[72px] items-center justify-center rounded-full bg-peach text-orange-deep"
					>
						<Icon name="mail" size={34} stroke={1.8} />
					</div>
					<h1 class="m-0 text-[27px] font-extrabold text-ink">Check your inbox</h1>
					<p class="mt-3 mb-[26px] text-[16.5px] leading-[1.6] text-warm-body">
						We’ve sent a sign-in link to<br /><strong id="login-email" class="text-ink">you@example.com</strong>
					</p>
					<a id="login-retry" href="#" class="cursor-pointer text-[14.5px] font-semibold text-orange-deep">Use a different email</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	const form = document.getElementById('magic-link-form') as HTMLFormElement
	const status = document.getElementById('status') as HTMLParagraphElement
	const button = form.querySelector('button') as HTMLButtonElement
	const formCard = document.getElementById('login-form-card') as HTMLElement
	const successCard = document.getElementById('login-success-card') as HTMLElement
	const emailOut = document.getElementById('login-email') as HTMLElement
	const retry = document.getElementById('login-retry') as HTMLAnchorElement

	retry.addEventListener('click', (e) => {
		e.preventDefault()
		successCard.style.display = 'none'
		formCard.style.display = ''
		button.disabled = false
		status.textContent = ''
	})

	form.addEventListener('submit', async (e) => {
		e.preventDefault()
		const email = (form.elements.namedItem('email') as HTMLInputElement).value
		const callbackURL = form.dataset.next || '/en/app/events/new'
		const locale = document.documentElement.lang === 'da' ? 'da' : 'en'
		button.disabled = true
		status.textContent = 'Sending...'
		try {
			const res = await fetch('/api/auth/sign-in/magic-link', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email, callbackURL, metadata: { locale } }),
			})
			if (res.ok) {
				status.textContent = ''
				emailOut.textContent = email || 'you@example.com'
				formCard.style.display = 'none'
				successCard.style.display = ''
			} else {
				const txt = await res.text()
				status.textContent = `Error: ${txt}`
				button.disabled = false
			}
		} catch (err) {
			status.textContent = `Network error: ${(err as Error).message}`
			button.disabled = false
		}
	})
</script>

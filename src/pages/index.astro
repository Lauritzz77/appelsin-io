---
import Layout from '../layouts/Layout.astro';
import type { Tier as TierId } from '../lib/tiers';

type Card = {
	id: TierId;
	name: string;
	price: string;
	priceNote: string;
	tagline: string;
	features: string[];
	cta: string;
	featured?: boolean;
};

const tiers: Card[] = [
	{
		id: 'free',
		name: 'Free',
		price: '€0',
		priceNote: 'with appelsin branding',
		tagline: 'Try it on a real event, no card required.',
		features: [
			'100 photos per event',
			'7-day retention',
			'appelsin watermark on shared photos',
			'“Powered by appelsin” on display',
			'1 active event at a time',
		],
		cta: 'Start free',
	},
	{
		id: 'basic',
		name: 'Basic',
		price: '€49',
		priceNote: 'per event',
		tagline: 'Clean, branded, ready for a wedding.',
		features: [
			'500 photos per event',
			'30-day retention',
			'No watermark',
			'Custom event title + accent colour',
			'Post-event zip download',
		],
		cta: 'Choose Basic',
		featured: true,
	},
	{
		id: 'gold',
		name: 'Gold',
		price: '€99',
		priceNote: 'per event',
		tagline: 'For big nights and long parties.',
		features: [
			'2 000 photos per event',
			'90-day retention',
			'Full branding + slideshow themes',
			'15-second video clips',
			'Priority support',
		],
		cta: 'Choose Gold',
	},
];

function ctaHref(tier: TierId): string {
	const dest = `/app/events/new?tier=${tier}`;
	return `/login?next=${encodeURIComponent(dest)}`;
}
---

<Layout>
	<div class="splash" aria-hidden="true">
		<img src="/logo.svg" alt="" width="320" height="320" />
	</div>

	<div class="page flex min-h-screen flex-col">
		<header class="flex items-start justify-between px-8 pt-6 sm:px-12 sm:pt-8">
			<a href="/" aria-label="appelsin.io home" class="block">
				<img src="/logo.svg" alt="appelsin.io" width="110" height="110" />
			</a>
			<nav class="flex items-center gap-3 pt-4 text-sm sm:text-base">
				<a href="/login" class="text-zinc-100 hover:text-orange-400">Login</a>
				<span class="text-zinc-400">|</span>
				<a href="/terms" class="text-zinc-100 hover:text-orange-400">Terms</a>
				<span class="text-zinc-400">|</span>
				<a href="/privacy" class="text-zinc-100 hover:text-orange-400">Privacy</a>
			</nav>
		</header>

		<main class="flex flex-1 flex-col items-center justify-center px-6 pb-24 pt-12 sm:px-12">
			<div class="mb-12 max-w-2xl text-center">
				<h1 class="text-3xl font-semibold text-white sm:text-4xl">
					Live event photos, on the big screen.
				</h1>
				<p class="mt-4 text-base text-zinc-300 sm:text-lg">
					Guests scan a QR code, upload from their phone, and the photos
					appear live on screen. Pick a plan per event — no subscriptions.
				</p>
			</div>

			<div class="grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-3">
				{tiers.map((tier) => (
					<div
						class:list={[
							'flex flex-col rounded-md p-6 transition',
							tier.featured
								? 'bg-orange-500/20 ring-1 ring-orange-400/60'
								: 'bg-white/10 hover:bg-white/15',
						]}
					>
						<div class="flex items-baseline justify-between">
							<h2 class="text-xl font-semibold text-white">{tier.name}</h2>
							{tier.featured && (
								<span class="rounded-full bg-orange-400/90 px-2 py-0.5 text-xs font-medium text-zinc-900">
									Most popular
								</span>
							)}
						</div>

						<div class="mt-4 flex items-baseline gap-2">
							<span class="text-4xl font-semibold text-white">{tier.price}</span>
							<span class="text-sm text-zinc-300">{tier.priceNote}</span>
						</div>

						<p class="mt-2 text-sm text-zinc-300">{tier.tagline}</p>

						<ul class="mt-6 space-y-2 text-sm text-zinc-100">
							{tier.features.map((feature) => (
								<li class="flex gap-2">
									<span class="text-orange-400" aria-hidden="true">✓</span>
									<span>{feature}</span>
								</li>
							))}
						</ul>

						<a
							href={ctaHref(tier.id)}
							class:list={[
								'mt-8 inline-flex justify-center rounded-md px-4 py-2 text-sm font-medium transition',
								tier.featured
									? 'bg-orange-400 text-zinc-900 hover:bg-orange-300'
									: 'bg-white/10 text-white hover:bg-white/20',
							]}
						>
							{tier.cta} →
						</a>
					</div>
				))}
			</div>

			<p class="mt-10 text-sm text-zinc-400">
				All plans include the QR-code pack, live photo wall, moderation queue
				and EU hosting.
			</p>

			<section class="mt-16 w-full max-w-5xl rounded-md border border-white/15 bg-white/5 p-8 sm:p-10">
				<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
					<div class="max-w-xl">
						<p class="text-xs font-medium uppercase tracking-wider text-orange-400">
							For businesses
						</p>
						<h2 class="mt-2 text-2xl font-semibold text-white">
							Running multiple events?
						</h2>
						<p class="mt-3 text-sm text-zinc-300 sm:text-base">
							Venues, agencies and brand teams: company branding instead of
							ours, sponsor watermarks on every shared photo, team seats, DPA
							and annual pricing.
						</p>
					</div>
					<a
						href="mailto:hello@appelsin.io?subject=Business%20plan"
						class="inline-flex shrink-0 items-center justify-center rounded-md bg-white/10 px-5 py-3 text-sm font-medium text-white transition hover:bg-white/20"
					>
						Talk to us →
					</a>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.splash {
		position: fixed;
		inset: 0;
		display: grid;
		place-items: center;
		background: #071952;
		z-index: 50;
		animation: splash-out 0.5s ease-in 0.8s forwards;
	}

	.page {
		opacity: 0;
		animation: page-in 0.5s ease-out 1s forwards;
	}

	@keyframes splash-out {
		to {
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
	}

	@keyframes page-in {
		to {
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.splash {
			animation: none;
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
		.page {
			animation: none;
			opacity: 1;
		}
	}
</style>

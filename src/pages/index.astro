---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import type { Tier as TierId } from '../lib/tiers'

const isSignedIn = !!Astro.locals.host

type Card = {
	id: TierId
	name: string
	price: string
	priceNote: string
	tagline: string
	features: string[]
	cta: string
	featured?: boolean
}

const tiers: Card[] = [
	{
		id: 'free',
		name: 'Free',
		price: '0 kr.',
		priceNote: 'Kun 1 aktivt event',
		tagline: 'Prøv det til et rigtigt event uden betalingskort.',
		features: [
			'20 billeder pr. event',
			'7 dages opbevaring',
			'Download billeder efter festen',
		],
		cta: 'Start gratis',
	},
	{
		id: 'basic',
		name: 'Basic',
		price: '249 kr.',
		priceNote: 'pr. event',
		tagline: 'Rent, brandet og klar til et bryllup.',
		features: [
			'500 billeder pr. event',
			'15 dages opbevaring',
			'Custom eventtitel og accentfarve',
			'Download billeder efter festen',
		],
		cta: 'Vælg Basic',
		featured: true,
	},
	{
		id: 'gold',
		name: 'Gold',
		price: '499 kr.',
		priceNote: 'pr. event',
		tagline: 'Til store aftener og lange fester.',
		features: [
			'2.000 billeder pr. event',
			'1 måneds opbevaring',
			'Custom eventtitel og accentfarve',
			'15 sekunders videoklip',
			'Download billeder efter festen',
		],
		cta: 'Vælg Gold',
	},
]

function ctaHref(tier: TierId): string {
	const dest = `/app/events/new?tier=${tier}`
	if (isSignedIn) return dest
	return `/login?next=${encodeURIComponent(dest)}`
}
---

<Layout
	title="appelsin — live eventbilleder"
	description="Gæster scanner en QR-kode, uploader billeder fra deres telefon, og billederne vises live på storskærmen."
	locale="da"
>
	<div class="splash" aria-hidden="true">
		<img src="/logo.svg" alt="" width="320" height="320" />
	</div>

	<div class="page flex min-h-screen flex-col">
		<header class="flex items-start justify-between px-8 pt-6 sm:px-12 sm:pt-8">
			<a href="/" aria-label="appelsin.io forside" class="block">
				<img src="/logo.svg" alt="appelsin.io" width="110" height="110" />
			</a>
			<nav class="flex items-center gap-3 pt-4 text-sm sm:text-base">
				<a href={isSignedIn ? '/app' : '/login'} class="text-zinc-100 hover:text-orange-400">
					{isSignedIn ? 'Dine events' : 'Login'}
				</a>
				<span class="text-zinc-400">|</span>
				<a href="/terms" class="text-zinc-100 hover:text-orange-400">Vilkår</a>
				<span class="text-zinc-400">|</span>
				<a href="/privacy" class="text-zinc-100 hover:text-orange-400">Privatliv</a>
			</nav>
		</header>

		<main class="flex flex-1 flex-col items-center justify-center px-6 pb-24 pt-12 sm:px-12">
			<div class="mb-12 max-w-2xl text-center">
				<h1 class="text-3xl font-semibold text-white sm:text-4xl">
					Live eventbilleder på storskærmen.
				</h1>
				<p class="mt-4 text-base text-zinc-300 sm:text-lg">
					Gæster scanner en QR-kode, uploader fra telefonen, og billederne vises live på skærmen. Vælg en plan pr. event - ingen abonnementer.
				</p>
			</div>

			<div class="grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-3">
				{tiers.map((tier) => (
					<div
						class:list={[
							'flex flex-col rounded-md p-6 transition',
							tier.featured
								? 'bg-orange-500/20 ring-1 ring-orange-400/60'
								: 'bg-white/10 hover:bg-white/15',
						]}
					>
						<div class="flex items-baseline justify-between">
							<h2 class="text-xl font-semibold text-white">{tier.name}</h2>
							{tier.featured && (
								<span class="rounded-full bg-orange-400/90 px-2 py-0.5 text-xs font-medium text-zinc-900">
									Mest populær
								</span>
							)}
						</div>

						<div class="mt-4 flex items-baseline gap-2">
							<span class="text-4xl font-semibold text-white">{tier.price}</span>
							<span class="text-sm text-zinc-300">{tier.priceNote}</span>
						</div>

						<p class="mt-2 text-sm text-zinc-300">{tier.tagline}</p>

						<ul class="mt-6 space-y-2 text-sm text-zinc-100">
							{tier.features.map((feature) => (
								<li class="flex gap-2">
									<span class="text-orange-400" aria-hidden="true">✓</span>
									<span>{feature}</span>
								</li>
							))}
						</ul>

						<a
							href={ctaHref(tier.id)}
							class:list={[
								'mt-8 inline-flex justify-center rounded-md px-4 py-2 text-sm font-medium transition',
								tier.featured
									? 'bg-orange-400 text-zinc-900 hover:bg-orange-300'
									: 'bg-white/10 text-white hover:bg-white/20',
							]}
						>
							{tier.cta} →
						</a>
					</div>
				))}
			</div>

			<p class="mt-10 text-sm text-zinc-400">
				Alle planer inkluderer QR-pakke, live fotovæg, moderation og EU-hosting.
			</p>

			<section class="mt-24 w-full max-w-3xl">
				<h2 class="mb-8 text-center text-2xl font-semibold text-white">Ofte stillede spørgsmål</h2>
				<div class="space-y-2">
					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Skal mine gæster downloade en app?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Nej. Gæsterne scanner QR-koden med kameraet på deres telefon og uploader direkte i browseren. Ingen app, ingen konto.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Hvad sker der hvis vi når op til billed-grænsen?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Når grænsen er nået bliver nye uploads blokeret. Du kan slette afviste billeder for at frigøre pladser, eller opgradere eventet til en større plan. Free er beregnet til test — vælg Basic eller Gold til selve festen.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Hvad sker der med billederne efter eventet?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Eventet markeres automatisk som afsluttet 2 dage efter event-datoen. Du og dine gæster (med email) får et download-link sendt på mail. Billederne gemmes derefter i 7-30 dage afhængigt af plan, hvorefter alt slettes automatisk.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Kan jeg vise fotovæggen på en iPad eller computer?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Ja. Fotovæggen er bare en URL — åbn den i en browser på storskærm, iPad, laptop, eller projektor. Billederne opdateres live efterhånden som gæsterne uploader.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Kan jeg slette et billede der ikke skal vises?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Ja. Du kan slette enkeltbilleder fra event-dashboardet — de forsvinder fra fotovæggen øjeblikkeligt og inkluderes ikke i den endelige download.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Hvornår kan gæster begynde at uploade?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							24 timer før event-datoen åbner upload-vinduet, så folk der scanner QR'en aftenen før kan komme i gang. Eventet er live indtil 2 dage efter event-datoen, så seneste billeder fra natten og dagen efter også kommer med.
						</p>
					</details>

					<details class="group rounded-md bg-white/5 transition open:bg-white/10">
						<summary class="cursor-pointer list-none px-5 py-4 text-base font-medium text-white">
							<span class="mr-2 inline-block text-orange-400 group-open:rotate-45 transition">+</span>
							Hvor opbevares billederne?
						</summary>
						<p class="px-5 pb-4 text-sm leading-6 text-zinc-300">
							Alle billeder hostes på Cloudflare's EU-infrastruktur. Vi sælger ikke jeres data og bruger dem ikke til andet end at vise og levere billederne i den aftalte opbevaringsperiode.
						</p>
					</details>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.splash {
		position: fixed;
		inset: 0;
		display: grid;
		place-items: center;
		background: #071952;
		z-index: 50;
		animation: splash-out 0.5s ease-in 0.8s forwards;
	}

	.page {
		opacity: 0;
		animation: page-in 0.5s ease-out 1s forwards;
	}

	@keyframes splash-out {
		to {
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
	}

	@keyframes page-in {
		to {
			opacity: 1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.splash {
			animation: none;
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
		}
		.page {
			opacity: 1;
			animation: none;
		}
	}
</style>

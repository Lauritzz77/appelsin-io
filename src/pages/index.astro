---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import MarketingNav from '../components/marketing/MarketingNav.astro'
import MarketingFooter from '../components/marketing/MarketingFooter.astro'
import HeroPolaroids from '../components/marketing/HeroPolaroids.astro'
import PlanCard from '../components/marketing/PlanCard.astro'
import Button from '../components/brand/Button.astro'
import Icon from '../components/brand/Icon.astro'
import Accordion from '../components/brand/Accordion.astro'
import { formatPrice, type Tier as TierId } from '../lib/tiers'

const isSignedIn = !!Astro.locals.host

type Card = {
	id: TierId
	priceNote: string
	tagline: string
	features: string[]
	cta: string
	featured?: boolean
}

const cards: Card[] = [
	{
		id: 'free',
		priceNote: '1 aktivt event',
		tagline: 'Prøv Appelsin.io til et mindre event uden betalingskort.',
		features: ['20 billeder pr. event', '7 dages opbevaring', 'Download alle billeder efter festen'],
		cta: 'Start gratis',
	},
	{
		id: 'basic',
		priceNote: 'pr. event',
		tagline: 'Perfekt til bryllupper, fødselsdage og mindre fester.',
		features: [
			'500 billeder pr. event',
			'15 dages opbevaring',
			'Tilpas eventtitel og tekstfarve',
			'Download alle billeder efter festen',
		],
		cta: 'Vælg Basic',
		featured: true,
	},
	{
		id: 'gold',
		priceNote: 'pr. event',
		tagline: 'Til store fester, lange aftener og mange gæster.',
		features: [
			'2.000 billeder pr. event',
			'1 måneds opbevaring',
			'Tilpas eventtitel og tekstfarve',
			'15 sekunders videoklip',
			'Download alle billeder efter festen',
		],
		cta: 'Vælg Gold',
	},
]

function ctaHref(tier: TierId): string {
	const dest = `/app/events/new?tier=${tier}`
	if (isSignedIn) return dest
	return `/login?next=${encodeURIComponent(dest)}`
}

const steps = [
	{ ic: 'qr', n: '01', t: 'Scan koden', d: 'Gæsterne scanner QR-koden med telefonens kamera. Ingen app, intet login.' },
	{ ic: 'camera', n: '02', t: 'Upload et billede', d: 'De vælger et billede eller optager et klip — direkte fra telefonen.' },
	{ ic: 'monitor', n: '03', t: 'Live på skærmen', d: 'Billedet dukker op på fotovæggen med det samme, så alle kan følge med.' },
]

const faq = [
	{
		q: 'Skal mine gæster downloade en app?',
		a: 'Nej. Gæsterne scanner QR-koden med kameraet på deres telefon og uploader direkte i browseren. Ingen app, ingen konto.',
	},
	{
		q: 'Hvad sker der hvis vi når op til billed-grænsen?',
		a: 'Når grænsen er nået bliver nye uploads blokeret. Du kan slette afviste billeder for at frigøre pladser, eller opgradere eventet til en større plan. Free er beregnet til test — vælg Basic eller Gold til selve festen.',
	},
	{
		q: 'Hvad sker der med billederne efter eventet?',
		a: 'Eventet markeres automatisk som afsluttet 2 dage efter event-datoen. Du og dine gæster (med email) får et link til billedsamlingen sendt på mail. Billederne gemmes derefter i 7-30 dage afhængigt af plan, hvorefter alt slettes automatisk.',
	},
	{
		q: 'Kan jeg vise fotovæggen på en iPad eller computer?',
		a: 'Ja. Fotovæggen er bare en URL — åbn den i en browser på storskærm, iPad, laptop, eller projektor. Billederne opdateres live efterhånden som gæsterne uploader.',
	},
	{
		q: 'Kan jeg slette et billede der ikke skal vises?',
		a: 'Ja. Du kan slette enkeltbilleder fra event-dashboardet — de forsvinder fra fotovæggen øjeblikkeligt og inkluderes ikke i den endelige billedsamling.',
	},
	{
		q: 'Hvornår kan gæster begynde at uploade?',
		a: '24 timer før event-datoen åbner upload-vinduet, så folk der scanner QR’en aftenen før kan komme i gang. Eventet er live indtil 2 dage efter event-datoen, så seneste billeder fra natten og dagen efter også kommer med.',
	},
	{
		q: 'Hvor opbevares billederne?',
		a: 'Alle billeder hostes på Cloudflare’s EU-infrastruktur. Vi sælger ikke jeres data og bruger dem ikke til andet end at vise og levere billederne i den aftalte opbevaringsperiode.',
	},
]
---

<Layout
	title="appelsin — live eventbilleder"
	description="Gæster scanner en QR-kode, uploader billeder fra deres telefon, og billederne vises live på storskærmen."
	locale="da"
	surface="cream"
>
	<div class="mkt screen-root">
		{/* NAVY HERO BAND (nav + hero) */}
		<div class="hero-band band-navy">
			<div class="mkt-wrap">
				<MarketingNav locale="da" isSignedIn={isSignedIn} onDark />

				<section class="hero fu py-20">
					<div>
						<div class="font-hand mb-4 text-2xl font-bold tracking-[0.14em] text-accent">
							Til bryllup · fødselsdag · firmafest
						</div>
						<h1 class="hero-h1 uppercase">
							Festens billeder,<br /> samlet et sted.
						</h1>
						<p class="mt-[22px] mb-8 max-w-[480px] text-[19.5px] leading-[1.6] text-tx-2">
							Gæsterne scanner en QR-kode og uploader billeder direkte fra telefonen — ingen app. Alle billeder er samlet et sted, og du downloader hele festen bagefter.
						</p>
						<div class="hero-cta flex flex-wrap gap-[14px]">
							<Button href="#priser" size="lg">Se planer</Button>
						</div>
						<div class="mt-[30px] flex flex-wrap items-center gap-1 lg:gap-2.5 text-[14.5px]  text-tx-3">
							{
								['Gratis at prøve', 'Ingen app', 'Klar på 2 minutter'].map((t, i) => (
									<>
										{i > 0 && <span class="opacity-40">·</span>}
										<span>{t}</span>
									</>
								))
							}
						</div>
					</div>
					<HeroPolaroids locale="da" />
				</section>
			</div>
		</div>

		{/* CREAM: how it works + pricing */}
		<div class="mkt-wrap">
			<section class="pt-15 lg:pt-24 pb-12 lg:pb-16">
				<div class="steps">
					{
						steps.map((s) => (
							<div class="rounded-xl border border-cream-line bg-white p-7 shadow-cream-sm">
								<div class="mb-4 flex items-center gap-[14px]">
									<span class="flex h-[52px] w-[52px] items-center justify-center rounded-md bg-peach ">
										<Icon name={s.ic} size={26} stroke={2} />
									</span>
									<span class="font-mono text-3xl font-bold ">{s.n}</span>
								</div>
								<div class="mb-2 text-[21px] font-bold text-ink">{s.t}</div>
								<div class="text-base leading-[1.6] text-warm-body">{s.d}</div>
							</div>
						))
					}
				</div>
			</section>

			<section id="priser" class="scroll-mt-6 pt-[28px] pb-15 lg:pb-24">
				<div class="mb-10 text-center">
					<h2 class="m-0 text-[clamp(32px,4cqw,46px)] font-extrabold tracking-[-0.02em] text-ink">Én pris pr. event</h2>
					<p class="mt-3 text-[18px] text-warm-body">Vælg en plan til dagen. Ingen abonnementer, ingen overraskelser.</p>
				</div>
				<div class="pricing">
					{
						cards.map((c) => (
							<PlanCard
								name={c.id === 'free' ? 'Free' : c.id === 'basic' ? 'Basic' : 'Gold'}
								price={formatPrice(c.id, 'da')}
								priceNote={c.priceNote}
								tagline={c.tagline}
								features={c.features}
								cta={c.cta}
								href={ctaHref(c.id)}
								featured={c.featured}
								popularLabel="Mest populær"
							/>
						))
					}
				</div>
				<p class="mt-7 text-center text-[15px] text-warm-muted">
					Alle planer inkluderer QR-pakke, live fotovæg, moderation og EU-hosting.
				</p>
			</section>
		</div>

		{/* NAVY FAQ BAND */}
		<div class="faq-band band-navy">
			<div class="mx-auto max-w-[860px] px-5 lg:px-10">
				<section class="pt-[60px] pb-16">
					<div class="mb-9 text-center">
						<div class="font-hand text-2xl font-semibold text-accent">godt at vide</div>
						<h2 class="mt-0.5 text-[clamp(30px,4cqw,42px)] font-extrabold tracking-[-0.02em] text-white">
							Spørgsmål før festen?
						</h2>
					</div>
					<Accordion items={faq} tone="cream" />
				</section>
			</div>
		</div>

		{/* NAVY footer */}
		<div class="band-navy">
			<div class="mkt-wrap">
				<MarketingFooter locale="da" isSignedIn={isSignedIn} onDark />
			</div>
		</div>
	</div>
</Layout>

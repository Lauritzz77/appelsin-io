---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import MarketingNav from '../components/marketing/MarketingNav.astro'
import MarketingFooter from '../components/marketing/MarketingFooter.astro'
import HeroCollage from '../components/marketing/HeroCollage.astro'
import PlanCard from '../components/marketing/PlanCard.astro'
import Button from '../components/brand/Button.astro'
import Icon from '../components/brand/Icon.astro'
import Accordion from '../components/brand/Accordion.astro'
import { formatPrice, type Tier as TierId } from '../lib/tiers'

const isSignedIn = !!Astro.locals.host

type Card = {
	id: TierId
	priceNote: string
	tagline: string
	features: string[]
	cta: string
	featured?: boolean
}

const cards: Card[] = [
	{
		id: 'free',
		priceNote: 'Kun 1 aktivt event',
		tagline: 'Prøv det til et rigtigt event uden betalingskort.',
		features: ['20 billeder pr. event', '7 dages opbevaring', 'Download billeder efter festen'],
		cta: 'Start gratis',
	},
	{
		id: 'basic',
		priceNote: 'pr. event',
		tagline: 'Rent, brandet og klar til et bryllup.',
		features: [
			'500 billeder pr. event',
			'15 dages opbevaring',
			'Custom eventtitel og accentfarve',
			'Download billeder efter festen',
		],
		cta: 'Vælg Basic',
		featured: true,
	},
	{
		id: 'gold',
		priceNote: 'pr. event',
		tagline: 'Til store aftener og lange fester.',
		features: [
			'2.000 billeder pr. event',
			'1 måneds opbevaring',
			'Custom eventtitel og accentfarve',
			'15 sekunders videoklip',
			'Download billeder efter festen',
		],
		cta: 'Vælg Gold',
	},
]

function ctaHref(tier: TierId): string {
	const dest = `/app/events/new?tier=${tier}`
	if (isSignedIn) return dest
	return `/login?next=${encodeURIComponent(dest)}`
}
const startHref = ctaHref('basic')

const steps = [
	{ ic: 'qr', n: '01', t: 'Scan koden', d: 'Gæsterne scanner QR-koden med telefonens kamera. Ingen app, intet login.' },
	{ ic: 'camera', n: '02', t: 'Upload et billede', d: 'De vælger et billede eller optager et klip — direkte fra telefonen.' },
	{ ic: 'monitor', n: '03', t: 'Live på skærmen', d: 'Billedet dukker op på fotovæggen med det samme, så alle kan følge med.' },
]

const faq = [
	{
		q: 'Skal mine gæster downloade en app?',
		a: 'Nej. Gæsterne scanner QR-koden med kameraet på deres telefon og uploader direkte i browseren. Ingen app, ingen konto.',
	},
	{
		q: 'Hvad sker der hvis vi når op til billed-grænsen?',
		a: 'Når grænsen er nået bliver nye uploads blokeret. Du kan slette afviste billeder for at frigøre pladser, eller opgradere eventet til en større plan. Free er beregnet til test — vælg Basic eller Gold til selve festen.',
	},
	{
		q: 'Hvad sker der med billederne efter eventet?',
		a: 'Eventet markeres automatisk som afsluttet 2 dage efter event-datoen. Du og dine gæster (med email) får et download-link sendt på mail. Billederne gemmes derefter i 7-30 dage afhængigt af plan, hvorefter alt slettes automatisk.',
	},
	{
		q: 'Kan jeg vise fotovæggen på en iPad eller computer?',
		a: 'Ja. Fotovæggen er bare en URL — åbn den i en browser på storskærm, iPad, laptop, eller projektor. Billederne opdateres live efterhånden som gæsterne uploader.',
	},
	{
		q: 'Kan jeg slette et billede der ikke skal vises?',
		a: 'Ja. Du kan slette enkeltbilleder fra event-dashboardet — de forsvinder fra fotovæggen øjeblikkeligt og inkluderes ikke i den endelige download.',
	},
	{
		q: 'Hvornår kan gæster begynde at uploade?',
		a: '24 timer før event-datoen åbner upload-vinduet, så folk der scanner QR’en aftenen før kan komme i gang. Eventet er live indtil 2 dage efter event-datoen, så seneste billeder fra natten og dagen efter også kommer med.',
	},
	{
		q: 'Hvor opbevares billederne?',
		a: 'Alle billeder hostes på Cloudflare’s EU-infrastruktur. Vi sælger ikke jeres data og bruger dem ikke til andet end at vise og levere billederne i den aftalte opbevaringsperiode.',
	},
]
---

<Layout
	title="appelsin — live eventbilleder"
	description="Gæster scanner en QR-kode, uploader billeder fra deres telefon, og billederne vises live på storskærmen."
	locale="da"
	surface="cream"
>
	<div class="mkt screen-root">
		<div class="mkt-wrap">
			<MarketingNav locale="da" isSignedIn={isSignedIn} />

			{/* HERO */}
			<section class="hero fu">
				<div>
					<div
						class="hero-kicker"
						style="font-family:var(--hand);font-size:30px;line-height:1.15;font-weight:600;color:var(--orange-700);margin-bottom:8px"
					>
						del øjeblikkene, mens de sker
					</div>
					<h1 class="hero-h1">
						Festens billeder,<br />live på <span style="color:var(--orange)">storskærmen</span>.
					</h1>
					<p style="font-size:19.5px;line-height:1.6;color:var(--warm-body);max-width:480px;margin:22px 0 32px">
						Gæster scanner en QR-kode, uploader fra telefonen, og billederne dukker op på skærmen med det samme.
						Betal én gang pr. event — ingen abonnementer.
					</p>
					<div style="display:flex;gap:14px;flex-wrap:wrap">
						<Button href={startHref} size="lg" iconRight="arrow-right">Opret dit event</Button>
						<Button href="#priser" variant="secondary" size="lg">Se planer</Button>
					</div>
					<div
						style="display:flex;gap:22px;margin-top:30px;flex-wrap:wrap;color:var(--warm-muted);font-size:14.5px;font-weight:600"
					>
						{
							['Ingen app', 'Klar på 2 min', 'EU-hosting'].map((t) => (
								<span style="display:flex;align-items:center;gap:7px">
									<Icon name="check" size={15} stroke={3} class="text-[var(--orange-700)]" />
									{t}
								</span>
							))
						}
					</div>
				</div>
				<HeroCollage locale="da" />
			</section>

			{/* HOW IT WORKS */}
			<section style="padding:calc(20px*var(--d)) 0 calc(64px*var(--d))">
				<div class="steps">
					{
						steps.map((s) => (
							<div style="background:#fff;border-radius:var(--r-xl);padding:28px;border:1px solid var(--cream-line);box-shadow:var(--sh-cream-sm)">
								<div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
									<span style="width:52px;height:52px;border-radius:var(--r-md);background:var(--peach);color:var(--orange-700);display:flex;align-items:center;justify-content:center">
										<Icon name={s.ic} size={26} stroke={2} />
									</span>
									<span style="font-family:var(--mono);font-size:15px;font-weight:700;color:var(--warm-muted)">{s.n}</span>
								</div>
								<div style="font-size:21px;font-weight:700;color:var(--ink);margin-bottom:8px">{s.t}</div>
								<div style="font-size:16px;line-height:1.6;color:var(--warm-body)">{s.d}</div>
							</div>
						))
					}
				</div>
			</section>

			{/* PRICING */}
			<section id="priser" style="padding:calc(28px*var(--d)) 0;scroll-margin-top:24px">
				<div style="text-align:center;margin-bottom:40px">
					<h2 style="font-size:clamp(32px,4cqw,46px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:0">
						Én pris pr. event
					</h2>
					<p style="font-size:18px;color:var(--warm-body);margin-top:12px">
						Vælg en plan til dagen. Ingen abonnementer, ingen overraskelser.
					</p>
				</div>
				<div class="pricing">
					{
						cards.map((c) => (
							<PlanCard
								name={c.id === 'free' ? 'Free' : c.id === 'basic' ? 'Basic' : 'Gold'}
								price={formatPrice(c.id, 'da')}
								priceNote={c.priceNote}
								tagline={c.tagline}
								features={c.features}
								cta={c.cta}
								href={ctaHref(c.id)}
								featured={c.featured}
								popularLabel="Mest populær"
							/>
						))
					}
				</div>
				<p style="text-align:center;margin-top:28px;font-size:15px;color:var(--warm-muted)">
					Alle planer inkluderer QR-pakke, live fotovæg, moderation og EU-hosting.
				</p>
			</section>

			{/* FAQ */}
			<section style="padding:calc(56px*var(--d)) 0 calc(40px*var(--d));max-width:820px;margin:0 auto">
				<div style="text-align:center;margin-bottom:36px">
					<div style="font-family:var(--hand);font-size:27px;color:var(--orange-700);font-weight:600">godt at vide</div>
					<h2 style="font-size:clamp(30px,4cqw,42px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:2px 0 0">
						Spørgsmål før festen?
					</h2>
				</div>
				<Accordion items={faq} tone="cream" />
			</section>

			<MarketingFooter locale="da" isSignedIn={isSignedIn} />
		</div>
	</div>
</Layout>

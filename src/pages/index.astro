---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="mx-auto max-w-2xl px-6 py-24">
		<p class="mb-6 text-sm font-medium tracking-widest text-orange-400 uppercase">
			Appelsin
		</p>
		<h1 class="mb-6 text-5xl font-semibold tracking-tight text-balance">
			Live event photos, from every guest's phone to the big screen.
		</h1>
		<p class="mb-10 text-lg text-zinc-400">
			A QR code on the table. A web page on their phone. Photos appear on the
			screen in real time. No app to install.
		</p>
		<div class="rounded-lg border border-zinc-800 bg-zinc-900/50 px-5 py-4 text-sm text-zinc-400">
			Scaffold placeholder — host dashboard, guest upload page, and live
			display wall are next.
		</div>
	</main>
</Layout>

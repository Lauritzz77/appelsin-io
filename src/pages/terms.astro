---
import Layout from '../layouts/Layout.astro'
import Legal from '../components/marketing/Legal.astro'
---

<Layout title="Vilkår — appelsin" locale="da" surface="cream">
	<Legal
		locale="da"
		kind="terms"
		backLabel="Forside"
		badge="Sidst opdateret 1. juni 2026"
		title="Vilkår"
		paras={[
			'appelsin.io bruges til live deling af billeder ved events. Når du opretter eller bruger et event, accepterer du at bruge tjenesten ansvarligt og kun uploade indhold, du har ret til at dele.',
			'Eventværten er ansvarlig for at informere gæster om, hvordan billeder bruges ved eventet. Billeder kan vises live på eventets skærm og gemmes i den opbevaringsperiode, der hører til den valgte plan.',
			'Vi kan fjerne indhold eller lukke adgang, hvis tjenesten misbruges, eller hvis der uploades ulovligt, krænkende eller skadeligt indhold.',
			'Betalte eventpas og abonnementer håndteres via Stripe. Eventpas gælder for det enkelte event, mens abonnementer følger de betingelser, der vises ved køb.',
		]}
		contactPrefix="Kontakt os på "
		contactSuffix=", hvis du har spørgsmål til vilkårene."
	/>
</Layout>
